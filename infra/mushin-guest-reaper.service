[Unit]
Description=Mushin guest-account retention purge (PIPA)
After=mushin.service

[Service]
Type=oneshot
User=mushin
Group=mushin
WorkingDirectory=/opt/mushin/mushin
EnvironmentFile=/opt/mushin/.env
Environment=UV_CACHE_DIR=/opt/mushin/.uv-cache
ExecStart=/usr/local/bin/uv run python -m app.services.guest_reaper

ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
ReadWritePaths=/opt/mushin/data /opt/mushin/.uv-cache
ReadOnlyPaths=/opt/mushin
