{% extends "web/base.html.jinja2" %}

{% block title %}{{ card.name }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<div class="flex flex-col gap-6">

    {# 1. Activity identity + rename trigger #}
    <div class="flex items-center gap-2 pb-2">
        <div id="rename-heading" class="flex items-center gap-2">
            <h1 class="text-title font-semibold text-text-primary">{{ card.name }}</h1>
            <button
                type="button"
                aria-label="{{ strings.RENAME_LABEL }}"
                hx-get="/activities/{{ card.id }}/rename-form"
                hx-target="#rename-heading"
                hx-swap="innerHTML"
                class="min-h-tap min-w-tap flex items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ icon('pencil', size=16) }}</button>
        </div>
    </div>

    {# 2. Log button + panel #}
    <div>
        <button
            type="button"
            id="log-trigger-{{ card.id }}"
            aria-expanded="false"
            aria-controls="log-panel"
            hx-get="/activities/{{ card.id }}/log-inline"
            hx-target="#log-panel"
            hx-swap="innerHTML"
            hx-on:click="var b=this,p=document.getElementById('log-panel'),i=document.getElementById('log-trigger-icon-{{ card.id }}');var open=b.getAttribute('aria-expanded')==='true';b.setAttribute('aria-expanded',open?'false':'true');if(open){p.setAttribute('hidden','');p.innerHTML='';i.classList.remove('rotate-45')}else{p.removeAttribute('hidden');i.classList.add('rotate-45')}"
            hx-on::after-request="var p=document.getElementById('log-panel'),i=document.getElementById('log-trigger-icon-{{ card.id }}');if(p)p.removeAttribute('hidden');if(i)i.classList.remove('rotate-45');"
            hx-on:log-saved="var p=document.getElementById('log-panel');p&&!p.hidden&&(p.hidden=true,p.innerHTML='');var i=document.getElementById('log-trigger-icon-{{ card.id }}');i&&i.classList.remove('rotate-45');"
            class="flex w-full min-h-tap items-center justify-center gap-2 rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            <span class="transition-transform"
                id="log-trigger-icon-{{ card.id }}">{{ icon('plus', size=20) }}</span>
            {{ strings.SUBTALLY_LOG_BUTTON }}
        </button>
        <div id="log-panel" hidden class="mt-3"></div>
    </div>

    {# 3. Competition #}
    {% if record is not none %}
        {% include "components/competition_stats.html.jinja2" with context %}
    {% endif %}

    {# 4. Stats summary #}
    {% include "components/stats_summary.html.jinja2" with context %}

    {# 5. History #}
    <section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
        {% include "components/history.html.jinja2" with context %}
    </section>

    {# 6. Field stats — analytics tail, correctly last #}
    {% include "components/field_stats.html.jinja2" with context %}

</div>

{% if public_notice %}
<p class="text-caption text-text-muted">
    {{ public_notice }}
</p>
{% endif %}
{% endblock %}
