{% extends "web/base.html.jinja2" %}

{% block title %}{{ card.name }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
{% from "components/_icon.html.jinja2" import icon %}

{% if public_notice %}
<p class="text-caption text-text-muted">
    {{ public_notice }}
    <a href="{{ preview_visitor_url }}" class="underline underline-offset-2 hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">{{ strings.ACTIVITY_PREVIEW_VISITOR }}</a>
    <a href="{{ preview_connection_url }}" class="underline underline-offset-2 hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">{{ strings.ACTIVITY_PREVIEW_CONNECTION }}</a>
</p>
{% endif %}

<div class="flex flex-col gap-6">

    {# 1. Page header: back nav + activity identity + rename trigger #}
    <header class="flex flex-col gap-1 border-b border-border pb-4">
        <a
            href="{{ home_url }}"
            class="inline-flex items-center gap-1 text-caption text-text-muted transition hover:text-text-primary focus-visible:outline-offset-2"
        >
            {{ icon('chevron-left', size=14) }}{{ strings.DETAIL_BACK }}
        </a>
        {% if card.show_breadcrumb %}
        <p class="text-caption text-text-muted">{{ card.category_name }}</p>
        {% endif %}
        <div id="rename-heading">
            <div class="flex items-center gap-2">
                <h1 class="text-title font-semibold text-text-primary">{{ card.name }}</h1>
                <button
                    type="button"
                    aria-label="{{ strings.RENAME_LABEL }}"
                    hx-get="/activities/{{ card.id }}/rename-form"
                    hx-target="#rename-heading"
                    hx-swap="outerHTML"
                    class="min-h-tap min-w-tap flex items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ icon('pencil', size=16) }}</button>
            </div>
        </div>
    </header>

    {# 2. Hero zone: chrome-less numeral + progress + advance line #}
    {% include "components/activity_card.html.jinja2" with context %}

    {# 3. Log button + panel — below the hero, action follows context #}
    <div x-data="{ open: false }" @log-saved.window="open = false">
        <button
            type="button"
            id="log-trigger-{{ card.id }}"
            @click="open = !open"
            :aria-expanded="open"
            aria-controls="log-panel"
            hx-get="/activities/{{ card.id }}/log"
            hx-target="#log-panel"
            hx-swap="innerHTML"
            class="flex w-full min-h-tap items-center justify-center gap-2 rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            <span class="transition-transform" :class="{ 'rotate-45': open }">{{ icon('plus', size=20) }}</span>
            {{ strings.SUBTALLY_LOG_BUTTON }}
        </button>
        <div id="log-panel" x-show="open" class="mt-3"></div>
    </div>

    {# 4. Progression — core product promise, before match records #}
    {% if progression is not none %}
        {% include "components/progression_status.html.jinja2" with context %}
    {% endif %}

    {# 5. Competition — supporting detail after progression #}
    {% if record is not none %}
        {% include "components/competition_stats.html.jinja2" with context %}
    {% endif %}

    {# 6. Stats summary #}
    {% include "components/stats_summary.html.jinja2" with context %}

    {# 7. History #}
    <section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
        {% include "components/history.html.jinja2" with context %}
    </section>

    {# 7b. Comments — per-entry affordance, mirrors the read-only
       public_activity.html.jinja2 thread/composer. ``?c={entry_id}`` (from a
       notification click-through) auto-expands that one slot via
       hx-trigger="load"; every other slot stays collapsed until tapped. #}
    {% if entries %}
    <section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
        <h2 class="text-title font-semibold text-text-primary">{{ strings.HISTORY_LOG_TITLE }}</h2>
        <ul class="flex flex-col gap-2">
            {% for entry in entries %}
                <li class="flex flex-col gap-1">
                    <div class="flex items-start justify-between gap-2">
                        <span class="text-body text-text-primary">
                            <span class="text-caption text-text-muted">
                                {{- entry.occurred_at[:10] -}}
                                {%- if entry.time_known == 1 %}
                                    {{ entry.occurred_at | format_entry_time }}
                                {%- endif %}
                            </span>
                            {% if entry.memo %}
                                <span class="ms-2">{{ entry.memo }}</span>
                            {% endif %}
                        </span>
                        {% if entry.comment_count or can_comment %}
                        <button
                            type="button"
                            aria-label="{{ strings.COMMENTS_TOGGLE_ARIA }}"
                            hx-get="/@{{ username }}/{{ slug }}/entries/{{ entry.id }}/comments"
                            hx-target="#comment-slot-{{ entry.id }}"
                            hx-swap="innerHTML"
                            class="min-h-tap flex shrink-0 items-center gap-1 rounded px-1 text-caption text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                        >{{ icon('message-circle', size=16) }}{% if entry.comment_count %}<span>{{ strings.COMMENTS_COUNT_LABEL.format(count=entry.comment_count) }}</span>{% endif %}</button>
                        {% endif %}
                    </div>
                    {% if expand_comment_entry_id == entry.id %}
                    <div
                        id="comment-slot-{{ entry.id }}"
                        hx-get="/@{{ username }}/{{ slug }}/entries/{{ entry.id }}/comments"
                        hx-trigger="load"
                        hx-swap="innerHTML"
                    ></div>
                    {% else %}
                    <div id="comment-slot-{{ entry.id }}"></div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {# 8. Field stats — analytics tail, correctly last #}
    {% include "components/field_stats.html.jinja2" with context %}

</div>
{% endblock %}
