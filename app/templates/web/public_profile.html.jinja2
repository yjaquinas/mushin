{#
  Public profile (/@{username}) — read-only, unauthenticated or non-owner.

  Dedicated read-only template: zero write affordances. Do NOT include
  components that carry log/edit/tag forms (activity_card.html.jinja2's
  `linked` mode only adds a navigation link, but we render the card body inline
  here anyway to keep this template fully self-contained and auditable).

  Context: username, view_mode ("connected" | "public" | "limited"), cards
  (list, see app.routes.web._build_card_context — each card's own `linked`
  flag controls whether it's wrapped in an <a>; non-clickable for "limited").
#}
{% extends "web/base.html.jinja2" %}

{% block title %}{{ username }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
{% include "components/fellows_section.html.jinja2" with context %}

{% if viewer_logged_in %}
{% include "components/relationship_affordance.html.jinja2" with context %}
{% endif %}

{% if view_mode == "limited" %}
<p class="text-caption text-text-muted">{{ strings.PROFILE_LIMITED_NOTICE.format(username=username) }}</p>
{% endif %}

{% if not cards %}
<section class="flex flex-col gap-4 rounded-card border border-border bg-surface-1 p-4">
    <div class="flex flex-col gap-1">
        <h2 class="text-title font-semibold text-text-primary">{{ strings.PROFILE_ACTIVITIES_HEADING }}</h2>
    </div>
    <p class="text-body text-text-secondary">{{ strings.PROFILE_ACTIVITIES_EMPTY }}</p>
</section>
{% else %}
<div class="flex flex-col gap-3">
    {% for card in cards %}
    <article>
        {% if card.linked %}
        <a
            href="/@{{ username }}/{{ card.slug }}"
            class="flex flex-col rounded-card transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
        >
        {% else %}
        <div class="flex flex-col rounded-card">
        {% endif %}
            {% with activity_id=card.id, counts=card.counts, streaks=card.streaks, heatmap=card.heatmap, top_tags=card.top_tags, card_name=card.name %}
            {% include "components/stats_summary.html.jinja2" with context %}
            {% endwith %}
        {% if card.linked %}
        </a>
        {% else %}
        </div>
        {% endif %}
    </article>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
