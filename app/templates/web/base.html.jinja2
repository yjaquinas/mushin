<!DOCTYPE html>
<html lang="en"{% if theme in ("light", "dark") %} data-theme="{{ theme }}"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title | default(strings.APP_NAME) }}{% endblock %}</title>
    <link rel="stylesheet" href="/static/style.css">
    <script src="https://unpkg.com/htmx.org@2"></script>
    <script defer src="https://unpkg.com/hyperscript.org@0.9.13"></script>
    <script defer src="/static/js/theme.js"></script>
    <script defer src="/static/js/auth-form.js"></script>
</head>
<body
    class="flex flex-col bg-surface-0 min-h-screen text-text-primary text-body"
    {#
      Delegated on <body> rather than on the swap target itself: an
      hx-on::after-swap attribute on the element that's being replaced by its
      own outerHTML swap is unreliable -- empirically, htmx fires afterSwap
      for the new content before that content's own freshly-processed
      listener is reliably wired up for SOME swaps (e.g. the calendar's
      day-detail panel) but not others (e.g. the period-tab swap), with no
      visible difference in markup shape. Binding on <body>, which never
      itself gets swapped, sidesteps the race. See
      components/history.html.jinja2 for the [data-history-focus] marker
      this looks for.
    #}
    hx-on::after-swap="
        const active = event.target.querySelector && event.target.querySelector('[data-history-focus]');
        if (active) { active.focus(); }
    "
>
    <div class="bg-obsidian">
        <div class="mx-auto flex max-w-screen-md items-baseline justify-between gap-2 px-4 py-3">
            <a
                href="{{ home_url }}"
                class="flex items-baseline gap-2 focus-visible:outline-offset-2"
            >
                <span class="text-title font-semibold text-on-brand">{{ strings.APP_NAME }}</span>
                <span class="text-caption text-on-brand opacity-70">{{ strings.APP_NAME_HANJA }}</span>
            </a>
            <div class="flex items-center gap-1 text-on-brand [&_a]:text-on-brand [&_a:hover]:bg-brand-subtle [&_button]:text-on-brand [&_button:hover]:bg-brand-subtle">
                {% block search_link %}
                {% if home_url != "/" %}
                <a
                    href="/search"
                    aria-label="{{ strings.SEARCH_NAV_LABEL }}"
                    class="flex min-h-tap min-w-tap items-center justify-center rounded-button transition hover:bg-brand-subtle focus-visible:outline-offset-2"
                >
                    {% from "components/_icon.html.jinja2" import icon %}
                    {{ icon("search", size=22) }}
                </a>
                {% endif %}
                {% endblock %}
                {% block theme_toggle %}
                {% include "components/theme_toggle.html.jinja2" with context %}
                {% endblock %}
            </div>
        </div>
    </div>
    <main class="mx-auto flex w-full max-w-screen-md grow flex-col gap-4 p-4">
        {% block content %}{% endblock %}
    </main>
    <footer class="mx-auto flex w-full max-w-screen-md items-center justify-center gap-4 p-4">
        {% block footer %}
        <a
            href="/privacy"
            class="min-h-tap text-micro sm:text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
        >
            {{ strings.FOOTER_PRIVACY }}
        </a>
        <a
            href="/account"
            class="min-h-tap text-micro sm:text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
        >
            {{ strings.FOOTER_ACCOUNT }}
        </a>
        {% endblock %}
    </footer>
</body>
</html>
