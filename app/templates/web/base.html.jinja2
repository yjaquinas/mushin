<!DOCTYPE html>
<html lang="en"{% if theme in ("light", "dark") %} data-theme="{{ theme }}"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title | default(strings.APP_NAME) }}{% endblock %}</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js" integrity="sha384-H5SrcfygHmAuTDZphMHqBJLc3FhssKjG7w/CeCpFReSfwBWDTKpkzPP8c+cLsK+V" crossorigin="anonymous"></script>
    <script defer src="/static/js/dialogs.js"></script>
    <script defer src="/static/js/account-dialogs.js"></script>
    <script defer src="/static/js/auth-form.js"></script>
    <script defer src="/static/js/base-behavior.js"></script>
    <script defer src="/static/js/category-sheet.js"></script>
    <script defer src="/static/js/field-stats.js"></script>
    <script defer src="/static/js/log-sheet.js"></script>
</head>
<body class="flex flex-col bg-surface-0 min-h-screen text-text-primary text-body">
    {# Masthead — top bar with back button + centered title. Hidden on entry, home, and one-time-gate pages. #}
    {% if page_title %}
    <header class="mx-auto flex w-full max-w-screen-md items-center justify-between gap-2 px-4 py-3">
        {% if show_back and back_url %}
        <a
            href="{{ back_url }}"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
            aria-label="Back"
        >
                {{ icon('chevron-left', size=22) }}
        </a>
        {% else %}
        <span class="min-w-[44px]"></span>
        {% endif %}
        <h1 class="text-title font-semibold text-text-primary">{{ page_title }}</h1>
        <span class="min-w-[44px]"></span>
    </header>
    {% endif %}
    <main class="mx-auto flex w-full max-w-screen-md grow flex-col gap-4 px-4 py-4">
        {% block content %}{% endblock %}
    </main>

    {# Bottom navigation bar — always visible. #}
    <nav class="bottom-nav" aria-label="{{ strings.NAV_HOME }}">
        <a
            href="{{ home_url }}"
            class="bottom-nav-tab{% if current_page == 'home' %} bottom-nav-tab--active{% endif %}"
        >
            {{ icon("footprints", size=22) }}
            <span>{{ strings.NAV_HOME }}</span>
        </a>
        <a
            href="/search"
            class="bottom-nav-tab{% if current_page == 'search' %} bottom-nav-tab--active{% endif %}"
        >
            {{ icon("search", size=22) }}
            <span>{{ strings.NAV_SEARCH }}</span>
        </a>
        <a
            href="/account"
            class="bottom-nav-tab{% if current_page == 'account' %} bottom-nav-tab--active{% endif %}"
        >
            {{ icon("circle-user", size=22) }}
            <span>{{ strings.NAV_ACCOUNT }}</span>
        </a>
    </nav>
</body>
</html>
