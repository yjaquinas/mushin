<!DOCTYPE html>
<html lang="en"{% if theme in ("light", "dark") %} data-theme="{{ theme }}"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title | default(strings.APP_NAME) }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ static_asset('/static/style.css') }}">
    <link rel="icon" type="image/svg+xml" href="{{ static_asset('/static/favicon.svg') }}">
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js" integrity="sha384-H5SrcfygHmAuTDZphMHqBJLc3FhssKjG7w/CeCpFReSfwBWDTKpkzPP8c+cLsK+V" crossorigin="anonymous"></script>
    <script defer src="{{ static_asset('/static/js/common/toast.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/account/account-dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/activities/activity-dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/auth/auth-form.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/auth/logout.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/textareas.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/local-time.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/entry-form-defaults.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/entry-expansion.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/history-focus.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/tag-filter.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/tag-filter-events.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/activities/activity-sheet.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/field-stats.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/log-sheet.js') }}"></script>
</head>
<body class="flex flex-col bg-surface-0 min-h-screen text-text-primary text-body">
    {# Masthead — top bar with back button + centered title. Hidden on entry, home, and one-time-gate pages. #}
    {% if page_title %}
    <header class="mx-auto flex w-full max-w-screen-md items-center justify-between gap-2 px-4 py-3">
        {% if show_back and back_url %}
        <a
            href="{{ back_url }}"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
            aria-label="Back"
        >
                {{ icon('chevron-left', size=22) }}
        </a>
        {% else %}
        <span class="min-w-[44px]"></span>
        {% endif %}
        <h1 class="text-title font-semibold text-text-primary">{{ page_title }}</h1>
        {% if share_url or profile_url %}
        {% include "components/common/_profile_share_button.html.jinja2" with context %}
        {% else %}
        <span class="min-w-[44px]"></span>
        {% endif %}
    </header>
    {% endif %}
    <main class="mx-auto flex w-full max-w-screen-md grow flex-col gap-4 px-4 py-4">
        {% block content %}{% endblock %}
    </main>
    <div
        id="toast"
        hidden
        role="status"
        aria-live="polite"
        data-toast-variant="informative"
        class="pointer-events-none fixed left-1/2 top-6 z-50 w-[calc(100%-2rem)] max-w-screen-sm -translate-x-1/2 rounded-card border px-4 py-3 text-body shadow-soft"
    ></div>

    {# Bottom navigation bar — always visible, icon-only with accessible labels. #}
    <nav class="bottom-nav" aria-label="{{ strings.NAV_PROFILE }}">
        <div class="bottom-nav__inner">
            <a
                href="{{ home_url }}"
                class="bottom-nav-tab{% if current_page == 'profile' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_PROFILE }}"
            >
                {{ icon("circle-user", size=22) }}
            </a>
            <a
                href="/search"
                class="bottom-nav-tab{% if current_page == 'search' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_SEARCH }}"
            >
                {{ icon("search", size=22) }}
            </a>
            <a
                href="/account"
                class="bottom-nav-tab{% if current_page == 'settings' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_SETTINGS }}"
            >
                {{ icon("settings", size=22) }}
            </a>
        </div>
    </nav>
</body>
</html>
