<!DOCTYPE html>
<html lang="en"{% if theme in ("light", "dark") %} data-theme="{{ theme }}"{% endif %}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}{{ meta_description | default('') }}{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}{{ meta_robots | default('index, follow') }}{% endblock %}">

    {% block open_graph %}
    <meta property="og:title" content="{% block og_title %}{{ og_title | default(self.title()) }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ og_description | default(self.meta_description()) }}{% endblock %}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:url" content="{{ canonical_url(request) }}">
    <meta property="og:site_name" content="{{ strings.APP_NAME }}">
    <meta property="og:locale" content="en_US">
    <meta property="og:image" content="{{ og_image_url(og_image | default(none)) }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    {% endblock %}

    {% block twitter_card %}
    <meta name="twitter:card" content="{{ twitter_card_type | default('summary') }}">
    <meta name="twitter:title" content="{{ self.og_title() }}">
    <meta name="twitter:description" content="{{ self.og_description() }}">
    <meta name="twitter:image" content="{{ og_image_url(og_image | default(none)) }}">
    {% endblock %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600&display=swap">
    <link rel="canonical" href="{{ canonical_url(request) }}">
    {% block structured_data %}{% endblock %}

    <title>{% block title %}{{ title | default(strings.APP_NAME) }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ static_asset('/static/style.css') }}">
    <style>html[data-theme="dark"] .theme-light{display:none}html:not([data-theme="dark"]) .theme-dark{display:none}</style>
    <link rel="icon" type="image/png" href="{{ static_asset('/static/logo.png') }}">
    <link rel="apple-touch-icon" href="{{ static_asset('/static/logo.png') }}">
    <link rel="manifest" href="{{ static_asset('/static/manifest.json') }}">
    <script>(function(){if(document.cookie.indexOf('mushin_theme=')===-1){var t=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';document.documentElement.setAttribute('data-theme',t);document.cookie='mushin_theme='+t+';path=/;max-age=31536000;SameSite=Lax'}})();</script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js" integrity="sha384-H5SrcfygHmAuTDZphMHqBJLc3FhssKjG7w/CeCpFReSfwBWDTKpkzPP8c+cLsK+V" crossorigin="anonymous"></script>
    <script>htmx.config.processHidden = true;</script>
    <script defer src="{{ static_asset('/static/js/common/tab-navigation.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/toast.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/settings/settings-dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/settings/settings-forms.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/activities/activity-dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/auth/auth-form.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/auth/logout.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/textareas.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/local-time.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/sw-register.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/pwa-install.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/common/legal-dialog.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/entry-form-defaults.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/entry-expansion.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/history-focus.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/tag-filter.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/tag-filter-events.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/activities/activity-sheet.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/history/field-stats.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/entries/log-sheet.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/social/social-search.js') }}"></script>
</head>
{% set current_tab = current_page if (current_page is defined and current_page in ('notifications', 'profile', 'social', 'settings')) else none %}
<body
    class="flex flex-col bg-surface-0 min-h-screen text-text-primary text-body"
    hx-history="false"
    data-current-tab="{{ current_tab or '' }}"
>
     {# Masthead — top bar with centered title. Always rendered
        (hidden when no title) so JS can update it on tab switch. #}
    <header
        id="masthead-area"
        class="flex w-full items-center justify-center border-b border-border h-14"
        {% if not page_title %}hidden{% endif %}
    >
        {% if page_title %}
        <div class="flex w-full max-w-screen-md items-center justify-between gap-2 px-4">
            <span class="flex shrink-0 items-center">
                <img src="{{ static_asset('/static/logo.png') }}" alt="{{ strings.APP_NAME }}" class="theme-light h-7 w-auto">
                <img src="{{ static_asset('/static/logo-dark.png') }}" alt="{{ strings.APP_NAME }}" class="theme-dark h-7 w-auto">
            </span>
            <h1 class="text-title font-semibold text-text-primary truncate">{{ page_title }}</h1>
            {% if share_url or profile_url %}
            {% include "components/common/_profile_share_button.html.jinja2" with context %}
            {% else %}
            {% block header_right %}<span class="min-w-[44px]"></span>{% endblock %}
            {% endif %}
        </div>
        {% endif %}
    </header>
    <div
        id="pwa-install-banner"
        hidden
        class="flex w-full items-center justify-center border-b border-border bg-surface-1"
    >
        <div class="flex w-full max-w-screen-md items-center gap-3 px-4 py-3">
            <span class="hidden shrink-0 self-center sm:flex">{{ icon("arrow-down-tray", size=20) }}</span>
            <p
                id="pwa-install-text"
                class="flex-1 text-body text-text-primary whitespace-pre-line"
                data-default="{{ strings.PWA_INSTALL_TEXT }}"
                data-safari-ios="{{ strings.PWA_INSTALL_SAFARI_IOS_TEXT }}"
                data-safari-mac="{{ strings.PWA_INSTALL_SAFARI_MAC_TEXT }}"
            >
                {{ strings.PWA_INSTALL_TEXT }}
            </p>
            <div class="flex shrink-0 items-center gap-2">
                <button
                    id="pwa-install-btn"
                    type="button"
                    class="min-h-tap rounded-button bg-brand px-3 text-body font-medium text-on-brand transition hover:opacity-90 focus-visible:outline-offset-2"
                >
                    {{ strings.PWA_INSTALL_BUTTON }}
                </button>
            </div>
            <button
                id="pwa-install-close"
                type="button"
                class="flex min-h-tap min-w-tap shrink-0 items-center justify-center rounded-button text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                aria-label="{{ strings.TOAST_DISMISS }}"
            >
                {{ icon("x", size=20) }}
            </button>
        </div>
    </div>
    <main
        id="main-content"
        class="mx-auto flex w-full max-w-screen-md grow flex-col gap-4 px-4 py-4"
    >
        <div
            id="tab-profile"
            class="tab-panel flex flex-col gap-4{% if current_tab == 'profile' or current_tab == none %} tab-panel--active{% endif %}"
            data-tab="profile"
            aria-hidden="{{ 'false' if current_tab == 'profile' or current_tab == none else 'true' }}"
            {% if current_tab != 'profile' and current_tab != none %}hidden{% endif %}
        >
            {% block tab_profile %}{% block content %}{% endblock %}{% endblock %}
        </div>
        <div
            id="tab-social"
            class="tab-panel flex flex-col gap-4{% if current_tab == 'social' %} tab-panel--active{% endif %}"
            data-tab="social"
            aria-hidden="{{ 'false' if current_tab == 'social' else 'true' }}"
            {% if current_tab != 'social' %}hidden{% endif %}
        >
            {% block tab_social %}{% endblock %}
        </div>
        <div
            id="tab-notifications"
            class="tab-panel flex flex-col gap-4{% if current_tab == 'notifications' %} tab-panel--active{% endif %}"
            data-tab="notifications"
            aria-hidden="{{ 'false' if current_tab == 'notifications' else 'true' }}"
            {% if current_tab != 'notifications' %}hidden{% endif %}
        >
            {% block tab_notifications %}{% endblock %}
        </div>
        <div
            id="tab-settings"
            class="tab-panel{% if current_tab == 'settings' %} tab-panel--active{% endif %}"
            data-tab="settings"
            aria-hidden="{{ 'false' if current_tab == 'settings' else 'true' }}"
            {% if current_tab != 'settings' %}hidden{% endif %}
        >
            {% block tab_settings %}{% endblock %}
        </div>
    </main>
    <div
        id="toast"
        hidden
        role="status"
        aria-live="polite"
        data-toast-variant="informative"
        class="fixed left-1/2 top-6 z-50 flex w-[calc(100%-2rem)] max-w-screen-sm -translate-x-1/2 items-center gap-2 rounded-card border px-4 py-2 text-body shadow-soft cursor-pointer select-none"
    >
        <span id="toast-text" class="flex-1"></span>
    </div>

    {# Bottom navigation bar — visible only on tabbed pages (profile/social/settings). #}
    {% if current_tab is not none %}
    <nav class="bottom-nav" aria-label="{{ strings.NAV_APP }}">
        <div class="bottom-nav__inner">
            <a
                href="{{ home_url }}"
                class="bottom-nav-tab{% if current_tab == 'profile' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_PROFILE }}"
                {% if current_tab == 'profile' %}aria-current="page"{% endif %}
                data-tab="profile"
            >
                {{ icon("user", size=22) }}
            </a>
            <a
                href="/social"
                class="bottom-nav-tab{% if current_tab == 'social' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_SOCIAL }}"
                {% if current_tab == 'social' %}aria-current="page"{% endif %}
                data-tab="social"
            >
                {{ icon("compass", size=22) }}
            </a>
            <a
                href="/notifications"
                class="bottom-nav-tab{% if current_tab == 'notifications' %} bottom-nav-tab--active{% endif %} relative"
                aria-label="{{ strings.NAV_NOTIFICATIONS }}"
                {% if current_tab == 'notifications' %}aria-current="page"{% endif %}
                data-tab="notifications"
            >
                <span class="bottom-nav-icon">
                    {{ icon("bell", size=22) }}
                    {% if unseen_notifications %}
                    <span class="bottom-nav-badge">
                        {{ "9+" if unseen_notifications >= 9 else unseen_notifications }}
                    </span>
                    {% endif %}
                </span>
            </a>
            <a
                href="/settings"
                class="bottom-nav-tab{% if current_tab == 'settings' %} bottom-nav-tab--active{% endif %}"
                aria-label="{{ strings.NAV_SETTINGS }}"
                {% if current_tab == 'settings' %}aria-current="page"{% endif %}
                data-tab="settings"
            >
                {{ icon("cog", size=22) }}
            </a>
        </div>
    </nav>
    {% endif %}
</body>
</html>
