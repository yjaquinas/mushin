{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.ACCOUNT_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
{% if flash_message %}
<p
    role="status"
    class="rounded-card border border-border bg-surface-2 px-4 py-2 text-caption font-medium text-text-primary"
    data-flash-dismiss
>{{ flash_message }}</p>
{% include "components/flash_dismiss.html.jinja2" %}
{% endif %}

{# Visibility/share-link section is non-guest only — guests have no username
   and thus no public profile (see .claude/rules/repo-wide.md). #}
{% if not is_guest %}
<section class="flex flex-col gap-4">
    <div class="flex flex-col gap-1">
        <h2 class="text-body font-semibold text-text-primary">{{ strings.ACCOUNT_VISIBILITY_HEADING }}</h2>
        <p class="text-caption text-text-secondary">
            {{ strings.ACCOUNT_VISIBILITY_SHARE_LINK.format(username=username) }}
        </p>
    </div>

    <form method="post" action="/account" class="flex flex-col gap-4" id="visibility-form">
        <fieldset class="flex flex-col gap-3">
            <legend class="sr-only">{{ strings.ACCOUNT_VISIBILITY_HEADING }}</legend>

            <label class="flex cursor-pointer items-start gap-3 rounded-card border border-border bg-surface-1 px-4 py-3 transition hover:bg-surface-2 has-[:checked]:border-brand">
                <input
                    type="radio"
                    name="visibility"
                    value="private"
                    {% if visibility != "public" %}checked{% endif %}
                    class="mt-1 focus-visible:outline-offset-2"
                >
                <span class="flex flex-col gap-1">
                    <span class="text-body font-medium text-text-primary">{{ strings.ACCOUNT_VISIBILITY_PRIVATE_LABEL }}</span>
                    <span class="text-caption text-text-secondary">{{ strings.ACCOUNT_VISIBILITY_PRIVATE_DESC }}</span>
                </span>
            </label>

            <label class="flex cursor-pointer items-start gap-3 rounded-card border border-border bg-surface-1 px-4 py-3 transition hover:bg-surface-2 has-[:checked]:border-brand">
                <input
                    type="radio"
                    name="visibility"
                    value="public"
                    {% if visibility == "public" %}checked{% endif %}
                    class="mt-1 focus-visible:outline-offset-2"
                >
                <span class="flex flex-col gap-1">
                    <span class="text-body font-medium text-text-primary">{{ strings.ACCOUNT_VISIBILITY_PUBLIC_LABEL }}</span>
                    <span class="text-caption text-text-secondary">{{ strings.ACCOUNT_VISIBILITY_PUBLIC_DESC }}</span>
                </span>
            </label>
        </fieldset>

        <button
            type="submit"
            class="flex min-h-tap w-full items-center justify-center rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
        >
            {{ strings.ACCOUNT_VISIBILITY_SAVE }}
        </button>
    </form>

    {# Disable save button when selected visibility matches current visibility. #}
    <script>
    (function() {
      var form = document.getElementById('visibility-form');
      if (!form) return;
      var radios = form.querySelectorAll('input[name="visibility"]');
      var saveBtn = form.querySelector('button[type="submit"]');
      var current = '{{ visibility }}';

      function checkVisibilityBtn() {
        var selected = '';
        for (var i = 0; i < radios.length; i++) {
          if (radios[i].checked) { selected = radios[i].value; break; }
        }
        saveBtn.disabled = selected === current;
      }

      checkVisibilityBtn();
      for (var i = 0; i < radios.length; i++) {
        radios[i].addEventListener('change', checkVisibilityBtn);
      }
      document.addEventListener('htmx:afterSwap', checkVisibilityBtn);
    })();
    </script>
</section>
{% endif %}

{# Theme toggle — available to every account. #}
<section class="flex flex-col gap-4 border-t border-border pt-4">
    <h2 class="text-body font-semibold text-text-primary">Theme</h2>
    {% include "components/theme_toggle_account.html.jinja2" with context %}
</section>

{# Data actions: export / import — available to every account, including guests. #}
<section class="flex flex-col gap-4 border-t border-border pt-4">
    <h2 class="text-body font-semibold text-text-primary">Data</h2>
    <div class="flex gap-3">
        <a
            href="/export"
            class="flex min-h-tap flex-1 items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            {% from "components/_icon.html.jinja2" import icon %}
            {{ icon("arrow-up-tray", size=18) }}
            {{ strings.FOOTER_EXPORT_ENTRIES }}
        </a>
        {% include "components/import_data_dialog.html.jinja2" with context %}
        <button
            type="button"
            id="import-open-button"
            hx-on:click="document.getElementById('import-data-dialog').removeAttribute('hidden')"
            class="flex min-h-tap flex-1 items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            {% from "components/_icon.html.jinja2" import icon %}
            {{ icon("arrow-down-tray", size=18) }}
            {{ strings.FOOTER_IMPORT_ENTRIES }}
        </button>
    </div>
</section>

{# Session actions: logout #}
<section class="flex flex-col gap-4 border-t border-border pt-4">
    <h2 class="text-body font-semibold text-text-primary">Session</h2>
    <button
        type="button"
        id="logout-button"
        hx-post="/auth/logout"
        hx-swap="none"
        hx-on::after-request="if(event.detail.successful)window.location.href='/'"
        class="flex min-h-tap w-full items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
    >
        {% from "components/_icon.html.jinja2" import icon %}
        {{ icon("circle-user", size=18) }}
        {{ strings.FOOTER_LOGOUT }}
    </button>
</section>

{# Danger zone: delete account — only for non-guest accounts. #}
{% if not is_guest %}
<section class="flex flex-col gap-4 border-t border-border pt-4">
    <h2 class="text-body font-semibold text-text-primary">Danger zone</h2>
    <button
        type="button"
        id="delete-open-button"
        hx-on:click="document.getElementById('delete-account-dialog').removeAttribute('hidden')"
        class="flex min-h-tap w-full items-center justify-center gap-2 rounded-button border border-danger bg-danger-subtle px-4 py-3 text-body font-semibold text-danger transition hover:opacity-90 focus-visible:outline-offset-2"
    >
        {% from "components/_icon.html.jinja2" import icon %}
        {{ icon("trash", size=18) }}
        {{ strings.FOOTER_DELETE_DATA }}
    </button>

    {# Delete-account confirm dialog. #}
    <div
        id="delete-account-dialog"
        hidden
        class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
        role="presentation"
    >
        <div
            role="dialog"
            aria-modal="true"
            aria-labelledby="delete-account-title"
            class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
        >
            <h2 id="delete-account-title" class="text-body font-semibold text-text-primary">
                {{ strings.DELETE_DATA_TITLE }}
            </h2>
            <p class="text-caption text-text-secondary">{{ strings.DELETE_DATA_BODY }}</p>

            <form
                hx-post="/delete"
                hx-swap="none"
                hx-on::after-request="if(event.detail.successful)window.location.href='/'"
                class="flex flex-col gap-3"
            >
                <button
                    type="submit"
                    hx-disabled-elt="this"
                    class="min-h-tap w-full rounded-button bg-danger px-4 py-3 text-body font-semibold text-white transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 disabled:opacity-60"
                >
                    {{ strings.DELETE_DATA_CONFIRM }}
                </button>
                <button
                    type="button"
                    id="delete-cancel-button"
                    hx-on:click="document.getElementById('delete-account-dialog').setAttribute('hidden','')"
                    class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >
                    {{ strings.DELETE_DATA_CANCEL }}
                </button>
            </form>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}
