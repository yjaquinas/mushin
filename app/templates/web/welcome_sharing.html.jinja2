{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.VISIBILITY_CONSENT_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<header class="flex flex-col gap-2 py-2">
    <h1 class="text-title font-semibold text-text-primary">{{ strings.VISIBILITY_CONSENT_TITLE }}</h1>
    <p class="text-body text-text-secondary">{{ strings.VISIBILITY_CONSENT_INTRO }}</p>
</header>

<form method="post" action="/welcome-sharing" class="flex flex-col gap-4">
    <fieldset class="flex flex-col gap-3">
        <legend class="sr-only">{{ strings.VISIBILITY_CONSENT_TITLE }}</legend>

        <label class="flex cursor-pointer items-start gap-3 rounded-card border border-border bg-surface-1 px-4 py-3 transition hover:bg-surface-2 has-[:checked]:border-brand">
            <input
                type="radio"
                name="visibility"
                value="private"
                checked
                class="mt-1 focus-visible:outline-offset-2"
            >
            <span class="flex flex-col gap-1">
                <span class="text-body font-medium text-text-primary">{{ strings.VISIBILITY_CONSENT_PRIVATE_LABEL }}</span>
                <span class="text-caption text-text-secondary">{{ strings.VISIBILITY_CONSENT_PRIVATE_DESC }}</span>
            </span>
        </label>

        <label class="flex cursor-pointer items-start gap-3 rounded-card border border-border bg-surface-1 px-4 py-3 transition hover:bg-surface-2 has-[:checked]:border-brand">
            <input
                type="radio"
                name="visibility"
                value="public"
                class="mt-1 focus-visible:outline-offset-2"
            >
            <span class="flex flex-col gap-1">
                <span class="text-body font-medium text-text-primary">{{ strings.VISIBILITY_CONSENT_PUBLIC_LABEL }}</span>
                <span class="text-caption text-text-secondary">{{ strings.VISIBILITY_CONSENT_PUBLIC_DESC }}</span>
            </span>
        </label>
    </fieldset>

    <p class="text-caption text-text-secondary">
        {{ strings.VISIBILITY_CONSENT_PRIVACY_PREFIX }}
        <a
            href="/privacy"
            class="underline underline-offset-2 hover:no-underline focus-visible:outline-offset-2"
        >{{ strings.VISIBILITY_CONSENT_PRIVACY_LINK_TEXT }}</a>
        {{ strings.VISIBILITY_CONSENT_PRIVACY_SUFFIX }}
    </p>

    <button
        type="submit"
        class="flex min-h-tap w-full items-center justify-center rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2"
    >
        {{ strings.VISIBILITY_CONSENT_SUBMIT }}
    </button>
</form>
{% endblock %}

{# One-time gate: no skip link, and the footer's data/logout controls are
   suppressed so the only way forward is to choose. Privacy link stays. #}
{% block footer %}
<a
    href="/privacy"
    class="text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
>
    {{ strings.FOOTER_PRIVACY }}
</a>
{% endblock %}
