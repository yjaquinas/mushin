{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.SEARCH_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<div class="flex flex-col gap-1">
    <label for="search-input" class="text-caption font-medium text-text-secondary">
        {{ strings.SEARCH_INPUT_LABEL }}
    </label>
    <input
        type="search"
        id="search-input"
        name="q"
        placeholder="{{ strings.SEARCH_INPUT_PLACEHOLDER }}"
        autocomplete="off"
        hx-get="/search/results"
        hx-trigger="input changed delay:300ms, search"
        hx-target="#search-results"
        hx-swap="innerHTML"
        class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
    >
</div>

<div id="search-results">
    {% include "components/search/search_results.html.jinja2" with context %}
</div>
{% endblock %}
