{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.HOME_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
{% from "components/_icon.html.jinja2" import icon %}

{% if flash_message %}
<p
    role="status"
    class="rounded-card border border-border bg-surface-2 px-4 py-2 text-caption font-medium text-text-primary"
    data-flash-dismiss
>{{ flash_message }}</p>
{% include "components/flash_dismiss.html.jinja2" %}
{% endif %}

<header class="flex items-center gap-2 py-2">
    <h1 class="sr-only">{{ strings.HOME_TITLE }}</h1>
    {% if unseen_comments %}
    <a
        href="/comments"
        aria-label="{{ strings.COMMENTS_UNSEEN_ARIA }}"
        class="flex min-h-tap min-w-tap items-center justify-center rounded-full bg-brand-subtle px-2 text-caption font-medium text-text-secondary transition hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    >{{ icon('message-circle', size=14) }}<span class="ms-1">{{ strings.COMMENTS_UNSEEN_BADGE.format(count=unseen_comments) }}</span></a>
    {% endif %}
</header>

{% include "components/fellows_section.html.jinja2" with context %}

{% if not cards %}
<div id="home-empty-state" class="flex flex-col items-center gap-3 py-12 text-center">
    <span class="text-[length:var(--spacing-icon-lg)] leading-none text-text-muted" aria-hidden="true">{{ strings.APP_NAME_HANJA }}</span>
    <p class="text-title font-medium text-text-primary">{{ strings.HOME_EMPTY }}</p>
    <p class="text-body text-text-secondary">{{ strings.APP_GLOSS }}</p>
</div>
{% endif %}

<div id="cards" class="flex flex-col gap-3"
     hx-on::after-swap="var e=document.getElementById('home-empty-state');if(e){var c=this.querySelectorAll('[id^=card-]');if(c.length>0)e.remove();}"
>
<script>
(function() {
  document.body.addEventListener("htmx:afterSwap", function(event) {
    if (event.detail.target.id !== "cards") return;
    var e = document.getElementById("home-empty-state");
    if (e) {
      var cards = document.querySelectorAll("#cards > [id^=card-]");
      if (cards.length > 0) e.remove();
    }
    var f = document.getElementById("add-activity-form");
    if (f && f.getAttribute("hidden") === "") {
      f.setAttribute("hidden", "");
      var b = document.getElementById("add-activity-inline");
      if (b) b.removeAttribute("hidden");
    }
  });
})();
</script>
    {% if not cards %}
    <div id="add-activity-inline">
        <button
            type="button"
            hx-on:click="var b=this,f=document.getElementById('add-activity-form');if(b)b.setAttribute('hidden','');if(f)f.removeAttribute('hidden');document.getElementById('category-name').focus();"
            class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2"
        >
            {{ strings.HOME_ADD_ACTIVITY }}
        </button>

        <form
            id="add-activity-form"
            hidden
            hx-post="/activities"
            hx-target="#cards"
            hx-swap="afterbegin"
            class="flex flex-col gap-4"
        >
            <div class="flex flex-col gap-1">
                <label for="category-name" class="text-caption font-medium text-text-secondary">
                    {{ strings.ACTIVITY_FORM_NAME_LABEL }}
                </label>
                <input
                    type="text"
                    id="category-name"
                    name="name"
                    required
                    placeholder="{{ strings.ACTIVITY_FORM_NAME_PLACEHOLDER }}"
                    class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
                >
            </div>

            <div class="flex gap-2">
                <button
                    type="button"
                    hx-on:click="var f=document.getElementById('add-activity-form'),b=this.closest('#add-activity-inline').querySelector('button');if(f)f.setAttribute('hidden','');if(b)b.removeAttribute('hidden');"
                    class="min-h-tap flex-1 rounded-button border border-border px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ACTIVITY_FORM_CANCEL }}
                </button>
                <button
                    type="submit"
                    hx-disabled-elt="this"
                    class="min-h-tap flex-1 rounded-button bg-brand px-4 py-3 text-body font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
                >
                    {{ strings.ACTIVITY_FORM_SUBMIT }}
                </button>
            </div>
        </form>
    </div>

    <p class="text-center text-caption text-text-secondary">{{ strings.HOME_EXAMPLES_HINT }}</p>
    {% for example in examples %}
        <form hx-post="/activities" hx-target="#cards" hx-swap="afterbegin">
            <input type="hidden" name="name" value="{{ example.name }}">
            <button
                type="submit"
                class="flex min-h-tap w-full items-center justify-between gap-2 rounded-card border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
            >
                <span>{{ example.name }}</span>
                <span class="text-caption text-text-muted">{{ strings.HOME_EXAMPLE_ADD }}</span>
            </button>
        </form>
    {% endfor %}
    {% else %}
    {% for card in cards %}
        {% include "components/activity_card.html.jinja2" with context %}
    {% endfor %}
    <div id="add-activity-inline">
        <button
            type="button"
            hx-on:click="var b=this,f=document.getElementById('add-activity-form');if(b)b.setAttribute('hidden','');if(f)f.removeAttribute('hidden');document.getElementById('category-name').focus();"
            class="flex min-h-tap w-full items-center gap-2 rounded-card border border-dashed border-border bg-transparent px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            <span aria-hidden="true">{{ icon("plus", size=20) }}</span>
            {{ strings.HOME_ADD_ACTIVITY }}
        </button>

        <form
            id="add-activity-form"
            hidden
            hx-post="/activities"
            hx-target="#cards"
            hx-swap="afterbegin"
            class="flex flex-col gap-4"
        >
            <div class="flex flex-col gap-1">
                <label for="category-name" class="text-caption font-medium text-text-secondary">
                    {{ strings.ACTIVITY_FORM_NAME_LABEL }}
                </label>
                <input
                    type="text"
                    id="category-name"
                    name="name"
                    required
                    placeholder="{{ strings.ACTIVITY_FORM_NAME_PLACEHOLDER }}"
                    class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
                >
            </div>

            <div class="flex gap-2">
                <button
                    type="button"
                    hx-on:click="var f=document.getElementById('add-activity-form'),b=this.closest('#add-activity-inline').querySelector('button');if(f)f.setAttribute('hidden','');if(b)b.removeAttribute('hidden');"
                    class="min-h-tap flex-1 rounded-button border border-border px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ACTIVITY_FORM_CANCEL }}
                </button>
                <button
                    type="submit"
                    hx-disabled-elt="this"
                    class="min-h-tap flex-1 rounded-button bg-brand px-4 py-3 text-body font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
                >
                    {{ strings.ACTIVITY_FORM_SUBMIT }}
                </button>
            </div>
        </form>
    </div>
    {% endif %}
</div>

{# Quick-add sheet target: empty until a card's "Log" button swaps in the
   form fragment (see GET /activities/{id}/log). #}
<div id="sheet"></div>
{% endblock %}
