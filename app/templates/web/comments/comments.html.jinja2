{#
  Comment notification history (GET /comments).
  Context: comments, username, has_more, next_before_id
#}
{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.COMMENTS_PAGE_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<header class="flex items-center gap-2 py-2">
    <h1 class="flat-section-title">{{ strings.COMMENTS_PAGE_TITLE }}</h1>
</header>

{% if not comments %}
<p class="py-8 text-center text-body text-text-secondary">{{ strings.COMMENTS_PAGE_EMPTY }}</p>
{% else %}
<ul class="flat-list">
    {% for comment in comments %}
    <li>
        <a
            href="/@{{ username }}/{{ comment.activity_slug }}?entry_id={{ comment.entry_id }}#comment-slot-{{ comment.entry_id }}"
            class="flex min-h-tap flex-col gap-1 px-4 py-3 transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            <div class="flex items-baseline justify-between gap-2">
                <span class="text-caption font-medium text-text-secondary">
                    {{ comment.activity_name }}
                </span>
                <span class="flex items-center gap-2 text-caption text-text-muted">
                    {% if comment.is_new %}
                    <span
                        aria-label="{{ strings.COMMENTS_PAGE_NEW_BADGE_ARIA }}"
                        class="h-2 w-2 rounded-full bg-brand"
                    ></span>
                    {% endif %}
                    <span data-local-timestamp="{{ comment.created_at }}" hidden>{{ comment.created_at | format_comment_timestamp }}</span>
                </span>
            </div>
            <p class="line-clamp-1 text-body text-text-primary">
                <span class="font-medium text-text-secondary">{{ comment.author_username }}</span>
                {% if comment.hidden_at %}
                <span class="ms-1 italic text-text-muted">{{ strings.COMMENTS_HIDDEN_BY_MODERATOR }}</span>
                {% else %}
                <span class="ms-1">{{ comment.body }}</span>
                {% endif %}
            </p>
        </a>
    </li>
    {% endfor %}
</ul>

{% if has_more %}
<a
    href="/comments?before_id={{ next_before_id }}"
    class="flex min-h-tap items-center justify-center text-body text-text-secondary underline-offset-2 hover:underline focus-visible:outline-offset-2"
>{{ strings.COMMENTS_PAGE_SHOW_OLDER }}</a>
{% endif %}
{% endif %}
{% endblock %}
