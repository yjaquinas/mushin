{% extends "web/base.html.jinja2" %}

{% block title %}{{ card.name }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<div class="flex flex-col gap-4">
    <a href="{{ home_url }}" class="flex items-center gap-1 text-body text-text-secondary hover:text-text-primary transition">
        {{ icon('chevron-left', size=16) }} {{ strings.ACTIVITY_BACK_TO_PROFILE }}
    </a>
    {# 1. Summary card #}
    {% with card_name=card.name, average_weekly_count=card.average_weekly_count, title_editable=true, show_top_tags=false, is_secret=card.secret %}
    {% include "components/history/stats_summary.html.jinja2" with context %}
    {% endwith %}

    {# 2. Log button #}
    <div>
        <button
            type="button"
            id="activity-button-log-{{ card.id }}"
            aria-expanded="false"
            aria-controls="activity-target-log-sheet"
            data-log-trigger
            hx-get="/activities/{{ card.id }}/log"
            hx-target="#activity-target-log-sheet"
            hx-swap="innerHTML"
            class="flex w-full min-h-tap items-center justify-center gap-2 rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            <span class="transition-transform"
                id="activity-icon-log-{{ card.id }}">{{ icon('plus', size=20) }}</span>
            {{ strings.SUBTALLY_LOG_BUTTON }}
        </button>
    </div>

    <div class="h-px bg-border" aria-hidden="true"></div>

    {# 3. History #}
    <section class="flat-section py-4">
        {% include "components/history/history.html.jinja2" with context %}
    </section>

    {% if field_stats.tag_groups or field_stats.scales %}
    <div class="h-px bg-border" aria-hidden="true"></div>
    {% endif %}

    {# 6. Field stats — analytics tail, correctly last #}
    {% include "components/history/field_stats.html.jinja2" with context %}

    <div class="flex flex-col gap-3 pt-2">
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/delete-confirm"
            hx-target="#activity-dialog-delete"
            hx-swap="outerHTML"
            class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-danger transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            {{ strings.ACTIVITY_DELETE }}
        </button>
    </div>

</div>

<div id="activity-dialog-rename"></div>
<div id="activity-dialog-delete"></div>
<div id="activity-target-log-sheet"></div>
{% endblock %}
