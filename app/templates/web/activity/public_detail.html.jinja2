{#
  Public activity detail (/@{username}/{slug}) — read-only.
  Context: username, view_mode, card, slug, record/timeline/head_to_head,
  counts, streaks, field_stats, activity_id, history.
#}
{% extends "web/base.html.jinja2" %}

{% block title %}{% if card %}{{ card.name }} · {% endif %}{{ username }} · {{ strings.APP_NAME }}{% endblock %}

{% block tab_social %}
<div class="flex flex-col gap-6">
    <a href="/social/@{{ username }}" class="flex items-center gap-1 text-caption text-text-secondary hover:text-text-primary transition">
        {{ icon('chevron-left', size=16) }} {{ strings.PROFILE_VISIT.format(username=username) }}
    </a>
    {% with card_name=card.name, average_weekly_count=card.average_weekly_count, show_top_tags=false %}
    {% include "components/history/stats_summary.html.jinja2" with context %}
    {% endwith %}

    {# Merged calendar/log view #}
    <section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
        {% include "components/history/history.html.jinja2" with context %}
    </section>

    {# Field stats — analytics tail, correctly last #}
    {% include "components/history/field_stats.html.jinja2" with context %}
</div>
{% endblock %}
