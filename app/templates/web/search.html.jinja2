{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.SEARCH_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block content %}
<header class="flex items-center gap-2 py-2">
    <a
        href="{{ home_url }}"
        class="flex items-center gap-1 text-caption font-medium text-text-secondary underline-offset-2 transition hover:underline focus-visible:outline-offset-2"
    >
        {% from "components/_icon.html.jinja2" import icon %}
        {{ icon("chevron-left", size=18) }}
        {{ strings.SEARCH_BACK_LABEL }}
    </a>
    <h1 class="text-title font-semibold text-text-primary">{{ strings.SEARCH_TITLE }}</h1>
</header>

<div class="flex flex-col gap-1">
    <label for="search-input" class="text-caption font-medium text-text-secondary">
        {{ strings.SEARCH_INPUT_LABEL }}
    </label>
    <input
        type="search"
        id="search-input"
        name="q"
        placeholder="{{ strings.SEARCH_INPUT_PLACEHOLDER }}"
        autocomplete="off"
        hx-get="/search/results"
        hx-trigger="input changed delay:300ms, search"
        hx-target="#search-results"
        hx-swap="innerHTML"
        class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
    >
</div>

<div id="search-results">
    {% include "components/search_results.html.jinja2" with context %}
</div>
{% endblock %}
