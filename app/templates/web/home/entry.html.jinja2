{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.META_TITLE_INDEX }}{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Mushin 無心",
    "url": "{{ canonical_url(request) }}",
    "description": "{{ strings.META_DESCRIPTION_INDEX }}"
}
</script>
{% endblock %}

{% block content %}
{% if flash_message %}
<div hidden data-toast-message="{{ flash_message }}"></div>
{% endif %}
<section class="flex flex-col justify-center gap-8 pb-8">
    <header class="flex flex-col items-center gap-4 text-center">
        <img src="{{ static_asset('/static/img/og-default.png') }}" alt="{{ strings.APP_NAME }}" class="theme-light w-full">
        <img src="{{ static_asset('/static/img/og-dark.png') }}" alt="{{ strings.APP_NAME }}" class="theme-dark w-full">
        <h1 class="text-hero-numeral font-semibold leading-tight text-text-primary">
          {{ strings.ENTRY_TAGLINE }}
        </h1>
        <p class="text-body text-text-secondary">{{ strings.APP_GLOSS }}</p>
    </header>

    {% include "components/auth/auth_login_form.html.jinja2" with context %}

    {% if demo_username %}
    <p class="text-center text-caption text-text-muted">
        <a
            href="/@{{ demo_username }}"
            class="underline underline-offset-2 focus-visible:outline-offset-2"
        >{{ strings.ENTRY_DEMO_LINK }}</a>
    </p>
    {% endif %}

    <p class="text-center text-micro text-text-muted">
        {{ strings.ENTRY_CONSENT_NOTICE }}
        <a href="/privacy" class="underline underline-offset-2 focus-visible:outline-offset-2">{{ strings.ENTRY_CONSENT_LINK_TEXT }}</a>.
    </p>
</section>

<div class="flex justify-center pb-8">
    <a
        href="https://www.producthunt.com/products/mushin-4?embed=true&amp;utm_source=badge-featured&amp;utm_medium=badge&amp;utm_campaign=badge-mushin-4"
        target="_blank"
        rel="noopener noreferrer"
        class="opacity-50 transition hover:opacity-100 focus-visible:outline-offset-2"
        aria-label="Mushin on Product Hunt"
    >
        <img
            alt="Mushin 無心 - A social network for people who'd log records. | Product Hunt"
            width="250"
            height="54"
            src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1188238&amp;theme=neutral&amp;t=1783232369687"
        >
    </a>
</div>

{% if feed_entries %}
<section class="flex flex-col gap-4 border-t border-border pt-8 pb-8">
    <h2 class="text-title font-semibold text-text-primary">{{ strings.ENTRY_FEED_HEADING }}</h2>
    {% include "components/entries/_recent_entries.html.jinja2" %}
</section>
{% endif %}
{% endblock %}
