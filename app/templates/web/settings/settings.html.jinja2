{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.SETTINGS_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block tab_settings %}
<div id="settings-content" class="flex flex-grow flex-col gap-2">
{% if flash_message %}
<div hidden data-toast-message="{{ flash_message }}"></div>
{% endif %}

{% if not is_guest %}

{# ── Plan section ── #}
<section class="flat-section py-4" id="settings-section-plan">
    <h2 class="flat-section-title">{{ strings.SETTINGS_PLAN_HEADING }}</h2>
    <div class="flex items-start justify-between gap-3">
        <div class="flex flex-col gap-1">
            <div class="flex items-center gap-2">
                <span class="text-caption font-medium text-text-secondary">{{ strings.SETTINGS_PLAN_CURRENT_LABEL }}</span>
                <p class="text-body font-semibold text-text-primary">{{ user_plan.name }}</p>
            </div>
            <p class="text-sm text-text-secondary">{{ strings.SETTINGS_PLAN_ACTIVITIES_USED.format(used=activity_count, max=user_plan.max_activities) }}</p>
            {% if user_plan.plan == "premium" and subscription_end %}
            <p class="text-sm text-text-secondary">{{ strings.SETTINGS_PLAN_NEXT_BILLING.format(date=subscription_end[:10]) }}</p>
            {% endif %}
        </div>
        <a href="/settings/plans"
           class="flex shrink-0 items-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            {{ icon("list", size=18) }}
            {{ strings.SETTINGS_PLAN_VIEW_BUTTON }}
        </a>
    </div>

    {# ── Payment history (expandable) ── #}
    <details class="group mt-2">
        <summary class="flex cursor-pointer select-none items-center gap-2 rounded-button px-1 py-2 text-body font-medium text-text-primary transition hover:text-accent focus-visible:outline-offset-2 list-none">
            <span class="chevron-icon inline-flex transition-transform duration-150">
                {{ icon("chevron-left", size=16) }}
            </span>
            {% if payments %}
            {{ strings.SETTINGS_PLAN_PAYMENT_COUNT.format(count=payments|length) }}
            {% else %}
            {{ strings.SETTINGS_PLAN_PAYMENT_HISTORY }}
            {% endif %}
        </summary>
        {% if payments %}
        <div class="mt-2 overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="text-text-secondary">
                    <tr>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_DATE }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_AMOUNT }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_STATUS }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_PERIOD }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for p in payments %}
                    <tr>
                        <td class="py-2 pr-3 text-text-secondary">{{ p.created_at[:10] }}</td>
                        <td class="py-2 pr-3 font-medium text-text-primary">
                            {% if p.payment_method == 'promotion' %}
                                {{ strings.PLANS_PREMIUM_NAME }} – Promotion
                            {% else %}
                                {{ strings.PLANS_PREMIUM_NAME }} – ${{ "{:.2f}".format(p.amount_cents / 100) }}
                            {% endif %}
                        </td>
                        <td class="py-2 pr-3 text-text-secondary">{{ p.status }}</td>
                        <td class="py-2 pr-3 text-text-secondary">
                            {% if p.period_start and p.period_end %}
                            {{ p.period_start[:10] }} – {{ p.period_end[:10] }}
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="mt-2 text-sm text-text-secondary">{{ strings.SETTINGS_PLAN_PAYMENT_EMPTY }}</p>
        {% endif %}
    </details>

    <style>
        #settings-section-plan details summary::-webkit-details-marker { display: none; }
        #settings-section-plan details summary::marker { display: none; }
        #settings-section-plan details:not([open]) summary .chevron-icon { transform: rotate(180deg); }
        #settings-section-plan details[open] summary .chevron-icon { transform: rotate(90deg); }
    </style>
</section>
<div class="h-px bg-border" aria-hidden="true"></div>

<section class="flat-section py-4" id="settings-section-account">
    <h2 class="flat-section-title">{{ strings.ACCOUNT_VISIBILITY_HEADING }}</h2>
    <form
        id="settings-form-account"
        method="post"
        action="/settings"
        class="flex flex-col gap-3"
        data-original-visibility="{{ visibility }}"
    >
        <fieldset class="flex flex-col gap-4">
            <legend class="sr-only">{{ strings.ACCOUNT_VISIBILITY_HEADING }}</legend>
            <div class="flex gap-2">
                <label class="flex-1 cursor-pointer rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 has-[:checked]:border-2 has-[:checked]:border-brand has-[:checked]:text-text-primary has-[:checked]:font-semibold">
                    <input
                        type="radio"
                        name="visibility"
                        value="private"
                        {% if visibility != "public" %}checked{% endif %}
                        class="sr-only"
                    >
                    <span class="relative flex items-center justify-center">
                        <span class="flex items-center justify-center gap-2">
                            {{ icon("shield", size=18) }}
                            {{ strings.ACCOUNT_VISIBILITY_PRIVATE_LABEL }}
                        </span>
                        {% if visibility != "public" %}
                        <span class="absolute right-0 text-brand" aria-label="{{ strings.ACCOUNT_VISIBILITY_CURRENT_BADGE }}">
                            {{ icon("check", size=18) }}
                        </span>
                        {% endif %}
                    </span>
                </label>
                <label class="flex-1 cursor-pointer rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 has-[:checked]:border-2 has-[:checked]:border-brand has-[:checked]:text-text-primary has-[:checked]:font-semibold">
                    <input
                        type="radio"
                        name="visibility"
                        value="public"
                        {% if visibility == "public" %}checked{% endif %}
                        class="sr-only"
                    >
                    <span class="relative flex items-center justify-center">
                        <span class="flex items-center justify-center gap-2">
                            {{ icon("globe", size=18) }}
                            {{ strings.ACCOUNT_VISIBILITY_PUBLIC_LABEL }}
                        </span>
                        {% if visibility == "public" %}
                        <span class="absolute right-0 text-brand" aria-label="{{ strings.ACCOUNT_VISIBILITY_CURRENT_BADGE }}">
                            {{ icon("check", size=18) }}
                        </span>
                        {% endif %}
                    </span>
                </label>
            </div>
            <div id="settings-target-visibility-explanation" class="text-caption text-text-secondary">
                <p id="settings-text-visibility-tagline" class="font-medium"></p>
                <p id="settings-text-visibility-description"></p>
            </div>
            <span id="settings-text-visibility-tagline-private" hidden>{{ strings.ACCOUNT_VISIBILITY_PRIVATE_TAGLINE }}</span>
            <span id="settings-text-visibility-desc-private" hidden>{{ strings.ACCOUNT_VISIBILITY_PRIVATE_DESC }}</span>
            <span id="settings-text-visibility-tagline-public" hidden>{{ strings.ACCOUNT_VISIBILITY_PUBLIC_TAGLINE }}</span>
            <span id="settings-text-visibility-desc-public" hidden>{{ strings.ACCOUNT_VISIBILITY_PUBLIC_DESC }}</span>
        </fieldset>

        <label class="flex flex-col gap-2" for="settings-field-email">
            <span class="text-caption font-medium text-text-primary">{{ strings.ACCOUNT_EMAIL_LABEL }}</span>
            <input
                id="settings-field-email"
                name="email"
                type="email"
                value="{{ email or '' }}"
                data-original-value="{{ email or '' }}"
                autocomplete="email"
                inputmode="email"
                spellcheck="false"
                class="min-h-tap rounded-button border border-border bg-surface-1 px-4 py-3 text-body text-text-primary placeholder:text-text-muted focus-visible:outline-offset-2"
            >
        </label>
        {% if email_error %}
        <div hidden data-toast-message="{{ email_error }}"></div>
        {% endif %}

        <button
            type="submit"
            disabled
            class="flex min-h-tap w-full items-center justify-center rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
        >
            {{ strings.ACCOUNT_VISIBILITY_SAVE }}
        </button>
    </form>
</section>
<div class="h-px bg-border" aria-hidden="true"></div>
{% endif %}

{# Password #}
{% if not is_guest %}
<section id="settings-section-password" class="flat-section py-4">
    <h2 class="flat-section-title">{{ strings.ACCOUNT_PASSWORD_HEADING }}</h2>
    <form
        id="settings-form-password"
        method="post"
        action="/settings/password"
        class="flex flex-col gap-3"
    >
        <label class="flex flex-col gap-2" for="settings-field-current-password">
            <span class="text-caption font-medium text-text-primary">{{ strings.ACCOUNT_PASSWORD_CURRENT_LABEL }}</span>
            <input
                id="settings-field-current-password"
                name="current_password"
                type="password"
                autocomplete="current-password"
                class="min-h-tap rounded-button border border-border bg-surface-1 px-4 py-3 text-body text-text-primary placeholder:text-text-muted focus-visible:outline-offset-2"
            >
        </label>
        <label class="flex flex-col gap-2" for="settings-field-new-password">
            <span class="text-caption font-medium text-text-primary">{{ strings.ACCOUNT_PASSWORD_NEW_LABEL }}</span>
            <input
                id="settings-field-new-password"
                name="new_password"
                type="password"
                autocomplete="new-password"
                placeholder="Min 8 chars, no spaces"
                class="min-h-tap rounded-button border border-border bg-surface-1 px-4 py-3 text-body text-text-primary placeholder:text-text-muted focus-visible:outline-offset-2"
            >
        </label>
        {% if password_error %}
        <div hidden data-toast-message="{{ password_error }}"></div>
        {% endif %}
        <button
            type="submit"
            disabled
            class="flex min-h-tap w-full items-center justify-center rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
        >
            {{ strings.ACCOUNT_PASSWORD_UPDATE }}
        </button>
    </form>
</section>
<div class="h-px bg-border" aria-hidden="true"></div>
{% endif %}

{# Theme #}
<section id="settings-section-theme" class="py-4">
    <div class="flex items-center justify-between">
        <span class="flat-section-title">{{ strings.SETTINGS_THEME_HEADING }}</span>
        {% include "components/common/theme_toggle_settings.html.jinja2" with context %}
    </div>
</section>
<div class="h-px bg-border" aria-hidden="true"></div>

{# Data, logout, delete #}
<section id="settings-section-data" class="flat-section py-4">
    <h2 class="flat-section-title">{{ strings.SETTINGS_DATA_HEADING }}</h2>
    <div class="flex gap-3">
      {% include "components/settings/entry_import_dialog.html.jinja2" with context %}
      <template id="settings-template-entry-import-dialog">
        {% include "components/settings/entry_import_dialog.html.jinja2" with context %}
      </template>
      <button
          type="button"
          id="settings-button-entry-import-open"
          class="flex min-h-tap flex-1 items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
      >
          {{ icon("arrow-down-tray", size=18) }}
          {{ strings.FOOTER_IMPORT_ENTRIES }}
      </button>
        <a
            href="/export-entries"
            class="flex min-h-tap flex-1 items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
        >
            {{ icon("arrow-up-tray", size=18) }}
            {{ strings.FOOTER_EXPORT_ENTRIES }}
        </a>
    </div>

    <button
        type="button"
        id="settings-button-logout"
        hx-post="/auth/logout"
        hx-swap="none"
        class="flex min-h-tap w-full items-center justify-center gap-2 rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
    >
        {{ icon("circle-user", size=18) }}
        {{ strings.FOOTER_LOGOUT }}
    </button>

{% if not is_guest %}
    <button
        type="button"
        id="settings-button-delete-open"
        class="flex min-h-tap w-full items-center justify-center gap-2 rounded-button border border-danger bg-danger-subtle px-4 py-3 text-body font-semibold text-danger transition hover:opacity-90 focus-visible:outline-offset-2"
    >
        {{ icon("trash", size=18) }}
        {{ strings.FOOTER_DELETE_DATA }}
    </button>

    {% include "components/settings/delete_account_confirm.html.jinja2" %}
{% endif %}
</section>
<div class="h-px bg-border" aria-hidden="true"></div>

{# About + legal links #}
<section id="settings-section-about" class="flex flex-col gap-3 py-4">
    <h2 class="text-body font-semibold text-text-primary">{{ strings.SETTINGS_ABOUT_HEADING }}</h2>
    <p class="text-caption text-text-secondary">
        {{ strings.APP_NAME }} {{ strings.APP_NAME_HANJA }}
    </p>
    <p class="text-caption text-text-secondary">
        <a href="mailto:{{ strings.SETTINGS_CONTACT_EMAIL }}" class="underline underline-offset-2 focus-visible:outline-offset-2">
            {{ strings.SETTINGS_CONTACT_EMAIL }}
        </a>
    </p>
    <div class="flex gap-3 pt-2">
        <a
            href="/licenses"
            data-legal="licenses"
            data-dialog-title="{{ strings.LICENSES_PAGE_TITLE }}"
            class="text-caption text-text-secondary underline underline-offset-2 focus-visible:outline-offset-2"
        >
            {{ strings.ACCOUNT_LICENSES_LINK }}
        </a>
        <a
            href="/terms"
            data-legal="terms"
            data-dialog-title="{{ strings.TERMS_PAGE_TITLE }}"
            class="text-caption text-text-secondary underline underline-offset-2 focus-visible:outline-offset-2"
        >
            {{ strings.ACCOUNT_TERMS_LINK }}
        </a>
        <a
            href="/privacy"
            data-legal="privacy"
            data-dialog-title="{{ strings.PRIVACY_PAGE_TITLE }}"
            class="text-caption text-text-secondary underline underline-offset-2 focus-visible:outline-offset-2"
        >
            {{ strings.ACCOUNT_PRIVACY_LINK }}
        </a>
    </div>
</section>

{# Legal dialog — content loaded via HTMX into #settings-target-legal-content. #}
<div
    id="settings-dialog-legal"
    hidden
    class="fixed inset-0 z-50 flex items-end justify-center bg-overlay/50 sm:items-center"
    role="presentation"
>
    <div
        role="dialog"
        aria-modal="true"
        aria-labelledby="settings-title-legal-dialog"
        tabindex="-1"
        class="flex max-h-[90vh] w-full max-w-screen-sm flex-col rounded-t-card border border-border bg-surface-1 shadow-soft sm:rounded-card"
    >
        <div class="flex items-center justify-between border-b border-border px-4 py-3">
            <h2 id="settings-title-legal-dialog" class="text-title font-semibold text-text-primary"></h2>
            <button
                id="settings-button-legal-close"
                type="button"
                class="flex min-h-tap min-w-tap items-center justify-center rounded-button text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                aria-label="{{ strings.LEGAL_DIALOG_CLOSE }}"
            >
                {{ icon("x", size=20) }}
            </button>
        </div>
        <div id="settings-target-legal-content" class="overflow-y-auto px-4 py-4 text-body text-text-secondary">
        </div>
    </div>
</div>
</div>
{% endblock tab_settings %}
