{% extends "web/base.html.jinja2" %}

{% block title %}{{ strings.SOCIAL_TITLE }} · {{ strings.APP_NAME }}{% endblock %}

{% block header_right %}
<button
    id="social-button-search-toggle"
    type="button"
    aria-label="{{ strings.SEARCH_OPEN_ARIA }}"
    class="flex min-h-tap min-w-tap items-center justify-center text-text-secondary transition hover:text-text-primary focus-visible:outline-offset-2"
>
    <span id="social-icon-search-open">{{ icon("search", size=18) }}</span>
    <span id="social-icon-search-close" hidden>{{ icon("x", size=18) }}</span>
</button>
{% endblock %}

{% block tab_social %}
<section id="social-section-feed" class="flat-section pt-2" aria-labelledby="social-title-feed">
    <h2 id="social-title-feed" class="flat-section-title">{{ strings.SOCIAL_FEED_HEADING }}</h2>
    {% include "components/entries/_recent_entries.html.jinja2" %}
</section>

<section id="social-section-search" class="flex flex-col" aria-labelledby="social-title-search" hidden>
    <h2 id="social-title-search" class="sr-only">{{ strings.SEARCH_INPUT_LABEL }}</h2>
    <div class="py-2">
        <label for="social-field-search" class="sr-only">{{ strings.SEARCH_INPUT_LABEL }}</label>
        <input
            type="search"
            id="social-field-search"
            name="q"
            placeholder="{{ strings.SEARCH_INPUT_PLACEHOLDER }}"
            autocomplete="off"
            hx-get="/social/results"
            hx-trigger="input changed delay:300ms, search"
            hx-target="#social-target-search-results"
            hx-swap="innerHTML"
            class="min-h-tap w-full rounded-input border border-border bg-surface-1 px-3 py-1 text-body text-text-primary focus-visible:outline-2"
        >
    </div>
    <div id="social-target-search-results">
        <p class="py-2 text-center text-caption text-text-secondary">{{ strings.SEARCH_PROMPT }}</p>
    </div>
</section>
{% endblock %}
