{#
  Public profile (/@{username}) — read-only, unauthenticated or non-owner.

  Dedicated read-only template: zero write affordances. Do NOT include
  components that carry log/edit/tag forms (activity_card.html.jinja2's
  `linked` mode only adds a navigation link, but we render the card body inline
  here anyway to keep this template fully self-contained and auditable).

  Context: username, view_mode ("connected" | "public" | "limited"), cards
  (list, see app.routes.web._build_card_context — each card's own `linked`
  flag controls whether it's wrapped in an <a>; non-clickable for "limited").
#}
{% extends "web/base.html.jinja2" %}

{% block title %}{{ username }} · {{ strings.APP_NAME }}{% endblock %}

{% block tab_social %}
{% if flash_message %}
<div hidden data-toast-message="{{ flash_message }}"></div>
{% endif %}

{% if bio %}
<section class="flat-section py-3">
    <h2 class="flat-section-title">{{ strings.PROFILE_BIO_HEADING_SOCIAL.format(username=username) }}</h2>
    <p class="break-words text-body text-text-secondary">{{ bio }}</p>
</section>
<div class="h-px bg-border" aria-hidden="true"></div>
{% endif %}

{% include "components/fellows/fellows_section.html.jinja2" with context %}

<div class="h-px bg-border" aria-hidden="true"></div>

{% if view_mode == "limited" %}
<p class="text-caption text-text-muted">{{ strings.PROFILE_LIMITED_NOTICE.format(username=username) }}</p>
{% endif %}

<section id="social-profile-section-activities" aria-labelledby="social-profile-title-activities" class="flat-section">
    <h2 id="social-profile-title-activities" class="flat-section-title">{{ strings.HOME_ACTIVITIES_HEADING }}</h2>
    {% if not cards %}
    <p class="py-4 text-body text-text-secondary">{{ strings.PROFILE_ACTIVITIES_EMPTY }}</p>
    {% else %}
    <div class="flex flex-col gap-3">
        {% for card in cards %}
        <article>
            {% if view_mode == "limited" %}
            <section class="flex flex-col gap-2 rounded-card border border-border bg-surface-1 p-4">
                <h3 class="truncate text-center text-title font-semibold text-text-primary">{{ card.name }}</h3>
                <div class="-mx-4 border-t border-border"></div>
                <dl class="bg-surface-0 px-3 py-2">
                    <div class="flex items-center justify-between gap-3">
                        <dt class="text-caption text-text-muted">{{ strings.STATS_PERIOD_LIFETIME }}</dt>
                        <dd class="text-title font-medium text-text-primary">{{ card.counts.lifetime | format_count }}</dd>
                    </div>
                </dl>
            </section>
            {% else %}
            {% set activity_href = "/@" ~ username ~ "/" ~ card.slug if card.linked else none %}
            {% if card.linked %}
            <a
                href="{{ activity_href }}"
                class="flex flex-col transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            >
            {% else %}
            <div class="flex flex-col">
            {% endif %}
                {% with activity_id=card.id, counts=card.counts, streaks=card.streaks, average_weekly_count=card.average_weekly_count, heatmap=card.heatmap, top_tags=card.top_tags, card_name=card.name, show_top_tags=not card.linked %}
                {% include "components/history/stats_summary.html.jinja2" with context %}
                {% endwith %}
            {% if card.linked %}
            </a>
            {% else %}
            </div>
            {% endif %}
            {% endif %}
        </article>
        {% endfor %}
    </div>
    {% endif %}
</section>
{% endblock %}
