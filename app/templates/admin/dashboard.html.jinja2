<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ strings.ADMIN_DASHBOARD_TITLE }} · {{ strings.APP_NAME }}</title>
    <link rel="stylesheet" href="{{ static_asset('/static/style.css') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ static_asset('/static/favicon/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ static_asset('/static/favicon/favicon-16x16.png') }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ static_asset('/static/favicon/apple-touch-icon.png') }}">
    <script defer src="{{ static_asset('/static/js/common/dialogs.js') }}"></script>
    <script defer src="{{ static_asset('/static/js/admin/admin-dialogs.js') }}"></script>
</head>
<body class="flex flex-col bg-surface-0 min-h-screen text-text-primary text-body">
    <main class="mx-auto flex w-full max-w-screen-lg grow flex-col gap-6 px-4 py-4">
        <header class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h1 class="text-title font-semibold text-text-primary">{{ strings.ADMIN_DASHBOARD_TITLE }}</h1>
            {% include "components/admin/_admin_nav.html.jinja2" with context %}
        </header>

        {% if admin_view == "user_detail" %}
            {% include "components/admin/_admin_user_detail.html.jinja2" with context %}
        {% elif admin_section == "users" %}
            {% include "components/admin/_admin_users.html.jinja2" with context %}
        {% else %}
            {% include "components/admin/_admin_monitor.html.jinja2" with context %}
        {% endif %}
    </main>
</body>
</html>
