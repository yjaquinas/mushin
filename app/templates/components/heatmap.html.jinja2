{#
  Trailing-365-day contribution heatmap.

  NON-INTERACTIVE: the whole grid is a single role="img" with one descriptive
  aria-label; individual .heat-cell elements are aria-hidden. Intensity buckets
  (.heat-cell--0..4) are computed server-side (see app.routes.web._heat_bucket).

  Context: `heatmap` ({"cells": [{"date", "bucket"}, ...]}).
#}
<section class="flex flex-col gap-2">
    <h3 class="text-body font-medium text-text-primary">{{ strings.HEATMAP_TITLE }}</h3>
    <div
        class="grid grid-flow-col grid-rows-7 gap-1 overflow-x-auto"
        role="img"
        aria-label="{{ strings.HEATMAP_ARIA_LABEL }}"
    >
        {% for cell in heatmap.cells %}
            <span class="heat-cell heat-cell--{{ cell.bucket }}" aria-hidden="true"></span>
        {% endfor %}
    </div>
</section>
