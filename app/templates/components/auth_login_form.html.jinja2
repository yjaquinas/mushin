{#
  Login form — username + password. Standalone-renderable: re-asserts the
  Log in / Create account toggle above itself so a direct fragment load
  (via the toggle's hx-get) isn't visually orphaned.

  Submits to POST /auth/login with hx-swap="none" (the endpoint returns JSON,
  not HTML). app/static/js/auth-form.js's MushinAuth.handle reads the
  response: on success it redirects to the user's /@{username} profile via the
  response's `redirect_url` field; on 401 it writes the JSON `detail` message
  into the form's [data-auth-error] element — the form itself is never
  swapped, so the entered username is preserved.

  Context:
    error (str, optional) — initial inline error message, for parity when
    this fragment is server-rendered directly (currently always empty; the
    JS path fills [data-auth-error] client-side).
    next (str, optional) — a same-origin path to return to after a successful
    login (already validated server-side by the entry/login GET route via
    profiles.safe_next_path before reaching this template). Carried as a
    hidden field so MushinAuth.handle can redirect there instead of the
    default /@{username} profile. Absent/None renders no hidden field, and
    the JS falls back to its normal redirect_url behavior.
#}
<div id="auth-form" class="flex flex-col gap-4">
    {% include "components/auth_tabs.html.jinja2" with context %}

    <form
        hx-post="/auth/login"
        hx-swap="none"
        data-auth-form
        class="flex flex-col gap-4"
    >
        {% if next %}
        <input type="hidden" name="next" value="{{ next }}">
        {% endif %}

        <div class="flex flex-col gap-1">
            <label for="login-username" class="text-caption font-medium text-text-secondary">
                {{ strings.ENTRY_FIELD_USERNAME }}
            </label>
            <input
                type="text"
                id="login-username"
                name="username"
                required
                autocomplete="username"
                value="{{ username | default('') }}"
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            >
        </div>

        <div class="flex flex-col gap-1">
            <label for="login-password" class="text-caption font-medium text-text-secondary">
                {{ strings.ENTRY_FIELD_PASSWORD }}
            </label>
            <input
                type="password"
                id="login-password"
                name="password"
                required
                autocomplete="current-password"
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            >
        </div>

        <p data-auth-error class="text-caption text-danger" role="alert" {% if not error %}hidden{% endif %}>{{ error | default('') }}</p>

        <button
            type="submit"
            hx-disabled-elt="this"
            class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
        >
            {{ strings.ENTRY_LOGIN_SUBMIT }}
        </button>
    </form>
</div>
