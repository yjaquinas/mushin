<section class="flex flex-col gap-4">
    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h3 class="font-semibold">{{ strings.ADMIN_RECENT_ACTIVITIES_HEADING }}</h3>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[480px] text-left text-sm">
                <thead class="text-text-secondary">
                    <tr>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_USER }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_NAME }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_CREATED }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for activity in recent_activities %}
                    <tr>
                        <td class="py-2 pr-3">@{{ activity.username or activity.display_name or activity.user_id }}</td>
                        <td class="py-2 pr-3">
                            {% if activity.username and activity.slug %}
                            <a class="underline-offset-2 hover:underline" href="/@{{ activity.username }}/{{ activity.slug }}">{{ activity.name }}</a>
                            {% else %}
                            {{ activity.name }}
                            {% endif %}
                        </td>
                        <td class="py-2 pr-3 text-text-secondary">{{ activity.created_at }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h3 class="font-semibold">{{ strings.ADMIN_RECENT_ENTRIES_HEADING }}</h3>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[760px] text-left text-sm">
                <thead class="text-text-secondary">
                    <tr>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_USER }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_ACTIVITY }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_NOTES }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_MANAGEMENT }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for entry in recent_entries %}
                    <tr>
                        <td class="py-2 pr-3">@{{ entry.username or entry.display_name or entry.user_id }}</td>
                        <td class="py-2 pr-3">
                            {% if entry.username and entry.slug %}
                            <a class="underline-offset-2 hover:underline" href="/@{{ entry.username }}/{{ entry.slug }}?c={{ entry.id }}#comment-slot-{{ entry.id }}">{{ entry.activity_name }}</a>
                            {% else %}
                            {{ entry.activity_name }}
                            {% endif %}
                            {% if entry.hidden_at %}<span class="ms-1 text-danger">{{ strings.ADMIN_STATUS_HIDDEN }}</span>{% endif %}
                        </td>
                        <td class="py-2 pr-3">
                            <form method="post" action="/admin/users/{{ detail_user.id }}/entries/{{ entry.id }}/edit" class="flex min-w-[18rem] gap-2">
                                <input name="memo" value="{{ entry.memo or '' }}" class="w-full rounded border border-border bg-surface-0 px-2 py-1 text-text-primary">
                                <button class="rounded-button border border-border px-2 py-1 text-text-secondary">{{ strings.ADMIN_SAVE }}</button>
                            </form>
                        </td>
                        <td class="py-2 pr-3">
                            <form method="post" action="/admin/users/{{ detail_user.id }}/entries/{{ entry.id }}/visibility">
                                <input type="hidden" name="hidden" value="{% if entry.hidden_at %}false{% else %}true{% endif %}">
                                <button class="rounded-button border border-border px-2 py-1 text-text-secondary">{% if entry.hidden_at %}{{ strings.ADMIN_UNHIDE }}{% else %}{{ strings.ADMIN_HIDE }}{% endif %}</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h3 class="font-semibold">{{ strings.ADMIN_RECENT_COMMENTS_HEADING }}</h3>
        <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[860px] text-left text-sm">
                <thead class="text-text-secondary">
                    <tr>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_ENTRY_USER }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_ACTIVITY }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_COMMENT_USER }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_TEXT }}</th>
                        <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_MANAGEMENT }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for comment in recent_comments %}
                    <tr>
                        <td class="py-2 pr-3">@{{ comment.entry_username or comment.entry_display_name or comment.entry_user_id }}</td>
                        <td class="py-2 pr-3">
                            {% if comment.entry_username and comment.slug %}
                            <a class="underline-offset-2 hover:underline" href="/@{{ comment.entry_username }}/{{ comment.slug }}?c={{ comment.entry_id }}#comment-slot-{{ comment.entry_id }}">{{ comment.activity_name }}</a>
                            {% else %}
                            {{ comment.activity_name }}
                            {% endif %}
                            {% if comment.hidden_at %}<span class="ms-1 text-danger">{{ strings.ADMIN_STATUS_HIDDEN }}</span>{% endif %}
                        </td>
                        <td class="py-2 pr-3">@{{ comment.comment_username or comment.comment_display_name or comment.comment_user_id }}</td>
                        <td class="py-2 pr-3">
                            <form method="post" action="/admin/users/{{ detail_user.id }}/comments/{{ comment.id }}/edit" class="flex min-w-[20rem] gap-2">
                                <input name="body" value="{{ comment.body }}" required class="w-full rounded border border-border bg-surface-0 px-2 py-1 text-text-primary">
                                <button class="rounded-button border border-border px-2 py-1 text-text-secondary">{{ strings.ADMIN_SAVE }}</button>
                            </form>
                        </td>
                        <td class="py-2 pr-3">
                            <form method="post" action="/admin/users/{{ detail_user.id }}/comments/{{ comment.id }}/visibility">
                                <input type="hidden" name="hidden" value="{% if comment.hidden_at %}false{% else %}true{% endif %}">
                                <button class="rounded-button border border-border px-2 py-1 text-text-secondary">{% if comment.hidden_at %}{{ strings.ADMIN_UNHIDE }}{% else %}{{ strings.ADMIN_HIDE }}{% endif %}</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
