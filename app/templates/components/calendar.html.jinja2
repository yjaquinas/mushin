{#
  Month calendar with marked days. Tapping a day swaps in that day's entries
  via HTMX into #calendar-day-detail. Prev/next month buttons swap this whole
  fragment (#calendar-{{ sub_tally_id }}).

  Context: sub_tally_id, calendar (see app.routes.web._build_calendar_context).
#}
<div id="calendar-{{ sub_tally_id }}" class="flex flex-col gap-2">
    <div class="flex items-center justify-between">
        <button
            type="button"
            hx-get="/sub-tallies/{{ sub_tally_id }}/calendar?year={{ calendar.prev_year }}&month={{ calendar.prev_month }}"
            hx-target="#calendar-{{ sub_tally_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.CALENDAR_PREV_MONTH }}"
        >
            &lt;
        </button>
        <h3 class="text-body font-medium text-text-primary">
            {{ calendar.year }}.{{ "%02d"|format(calendar.month) }}
        </h3>
        <button
            type="button"
            hx-get="/sub-tallies/{{ sub_tally_id }}/calendar?year={{ calendar.next_year }}&month={{ calendar.next_month }}"
            hx-target="#calendar-{{ sub_tally_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.CALENDAR_NEXT_MONTH }}"
        >
            &gt;
        </button>
    </div>

    <table class="w-full border-collapse">
        <caption class="sr-only">{{ strings.CALENDAR_TITLE }}</caption>
        <thead>
            <tr>
                {% for wd in calendar.weekdays %}
                    <th scope="col" class="text-caption font-medium text-text-muted">{{ wd }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for week in calendar.weeks %}
                <tr>
                    {% for day in week %}
                        <td class="text-center">
                            {% if day is not none %}
                                <button
                                    type="button"
                                    class="cal-day{% if day.marked %} cal-day--marked{% endif %}{% if day.today %} cal-day--today{% endif %}"
                                    hx-get="/sub-tallies/{{ sub_tally_id }}/calendar/day/{{ day.date }}"
                                    hx-target="#calendar-day-detail"
                                    hx-swap="innerHTML"
                                >
                                    {{ day.day }}
                                </button>
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div id="calendar-day-detail"></div>
</div>
