{#
  Delete-my-data — quiet footer link opening a focus-trapped confirm dialog
  for the single destructive action (guest-only build: no "switch account"
  framing, nothing to switch to). Confirm posts to /auth/delete and redirects
  to / on success.

  No context required.
#}
<div x-data="{ open: false }" @keydown.escape.window="open = false">
    <button
        type="button"
        @click="open = true"
        class="text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
    >
        {{ strings.FOOTER_DELETE_DATA }}
    </button>

    <div
        x-show="open"
        x-cloak
        class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
        role="presentation"
    >
        <div
            x-show="open"
            @click.outside="open = false"
            x-init="$watch('open', (open) => { if (open) $nextTick(() => $refs.deleteCancelButton.focus()) })"
            role="dialog"
            aria-modal="true"
            aria-labelledby="delete-data-title"
            class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
        >
            <h2 id="delete-data-title" class="text-body font-semibold text-text-primary">
                {{ strings.DELETE_DATA_TITLE }}
            </h2>
            <p class="text-caption text-text-secondary">{{ strings.DELETE_DATA_BODY }}</p>

            <button
                type="button"
                hx-post="/auth/delete"
                hx-swap="none"
                hx-on::after-request="if(event.detail.successful) window.location.href = '/'"
                class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-danger transition hover:bg-surface-2 focus-visible:outline-offset-2"
            >
                {{ strings.DELETE_DATA_CONFIRM }}
            </button>

            <button
                type="button"
                x-ref="deleteCancelButton"
                @click="open = false"
                class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
            >
                {{ strings.DELETE_DATA_CANCEL }}
            </button>
        </div>
    </div>
</div>
