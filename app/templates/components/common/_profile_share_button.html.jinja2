<button
    type="button"
    data-share-link
    data-share-url="{{ share_url or profile_url }}"
    data-share-label="{{ strings.ACCOUNT_SHARE }}"
    data-share-copied="{{ strings.ACCOUNT_SHARE_COPIED }}"
    data-share-failed="{{ strings.ACCOUNT_SHARE_FAILED }}"
    aria-label="{{ strings.ACCOUNT_SHARE }}"
    class="flex min-h-tap min-w-tap items-center justify-center rounded-full border border-border bg-surface-1 text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
>
    {{ icon("share", size=18) }}
</button>
