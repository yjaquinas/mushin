{#
  Theme toggle — icon-only pill showing both sun and moon.
  The active icon is highlighted with brand fill; the inactive one is muted.
  Tapping posts to /preferences/theme which sets the mushin_theme cookie
  and triggers a full page refresh.

  Context: theme ("light" | "dark").
#}
<button
    type="button"
    id="theme-toggle"
    hx-post="/preferences/theme"
    hx-swap="outerHTML"
    aria-label="{{ 'Switch to dark theme' if theme == 'light' else 'Switch to light theme' }}"
    data-theme="{{ theme }}"
    class="flex items-center rounded-full border border-border bg-surface-1 p-0.5 transition hover:bg-surface-2 focus-visible:outline-offset-2"
>
    <span class="flex items-center justify-center rounded-full p-1.5 transition-colors {% if theme == 'light' %}bg-brand text-on-brand{% else %}text-text-muted{% endif %}">
        {{ icon("sun", size=16) }}
    </span>
    <span class="flex items-center justify-center rounded-full p-1.5 transition-colors {% if theme == 'dark' %}bg-brand text-on-brand{% else %}text-text-muted{% endif %}">
        {{ icon("moon", size=16) }}
    </span>
</button>
