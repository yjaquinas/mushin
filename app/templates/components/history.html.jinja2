{#
  Unified history view: a persistent header (week/month/all period switcher +
  prev/current/next nav) AND the period-shaped visual (week strip / month
  calendar) always render, regardless of day selection — the grid never
  leaves the DOM. Only the log area below the visual swaps between two
  mutually exclusive states:
    - no day selected (the default): the full, day-grouped period log
      (components/period_log.html.jinja2).
    - a day selected: a "clear selection" control followed by *only* that
      day's entries (components/day_entries.html.jinja2).

  This whole div is the HTMX swap target (#history-{{ activity_id }}) for
  every period-switch, prev/next, day-select, and clear-selection
  interaction — `hx-swap="outerHTML"`. Tapping an already-selected day cell
  omits `&day=...` from its own hx-get, so re-tapping it has the same effect
  as the clear-selection control (toggle off).

  Focus-after-swap: exactly one element in the swapped fragment carries
  `data-history-focus` per state — the active period tab when no day is
  selected, or the day-detail panel's root (#calendar-day-detail, see
  components/day_entries.html.jinja2) when one is — so after every swap,
  focus lands on a stable, predictable target regardless of which control
  (tab, prev/next, day-cell, or clear-selection) triggered the swap, without
  requiring per-control id-matching. The actual after-swap listener lives
  in app/static/js/base-behavior.js, registered on `<body>` — see that file
  for why it can't live on this self-replacing `outerHTML` target.

  Period sync: after every swap, the `data-period` attribute on the
  field-stats div is updated from the active period tab's `data-period`.

  Context: activity_id, history (see app.routes.web._build_history_context).
#}
<div
    id="history-{{ activity_id }}"
    class="flex flex-col gap-3"
>
    {# Sentinel: refreshes the whole history section on log-saved.
       Lives here (not on the parent div) so its hx-vals don't bleed into
       period/prev/next button requests via HTMX ancestor-merging. #}
    <span
        class="sr-only"
        aria-hidden="true"
        hx-get="/activities/{{ activity_id }}/history"
        hx-vals='{"period": "{{ history.period }}", "anchor": "{{ history.anchor }}"}'
        hx-trigger="log-saved from:body"
        hx-target="#history-{{ activity_id }}"
        hx-swap="outerHTML"
    ></span>
    {# Period switcher #}
    <div role="tablist" aria-label="{{ strings.HISTORY_PERIOD_SWITCHER_LABEL }}" class="flex gap-2">
        {% for period_key, period_label in [
            ("week", strings.HISTORY_PERIOD_WEEK),
            ("month", strings.HISTORY_PERIOD_MONTH),
            ("all", strings.HISTORY_PERIOD_ALL),
        ] %}
            {% set is_selected = history.period == period_key %}
            <button
                type="button"
                role="tab"
                id="history-tab-{{ activity_id }}-{{ period_key }}"
                aria-selected="{{ "true" if is_selected else "false" }}"
                {% if is_selected and history.selected_day is none %}data-history-focus{% endif %}
                hx-get="/activities/{{ activity_id }}/history?period={{ period_key }}&anchor={{ history.anchor }}"
                hx-target="#history-{{ activity_id }}"
                hx-swap="outerHTML"
                class="min-h-tap min-w-tap flex-1 rounded-button px-3 text-body transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong
                    {% if is_selected %}
                        border border-accent bg-accent-subtle font-semibold text-accent-text
                    {% else %}
                        border border-border text-text-secondary hover:bg-surface-2
                    {% endif %}"
            >
                {{ period_label }}
            </button>
        {% endfor %}
    </div>

    {# Prev / current / next nav — hidden for the "all" period #}
    {% if history.period != "all" %}
    <div class="flex items-center justify-between">
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.prev_anchor }}"
            hx-target="#history-{{ activity_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            aria-label="{% if history.period == 'week' %}{{ strings.HISTORY_PREV_WEEK }}{% else %}{{ strings.CALENDAR_PREV_MONTH }}{% endif %}"
        >
            &lt;
        </button>
        <div class="flex items-center gap-2">
            <h3 class="text-body font-medium text-text-primary" aria-live="polite">
                {{ history.label }}
            </h3>
            {% if history.today_anchor < history.start or history.today_anchor > history.end %}
            <button
                type="button"
                hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.today_anchor }}"
                hx-target="#history-{{ activity_id }}"
                hx-swap="outerHTML"
                class="rounded-button border border-border px-2 py-0.5 text-caption text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            >
                {{ strings.HISTORY_TODAY }}
            </button>
            {% endif %}
        </div>
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.next_anchor }}"
            hx-target="#history-{{ activity_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            aria-label="{% if history.period == 'week' %}{{ strings.HISTORY_NEXT_WEEK }}{% else %}{{ strings.CALENDAR_NEXT_MONTH }}{% endif %}"
        >
            &gt;
        </button>
    </div>
    {% endif %}

    {# Period visual — branched on period, not rendered for "all". Always
       rendered regardless of day selection; the grid/strip never leaves the
       DOM, only the log area below it (see next block) swaps. #}
    {% if history.period == "month" %}
        <table class="w-full border-collapse">
            <caption class="sr-only">{{ strings.CALENDAR_TITLE }}</caption>
            <thead>
                <tr>
                    {% for wd in history.visual.weekdays %}
                        <th scope="col" class="text-caption font-medium text-text-muted">{{ wd }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for week in history.visual.weeks %}
                    <tr>
                        {% for day in week %}
                            <td class="text-center">
                                {% if day is not none %}
                                    {% if day.marked %}
                                    <button
                                        type="button"
                                        aria-pressed="{{ 'true' if day.selected else 'false' }}"
                                        class="cal-day cal-day--marked{% if day.today %} cal-day--today{% endif %}{% if day.selected %} cal-day--selected{% endif %}"
                                        {% if day.selected %}
                                        hx-get="/activities/{{ activity_id }}/history?period=month&anchor={{ history.anchor }}"
                                        {% else %}
                                        hx-get="/activities/{{ activity_id }}/history?period=month&anchor={{ history.anchor }}&day={{ day.date }}"
                                        {% endif %}
                                        hx-target="#history-{{ activity_id }}"
                                        hx-swap="outerHTML"
                                    >
                                        {{ day.day }}
                                    </button>
                                    {% else %}
                                    <span class="cal-day cal-day--empty{% if day.today %} cal-day--today{% endif %}">
                                        {{ day.day }}
                                    </span>
                                    {% endif %}
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% elif history.period == "week" %}
        {% include "components/week_strip.html.jinja2" with context %}
    {% endif %}

    {% if top_tags is defined and top_tags is not none %}
        {% include "components/activity_tags.html.jinja2" with context %}
    {% endif %}

    {# Log area: mutually exclusive — the full-period log (no day selected,
       the default) or the day-detail panel + a clear-selection control (a
       day selected). #}
    {% if history.selected_day is none %}
        {% include "components/period_log.html.jinja2" with context %}
    {% else %}
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.anchor }}"
            hx-target="#history-{{ activity_id }}"
            hx-swap="outerHTML"
            class="min-h-tap flex w-fit items-center gap-1 rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
        >
            &times; {{ strings.HISTORY_CLEAR_SELECTION }}
        </button>

        {% with day = history.selected_day, entries = history.day_entries %}
            {% include "components/day_entries.html.jinja2" with context %}
        {% endwith %}
    {% endif %}
</div>
