<div
    id="recent-entries"
    class="flex flex-col gap-4"
>
    {% for item in feed_entries %}
    <a
        href="/social{{ item.activity_url }}?entry_id={{ item.entry_id }}"
        class="group flex min-h-tap flex-row transition hover:bg-surface-2 focus-visible:outline-offset-2"
    >
        <div class="flex min-w-0 flex-1 flex-col">
            <h3 class="truncate text-body font-semibold text-text-primary">
                <span class="font-medium text-text-secondary group-hover:text-text-primary">@{{ item.username }}</span>
                {{ item.name }}
            </h3>
            <p class="mt-0.5 text-caption text-text-muted">
                {{ item.occurred_at | format_feed_entry_timestamp(item.time_known) }}
            </p>
            {% if item.memo %}
            {% set lines = item.memo.split('\n') %}
            <p class="mt-1 text-caption text-text-secondary line-clamp-2">{{ lines[:2] | join('\n') }}{% if lines | length > 2 %}&hellip;{% endif %}</p>
            {% endif %}
        </div>
        <span class="ml-2 flex shrink-0 items-center self-center text-text-muted opacity-50 transition group-hover:opacity-100">{{ icon("arrow-right", size=20) }}</span>
    </a>
    {% if not loop.last %}
    <div class="h-px bg-border" aria-hidden="true"></div>
    {% endif %}
    {% else %}
    <p class="text-caption text-text-muted">{{ strings.ENTRY_FEED_EMPTY }}</p>
    {% endfor %}
</div>
