<div
    id="recent-entries"
    class="flex flex-col gap-3"
>
    {% for item in feed_entries %}
    <article class="rounded-card border border-border bg-surface-1 p-4">
        <div class="flex items-baseline justify-between gap-2">
            <a
                href="{{ item.profile_url }}"
                class="text-caption font-medium text-text-secondary hover:text-text-primary focus-visible:outline-offset-2"
            >@{{ item.username }}</a>
            <span
                class="text-micro text-text-muted"
                data-local-timestamp="{{ item.created_at }}"
                hidden
            >{{ item.created_at }}</span>
        </div>
        <a
            href="{{ item.activity_url }}"
            class="mt-1 block focus-visible:outline-offset-2"
        >
            <h3 class="text-body font-semibold text-text-primary">{{ item.name }}</h3>
        </a>
        <p class="mt-1 text-micro text-text-muted">{{ item.entry_count }} total</p>
        {% if item.memo %}
        {% set lines = item.memo.split('\n') %}
        <p class="mt-2 text-caption text-text-secondary">{{ lines[:2] | join('\n') }}{% if lines | length > 2 %}&hellip;{% endif %}</p>
        {% endif %}
    </article>
    {% else %}
    <p class="text-caption text-text-muted">{{ strings.ENTRY_FEED_EMPTY }}</p>
    {% endfor %}
</div>
