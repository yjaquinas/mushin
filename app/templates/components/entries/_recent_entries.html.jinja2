<div
    id="recent-entries"
    class="flex flex-col gap-3"
>
    {% for item in feed_entries %}
    <a
        href="{{ item.activity_url }}?entry_id={{ item.entry_id }}"
        class="group block rounded-card border border-border bg-surface-2 p-4 transition hover:border-strong focus-visible:outline-offset-2"
    >
        <span class="text-caption font-medium text-text-secondary group-hover:text-text-primary">@{{ item.username }}</span>
        <h3 class="mt-0.5 text-body font-semibold text-text-primary">{{ item.name }}</h3>
        <span
            class="mt-1 block text-micro text-text-muted"
            data-local-timestamp="{{ item.created_at }}"
        >{{ item.created_at }}</span>
        {% if item.memo %}
        {% set lines = item.memo.split('\n') %}
        <p class="mt-1 text-caption text-text-secondary line-clamp-2">{{ lines[:2] | join('\n') }}{% if lines | length > 2 %}&hellip;{% endif %}</p>
        {% endif %}
    </a>
    {% else %}
    <p class="text-caption text-text-muted">{{ strings.ENTRY_FEED_EMPTY }}</p>
    {% endfor %}
</div>
