{#
  Shared single-entry-row macro: collapsed one-line summary plus an expanded
  inline detail state that reveals the full note and comments.

  This is the one canonical row shape used by:
    - components/history/period_log.html.jinja2 (the full chronological log)
    - components/history/day_entries.html.jinja2 (the day-detail panel)
    - the read-only fragment returned by app/routes/web.py's
      ``_render_entry_row`` (the update/cancel-edit swap-back target)

  Parameters (all plain, non-namespaced — callers holding a ``history``
  dict pass ``history.is_owner`` etc. through positionally/by keyword; the
  macro itself doesn't know about ``history``):
    entry                     dict        — hydrated entry; comment_count
                                             must already be set (0 if none).
    activity_id               int         — owning activity (edit-route URLs)
    is_owner                  bool        — edit button shown only when true
    can_comment               bool        — comments load in the expanded view
                                             when this or entry.comment_count
                                             is truthy
    username                  str | None  — comment routes suppressed
    slug                      str | None    entirely when either is None
    expand_comment_entry_id   int | None  — optional ``?entry_id={id}`` deep-link target;
                                             matching entry auto-expands and
                                             loads its comments on render.
    login_redirect_url        str | None  — optional already-validated
                                             `/?next=...` URL; an entry
                                             with zero comments shows a
                                             "log in to comment" link instead
                                             of comment metadata when set.
#}

{% macro entry_row(entry, activity_id, is_owner=False, can_comment=False, username=None, slug=None, expand_comment_entry_id=None, login_redirect_url=None) %}
{% set memo_text = entry.memo or "" %}
{% set memo_lines = memo_text.split('\n') %}
{% set collapsed_memo = memo_lines[0] if memo_lines else "" %}
{% set show_full_memo = memo_text | length > 80 or memo_lines | length > 1 %}
{% set entry_time = entry.occurred_at | format_entry_time %}
<li
    id="entry-row-{{ entry.id }}"
    class="entry-row flex flex-col gap-1 py-2"
    data-entry-row
    data-entry-tags="{{ entry.memo | entry_tags_csv }}"
    {% if expand_comment_entry_id == entry.id %}data-entry-deep-link{% endif %}
>
    <div class="flex items-center gap-2">
        <button
            type="button"
            aria-expanded="{% if expand_comment_entry_id == entry.id %}true{% else %}false{% endif %}"
            data-entry-toggle
            data-entry-id="{{ entry.id }}"
            class="flex min-w-0 flex-1 items-center justify-between gap-2 rounded text-left transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            <span class="min-w-0 flex flex-1 items-baseline gap-2 text-body text-text-primary">
                <span class="shrink-0 text-caption text-text-muted">{{ entry.occurred_at[:10] }}</span>
                {% if entry.time_known and entry_time %}
                <span
                    class="shrink-0 text-caption text-text-muted"
                    data-entry-time
                    {% if expand_comment_entry_id != entry.id %}hidden{% endif %}
                >{{ entry_time }}</span>
                {% endif %}
                {% if entry.hidden_at %}
                <span
                    class="block min-w-0 flex-1 truncate text-text-muted italic"
                    data-entry-summary
                    {% if expand_comment_entry_id == entry.id %}hidden{% endif %}
                >{{ strings.ENTRY_HIDDEN_BY_MODERATOR }}</span>
                {% elif entry.memo %}
                <span
                    class="block min-w-0 flex-1 truncate"
                    data-entry-summary
                    {% if expand_comment_entry_id == entry.id %}hidden{% endif %}
                >
                    {{ collapsed_memo }}{% if show_full_memo %} ...{% endif %}
                </span>
                {% endif %}
            </span>
            <span class="flex shrink-0 items-center gap-2 text-caption text-text-muted">
            {% if username is not none and slug is not none %}
                <span
                    class="flex shrink-0 items-center gap-1"
                    data-entry-comment-indicator
                >
                    <span
                        data-entry-comment-icon-collapsed
                        {% if expand_comment_entry_id == entry.id %}hidden{% endif %}
                    >{{ icon('message-circle', size=20) }}</span>
                    <span
                        data-entry-comment-icon-expanded
                        {% if expand_comment_entry_id != entry.id %}hidden{% endif %}
                    >{{ icon('chevron-up', size=20) }}</span>
                    <span>{{ strings.COMMENTS_COUNT_LABEL.format(count=entry.comment_count or 0) }}</span>
                </span>
            {% endif %}
            </span>
        </button>
        {% if is_owner %}
        <button
            type="button"
            aria-label="{{ strings.ENTRY_EDIT }}"
            hx-get="/activities/{{ activity_id }}/entries/{{ entry.id }}/edit"
            hx-target="#entry-edit-dialog-{{ entry.id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap flex shrink-0 items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >
            {{ icon('pencil', size=20) }}
        </button>
        {% endif %}
    </div>

    <div
        id="entry-expanded-{{ entry.id }}"
        class="flex flex-col gap-2"
        {% if expand_comment_entry_id != entry.id %}hidden{% endif %}
    >
        {% if entry.hidden_at %}
        <p class="whitespace-pre-wrap break-words text-body text-text-muted italic">{{ strings.ENTRY_HIDDEN_BY_MODERATOR }}</p>
        {% elif memo_text %}
        <p class="whitespace-pre-wrap break-words text-body text-text-primary">{{ memo_text }}</p>
        {% endif %}

        {% if (entry.comment_count or can_comment) and username is not none and slug is not none %}
        <div id="comment-slot-{{ entry.id }}"></div>
        <div
            id="comment-loader-{{ entry.id }}"
            hidden
            hx-get="/@{{ username }}/{{ slug }}/entries/{{ entry.id }}/comments"
            hx-target="#comment-slot-{{ entry.id }}"
            hx-swap="innerHTML"
            hx-trigger="{% if expand_comment_entry_id == entry.id %}load{% else %}load-comments{% endif %}"
        ></div>
        {% elif login_redirect_url %}
        <a
            href="{{ login_redirect_url }}"
            class="text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
        >{{ strings.COMMENTS_LOGIN_TO_COMMENT }}</a>
        {% endif %}
    </div>
    <div id="entry-edit-dialog-{{ entry.id }}"></div>
</li>
{% endmacro %}
