{#
  Shared form body for both the inline and dialog log-sheet variants.
  Renders the field inputs, date/time picker, and submit button.

  Context: activity_id, fields (field-priority order), today (YYYY-MM-DD).
#}
{% for field in fields %}
    {% if field.kind == "memo" %}
        <div class="flex flex-col gap-1">
            <label for="memo" class="text-caption font-medium text-text-secondary">
                {{ strings.LOG_MEMO_LABEL }}
            </label>
            <textarea
                id="memo"
                name="memo"
                rows="3"
                placeholder="{{ strings.LOG_MEMO_PLACEHOLDER }}"
                data-bounded-textarea
                data-bounded-max-lines="10"
                data-bounded-max-chars="1000"
                data-bounded-max-lines-message="{{ strings.LOG_NOTES_MAX_LINES_REACHED }}"
                data-bounded-max-chars-message="{{ strings.LOG_NOTES_MAX_CHARS_REACHED }}"
                class="resize-none overflow-hidden rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            ></textarea>
            <span class="self-end text-caption text-text-muted" data-bounded-char-count>0/1,000</span>
        </div>
    {% elif field.kind == "count" %}
        <div class="flex flex-col gap-1">
            <label for="num_value" class="text-caption font-medium text-text-secondary">
                {{ field.label }}
            </label>
            <input
                type="number"
                inputmode="decimal"
                step="any"
                id="num_value"
                name="num_value"
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            >
        </div>
    {% endif %}
{% endfor %}

<div class="flex flex-col gap-2">
    <div class="flex flex-col gap-1">
        <label for="date" class="text-caption font-medium text-text-secondary">
            {{ strings.LOG_OCCURRED_AT_LABEL }}
        </label>
        <input
            type="date"
            id="date"
            name="date"
            value="{{ today }}"
            required
            class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
        >
    </div>
    <label class="flex min-h-tap items-center gap-2 text-body text-text-secondary">
        <input
            type="checkbox"
            name="add_time"
            class="rounded border-border"
            data-toggle-time
        >
        {{ strings.LOG_TIME_ADD }}
    </label>
    <div hidden class="flex flex-col gap-1">
        <label for="time" class="text-caption font-medium text-text-secondary">
            {{ strings.LOG_TIME_ADD }}
        </label>
        <input
            type="time"
            id="time"
            name="time"
            class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
        >
    </div>
</div>

<button
    type="submit"
    hx-disabled-elt="this"
    class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
>
    {{ strings.LOG_SUBMIT }}
</button>
