{# Entry-delete confirm dialog. HTMX swaps this whole component into the
   per-entry dialog slot and JS opens it automatically. #}
<div id="entry-delete-dialog-{{ entry.id }}" hidden data-auto-open>
    <div
        class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
        role="presentation"
    >
        <div
            role="dialog"
            aria-modal="true"
            aria-labelledby="entry-delete-title-{{ entry.id }}"
            tabindex="-1"
            class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
        >
            <h2 id="entry-delete-title-{{ entry.id }}" class="text-body font-semibold text-text-primary">
                {{ strings.ENTRY_DELETE }}
            </h2>
            <p class="text-caption text-text-muted">{{ strings.ENTRY_DELETE_CONFIRM_BODY }}</p>
            <div class="flex flex-col gap-3">
                <button
                    type="button"
                    hx-post="/activities/{{ activity_id }}/entries/{{ entry.id }}/delete"
                    hx-target="closest .entry-row"
                    hx-swap="outerHTML"
                    class="min-h-tap w-full rounded-button bg-danger px-4 py-3 text-body font-semibold text-white transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ENTRY_DELETE_CONFIRM }}
                </button>
                <button
                    type="button"
                    data-dialog-close="entry-delete"
                    class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ENTRY_DELETE_CANCEL }}
                </button>
            </div>
        </div>
    </div>
</div>
