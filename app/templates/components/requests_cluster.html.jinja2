{#
  Requests cluster — owner-only, rendered separately from the fellows
  disclosure and only when there is pending state.

  Incoming pending: Accept (direct) / Decline (direct).
  Outgoing pending: "Requested" label + a quiet Cancel (direct).

  Context: `fellows.incoming_requests` / `fellows.outgoing_requests`, each
  ``[{connection_id, id, username, display_name}, ...]`` (see
  app.services.connections.list_incoming_pending / list_outgoing_pending),
  `fellows.pending_count`.
#}
<section class="flex flex-col gap-3 pt-4">
    <header class="flex flex-wrap items-center gap-2">
        <h2 class="text-title font-medium text-text-primary">
            {{ strings.REQUESTS_HEADING }} ({{ strings.REQUESTS_PENDING_BADGE.format(count=fellows.pending_count) }})
        </h2>
    </header>

    {% if fellows.incoming_requests %}
    <ul class="flex flex-col gap-2">
        {% for req in fellows.incoming_requests %}
        <li class="flex flex-wrap items-center justify-between gap-2 rounded-card px-1 py-1">
            <a
                href="/@{{ req.username }}"
                class="flex min-h-tap flex-wrap items-center gap-x-2 gap-y-0.5 rounded-card px-2 py-2 text-body text-text-primary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >
                <span class="font-medium">@{{ req.username }}</span>
                {% if req.display_name %}
                <span class="text-caption text-text-secondary">{{ req.display_name }}</span>
                {% endif %}
            </a>
            <div class="flex flex-wrap items-center gap-2">
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/accept"
                    hx-target="#fellows-section"
                    hx-swap="outerHTML"
                    class="min-h-tap rounded-button bg-brand px-3 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.REQUESTS_ACCEPT }}</button>
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/decline"
                    hx-target="#fellows-section"
                    hx-swap="outerHTML"
                    class="min-h-tap rounded-button border border-border px-3 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.REQUESTS_DECLINE }}</button>
            </div>
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if fellows.outgoing_requests %}
    <ul class="flex flex-col gap-2">
        {% for req in fellows.outgoing_requests %}
        <li class="flex flex-wrap items-center justify-between gap-2 rounded-card px-1 py-1">
            <a
                href="/@{{ req.username }}"
                class="flex min-h-tap flex-wrap items-center gap-x-2 gap-y-0.5 rounded-card px-2 py-2 text-body text-text-primary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >
                <span class="font-medium">@{{ req.username }}</span>
                {% if req.display_name %}
                <span class="text-caption text-text-secondary">{{ req.display_name }}</span>
                {% endif %}
            </a>
            <div class="flex flex-wrap items-center gap-2">
                <span class="text-caption text-text-muted">{{ strings.REQUESTS_OUTGOING_HEADING }}</span>
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/cancel"
                    hx-target="#fellows-section"
                    hx-swap="outerHTML"
                    class="min-h-tap rounded-button border border-border px-3 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.REQUESTS_CANCEL }}</button>
            </div>
        </li>
        {% endfor %}
    </ul>
    {% endif %}
</section>
