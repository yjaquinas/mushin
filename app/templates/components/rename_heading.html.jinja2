{#
  Plain (read-only) activity-name heading fragment — used by the cancel route
  to swap #rename-heading back to the non-editable state without a page reload.

  Context:
    activity_id   int   — the sub-tally id (for the pencil button)
    current_name   str   — the activity name to display
#}
{% from "components/_icon.html.jinja2" import icon %}
<h1 class="text-title font-semibold text-text-primary">{{ current_name }}</h1>
<button
    type="button"
    aria-label="{{ strings.RENAME_LABEL }}"
    hx-get="/activities/{{ activity_id }}/rename-form"
    hx-target="#rename-heading"
    hx-swap="innerHTML"
    class="min-h-tap min-w-tap flex items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
>{{ icon('pencil', size=16) }}</button>
