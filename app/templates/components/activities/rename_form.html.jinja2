{# Activity-rename dialog. HTMX swaps this whole component into
   #activity-dialog-rename and JS opens it automatically. #}
<div
    id="activity-dialog-rename"
    hidden
    data-auto-open
>
    <div
        class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
        role="presentation"
    >
        <div
            role="dialog"
            aria-modal="true"
            aria-labelledby="rename-activity-title"
            tabindex="-1"
            class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
        >
            <h2 id="rename-activity-title" class="text-body font-semibold text-text-primary">
                {{ strings.ACTIVITY_EDIT_TITLE }}
            </h2>

            <form
                hx-post="/activities/{{ activity_id }}/rename"
                hx-target="#activity-dialog-rename"
                hx-swap="outerHTML"
                class="flex flex-col gap-4"
                data-secret-allowed="{{ "true" if secret_allowed|default(true) else "false" }}"
                data-secret-toast="{{ secret_toast_message|default("Secret activities are available on the Premium plan.") }}"
            >
                <div class="flex flex-col gap-1">
                    <label for="rename-input" class="text-caption font-medium text-text-secondary">
                        {{ strings.RENAME_LABEL }}
                    </label>
                    <input
                        id="rename-input"
                        type="text"
                        name="name"
                        value="{{ current_name }}"
                        maxlength="20"
                        required
                        autofocus
                        class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-1 text-body text-text-primary focus-visible:outline-2"
                    >
                </div>

                {% if error %}
                <p class="text-caption text-danger" role="alert">{{ error }}</p>
                {% endif %}

                <p class="text-caption text-text-muted">{{ strings.RENAME_SLUG_NOTICE }}</p>

                <div class="flex items-start gap-3 border-t border-border pt-3">
                    <input
                        type="checkbox"
                        id="activity-secret-edit"
                        name="secret"
                        value="1"
                        {% if is_secret %}checked{% endif %}
                        class="mt-1 h-4 w-4 rounded border-border text-brand focus-visible:outline-2"
                    >
                    <div class="flex flex-col gap-0.5">
                        <label for="activity-secret-edit" class="text-body font-medium text-text-primary">
                            {{ strings.ACTIVITY_FORM_SECRET_LABEL }}
                        </label>
                        <p class="text-caption text-text-muted">{{ strings.ACTIVITY_FORM_SECRET_HELP }}</p>
                    </div>
                </div>

                <button
                    type="submit"
                    class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.ACTIVITY_EDIT_SAVE }}</button>
                <button
                    type="button"
                    id="rename-activity-cancel-button"
                    class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >{{ strings.RENAME_CANCEL }}</button>

                <div class="h-px bg-border" aria-hidden="true"></div>
                <button
                    type="button"
                    hx-get="/activities/{{ activity_id }}/delete-confirm"
                    hx-target="#activity-dialog-rename"
                    hx-swap="outerHTML"
                    class="min-h-tap w-full rounded-button border border-danger bg-danger-subtle px-4 py-3 text-body font-semibold text-danger transition hover:opacity-90 focus-visible:outline-offset-2"
                >{{ strings.ACTIVITY_DELETE }}</button>
            </form>
        </div>
    </div>
</div>
