{#
  Create-activity form body — name only (no icon picker).
  Used by the HTMX sheet fragment activity_sheet.html.jinja2.

  Submits to POST /activities. On success the route returns 201 with
  ``HX-Redirect`` to the new activity's detail page.
  On failure (empty / duplicate name), returns 400 with the form fragment
  and an inline error message.

  Optional: hx_post/hx_target/hx_swap (embedded-sheet context — when unset,
  renders a plain form posting to /activities for the standalone page).
  Optional: name_error (shown near the name field when present).
#}
<form
    {% if hx_post is defined %}
    hx-post="{{ hx_post }}"
    hx-target="{{ hx_target }}"
    hx-swap="{{ hx_swap }}"
    {% else %}
    method="post"
    action="/activities"
    {% endif %}
    class="flex flex-col gap-4"
>
    <div class="flex flex-col gap-1">
        <label for="activity-name" class="text-caption font-medium text-text-secondary">
            {{ strings.ACTIVITY_FORM_NAME_LABEL }}
        </label>
        <input
            type="text"
            id="activity-name"
            name="name"
            required
            placeholder="{{ strings.ACTIVITY_FORM_NAME_PLACEHOLDER }}"
            class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
        >
        {% if name_error %}
            <p class="text-caption text-danger">{{ name_error }}</p>
        {% endif %}
    </div>

    <button
        type="submit"
        {% if hx_post is defined %}hx-disabled-elt="this"{% endif %}
        class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-title font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
    >
        {{ strings.ACTIVITY_FORM_SUBMIT }}
    </button>
</form>
