{#
  Notes field — free text with inline #tags. Replaces the separate memo and hashtag inputs.
  Context: activity_id, field (id, label, hashtag_text).
  hashtag_text: entry.memo verbatim on edit; "" for new entries.
#}
<div class="flex flex-col gap-1">
    <label for="notes-input-{{ field.id }}" class="text-caption font-medium text-text-secondary">
        {{ strings.LOG_NOTES_LABEL }}
    </label>
    <textarea
        id="notes-input-{{ field.id }}"
        name="hashtags_{{ field.id }}"
        rows="3"
        placeholder="{{ strings.LOG_NOTES_PLACEHOLDER }}"
        class="min-h-tap w-full rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2 resize-none"
    >{{ field.hashtag_text or '' }}</textarea>
</div>
