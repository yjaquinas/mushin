{# The destructive confirmation is the second state of the edit-activity
   dialog, so it swaps into the same dialog host rather than stacking modals. #}
<div id="activity-dialog-rename" hidden data-auto-open>
    <div
        class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
        role="presentation"
    >
        <div
            role="dialog"
            aria-modal="true"
            aria-labelledby="activity-delete-title"
            tabindex="-1"
            class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
        >
            <h2 id="activity-delete-title" class="text-body font-semibold text-text-primary">
                {{ strings.ACTIVITY_DELETE }}
            </h2>
            <p class="text-caption text-text-muted">{{ strings.ACTIVITY_DELETE_CONFIRM_BODY }}</p>
            <div class="flex flex-col gap-3">
                <button
                    type="button"
                    hx-post="/activities/{{ activity_id }}/delete"
                    hx-target="#activity-dialog-rename"
                    hx-swap="outerHTML"
                    class="min-h-tap w-full rounded-button bg-danger px-4 py-3 text-body font-semibold text-on-danger transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ACTIVITY_DELETE_CONFIRM }}
                </button>
                <button
                    type="button"
                    hx-get="/activities/{{ activity_id }}/rename-form"
                    hx-target="#activity-dialog-rename"
                    hx-swap="outerHTML"
                    class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
                >
                    {{ strings.ACTIVITY_DELETE_CANCEL }}
                </button>
            </div>
        </div>
    </div>
</div>
