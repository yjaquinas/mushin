{#
  Shared add-activity form — used by both the empty-state and has-cards
  variants on the home page. The surrounding #add-activity-inline disclosure
  differs between states; only this form is shared.
#}
<form
    id="add-activity-form"
    hx-post="/activities"
    hx-target="#cards"
    hx-swap="afterbegin"
    class="flex flex-col gap-4"
>
    <div class="flex flex-col gap-1">
        <label for="activity-name" class="text-caption font-medium text-text-secondary">
            {{ strings.ACTIVITY_FORM_NAME_LABEL }}
        </label>
        <input
            type="text"
            id="activity-name"
            name="name"
            required
            placeholder="{{ strings.ACTIVITY_FORM_NAME_PLACEHOLDER }}"
            class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-1 text-body text-text-primary focus-visible:outline-2"
        >
    </div>

    <button
        type="submit"
        hx-disabled-elt="this"
        class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-body font-semibold text-on-brand transition focus-visible:outline-offset-2 disabled:opacity-60"
    >
        {{ strings.ACTIVITY_FORM_SUBMIT }}
    </button>
</form>
