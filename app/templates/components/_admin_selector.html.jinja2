{% if selector.kind == "month-grid" %}
<div class="mt-4">
    <div class="mb-3 flex items-center justify-between gap-3">
        <a
            href="/admin?period={{ selected_period }}&calendar_month={{ selector.prev_value }}&{% if selected_period == 'daily' %}day={{ selector.prev_period_value }}{% else %}week={{ selector.prev_period_value }}{% endif %}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.CALENDAR_PREV_MONTH }}"
        >
            &lt;
        </a>
        <h3 class="text-body font-medium text-text-primary">{{ selector.title }}</h3>
        <a
            href="/admin?period={{ selected_period }}&calendar_month={{ selector.next_value }}&{% if selected_period == 'daily' %}day={{ selector.next_period_value }}{% else %}week={{ selector.next_period_value }}{% endif %}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.CALENDAR_NEXT_MONTH }}"
        >
            &gt;
        </a>
    </div>
    <table class="w-full border-collapse">
        <thead>
            <tr>
                {% for wd in selector.weekdays %}
                <th scope="col" class="pb-2 text-caption font-medium text-text-muted">{{ wd }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for week in selector.weeks %}
            <tr class="{% if selected_period == 'weekly' %}admin-week-row{% endif %}">
                {% for day in week %}
                <td class="text-center">
                    {% if selected_period == "daily" %}
                    <a
                        href="/admin?period=daily&day={{ day.date }}&calendar_month={{ selector.title }}&page=1"
                        class="admin-day{% if day.today %} admin-day--today{% endif %}{% if day.selected %} admin-day--selected{% endif %}{% if not day.in_month %} admin-day--outside{% endif %}"
                    >
                        {{ day.day }}
                    </a>
                    {% else %}
                    <a
                        href="/admin?period=weekly&week={{ day.week_value }}&calendar_month={{ selector.title }}&page=1"
                        class="admin-week-day{% if day.week_selected %} admin-week-day--selected{% endif %}{% if day.current_week and loop.first %} admin-week-day--today{% endif %}{% if not day.in_month %} admin-week-day--outside{% endif %}{% if loop.first %} admin-week-day--first{% endif %}{% if loop.last %} admin-week-day--last{% endif %}"
                    >
                        {{ day.day }}
                    </a>
                    {% endif %}
                </td>
                {% endfor %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% elif selector.kind == "month-picker" %}
<div class="mt-4">
    <div class="mb-3 flex items-center justify-between gap-3">
        <a
            href="/admin?period=monthly&month={{ selected_value }}&calendar_year={{ selector.prev_value }}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.ADMIN_PREVIOUS_YEAR }}"
        >
            &lt;
        </a>
        <h3 class="text-body font-medium text-text-primary">{{ selector.title }}</h3>
        <a
            href="/admin?period=monthly&month={{ selected_value }}&calendar_year={{ selector.next_value }}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.ADMIN_NEXT_YEAR }}"
        >
            &gt;
        </a>
    </div>
    <div class="grid grid-cols-4 gap-2">
        {% for row in selector.rows %}
            {% for month in row %}
            <a
                href="/admin?{% if month.selected %}period=weekly&week={{ month.drill_week_value }}&calendar_month={{ month.value }}{% else %}period=monthly&month={{ month.value }}&calendar_year={{ selector.title }}{% endif %}&page=1"
                class="admin-grid-card{% if month.selected %} admin-grid-card--selected{% endif %}{% if month.today %} admin-grid-card--today{% endif %}"
            >
                {{ month.label }}
            </a>
            {% endfor %}
        {% endfor %}
    </div>
</div>
{% elif selector.kind == "year-picker" %}
<div class="mt-4">
    <div class="mb-3 flex items-center justify-between gap-3">
        <a
            href="/admin?period=yearly&year={{ selector.prev_period_value }}&calendar_year={{ selector.prev_value }}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.ADMIN_PREVIOUS_YEAR }}"
        >
            &lt;
        </a>
        <h3 class="text-body font-medium text-text-primary">{{ selector.title }}</h3>
        <a
            href="/admin?period=yearly&year={{ selector.next_period_value }}&calendar_year={{ selector.next_value }}&page=1"
            class="flex min-h-tap min-w-tap items-center justify-center rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2"
            aria-label="{{ strings.ADMIN_NEXT_YEAR }}"
        >
            &gt;
        </a>
    </div>
    <div class="grid grid-cols-4 gap-2">
        {% for row in selector.rows %}
            {% for year in row %}
            <a
                href="/admin?{% if year.selected %}period=monthly&month={{ year.drill_month_value }}&calendar_year={{ year.value }}{% else %}period=yearly&year={{ year.value }}&calendar_year={{ selector.title }}{% endif %}&page=1"
                class="admin-grid-card{% if year.selected %} admin-grid-card--selected{% endif %}{% if year.today %} admin-grid-card--today{% endif %}"
            >
                {{ year.label }}
            </a>
            {% endfor %}
        {% endfor %}
    </div>
</div>
{% endif %}
