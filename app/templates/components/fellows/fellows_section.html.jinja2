{#
  Fellows section — always visible, one line, no collapse.
  Context: fellows (fellow_count, fellows list, show_fellow_names, is_owner,
           pending_count), username, error.
#}
{% set section_scope = "profile" if fellows.is_owner else "social-profile" %}
<section
    id="{{ section_scope }}-section-fellows"
    aria-labelledby="{{ section_scope }}-title-fellows"
    class="flat-section"
>
    <div class="flex items-center justify-between gap-3">
        <h2 id="{{ section_scope }}-title-fellows" class="flat-section-title">{{ strings.FELLOWS_HEADING }}</h2>
        <div class="flex items-center gap-2">
            {% if not fellows.is_owner and state is defined and viewer_logged_in %}
            {% if state == "none" %}
            <button
                type="button"
                hx-post="/fellows/{{ username }}/connect"
                hx-target="#{{ section_scope }}-section-fellows"
                hx-swap="outerHTML"
                class="rounded-button bg-brand px-2 py-0.5 text-sm font-semibold text-on-brand transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.CONNECT_ACTION }}</button>
            {% elif state == "pending_outgoing" %}
            <button
                type="button"
                hx-get="/fellows/requests/{{ username }}/cancel-confirm?source=profile"
                hx-target="#connect-cancel-dialog-{{ username }}"
                hx-swap="outerHTML"
                class="rounded-button border border-border px-2 py-0.5 text-sm font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.CONNECT_REQUESTED }}</button>
            {% elif state == "pending_incoming" %}
            <button
                type="button"
                hx-post="/fellows/requests/{{ username }}/accept?source=profile"
                hx-target="#{{ section_scope }}-section-fellows"
                hx-swap="outerHTML"
                class="rounded-button bg-brand px-2 py-0.5 text-sm font-semibold text-on-brand transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.REQUESTS_ACCEPT }}</button>
            <button
                type="button"
                hx-post="/fellows/requests/{{ username }}/decline?source=profile"
                hx-target="#{{ section_scope }}-section-fellows"
                hx-swap="outerHTML"
                class="rounded-button border border-border px-2 py-0.5 text-sm font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.REQUESTS_DECLINE }}</button>
            {% elif state == "fellow" %}
            <button
                type="button"
                hx-get="/fellows/{{ username }}/remove-confirm"
                hx-target="#connect-remove-dialog-{{ username }}"
                hx-swap="outerHTML"
                class="rounded-button border border-accent px-2 py-0.5 text-sm font-medium text-accent-text transition hover:bg-accent-subtle focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.CONNECT_REMOVE_CONFIRM }}</button>
            {% elif state == "blocked" %}
            <button
                type="button"
                hx-post="/fellows/{{ username }}/unblock"
                hx-target="#{{ section_scope }}-section-fellows"
                hx-swap="outerHTML"
                class="rounded-button border border-border px-2 py-0.5 text-sm font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.CONNECT_UNBLOCK }}</button>
            {% endif %}
            {% endif %}
            {% if (username is defined and username) and (fellows.is_owner or view_mode is not defined or view_mode != "limited") %}
            <a
                href="/@{{ username }}/fellows"
                class="inline-flex items-center gap-1 rounded-button border border-border px-2 py-0.5 text-sm font-medium text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >
                <span class="text-sm">{{ strings.FELLOWS_MANAGE }}</span>
                {% if fellows.pending_count > 0 %}
                <span class="inline-flex size-5 items-center justify-center rounded-full bg-brand text-[0.625rem] font-semibold text-on-brand">{{ "9+" if fellows.pending_count >= 9 else fellows.pending_count }}</span>
                {% endif %}
            </a>
            {% endif %}
        </div>
    </div>

    {% if error %}
    <p class="text-caption text-danger" role="alert">{{ error }}</p>
    {% endif %}

    {% set _show_contents = (view_mode is defined and view_mode != "limited") or (view_mode is not defined and (fellows.is_owner or fellows.show_fellow_names)) %}
    {% if _show_contents %}
    {% if fellows.fellow_count == 0 %}
    <p class="text-caption text-text-secondary">{{ strings.FELLOWS_EMPTY }}</p>
    {% elif fellows.show_fellow_names %}
    <ul class="flex gap-2 overflow-x-auto pb-1">
        {% for fellow in fellows.fellows %}
        {% set fellow_label = fellow.username %}
        {% set initials = fellow.username[:2] %}
        <li class="shrink-0">
            <a
                href="/@{{ fellow.username }}"
                class="flex min-h-tap w-16 flex-col items-center gap-1 px-1 py-2 text-center transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >
                <span
                    class="flex h-10 w-10 min-h-tap min-w-tap items-center justify-center rounded-full border border-border-strong bg-surface-2 text-body font-semibold text-text-primary"
                    aria-hidden="true"
                >{{ initials | upper }}</span>
                <span class="w-full truncate text-[0.625rem] leading-tight text-text-secondary">{{ fellow_label }}</span>
            </a>
        </li>
        {% endfor %}
    </ul>
    {% else %}
    <p class="text-body text-text-secondary">
        {% if fellows.fellow_count == 1 %}
            {{ strings.FELLOWS_COUNT_LABEL_ONE }}
        {% else %}
            {{ strings.FELLOWS_COUNT_LABEL.format(count=fellows.fellow_count) }}
        {% endif %}
    </p>
    {% endif %}
    {% endif %}

</section>
<div id="connect-remove-dialog-{{ username }}" hidden></div>
<div id="connect-cancel-dialog-{{ username }}" hidden></div>
