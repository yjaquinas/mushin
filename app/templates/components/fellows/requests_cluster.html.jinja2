{#
  Requests cluster — owner-only.
  Context: fellows.incoming_requests / fellows.outgoing_requests,
  fellows.pending_count.
#}
{% set requests_hx_target = requests_hx_target | default('#fellows-section') %}
{% set requests_hx_source = requests_hx_source | default('') %}
<section class="flex flex-col gap-3">
    <header class="flex flex-wrap items-center gap-2">
        <h2 class="text-title font-medium text-text-primary">
            {{ strings.REQUESTS_HEADING }} ({{ strings.REQUESTS_PENDING_BADGE.format(count=fellows.pending_count) }})
        </h2>
    </header>

    {% if fellows.incoming_requests %}
    <ul class="flex flex-col gap-2">
        {% for req in fellows.incoming_requests %}
        <li class="flex items-center justify-between rounded-card border border-border bg-surface-1 px-4 py-3">
            <a href="/@{{ req.username }}" class="text-body font-medium text-text-primary hover:underline">{{ req.username }}</a>
            <div class="flex flex-wrap items-center gap-2">
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/accept{{ requests_hx_source }}"
                    hx-target="{{ requests_hx_target }}"
                    hx-swap="outerHTML"
                    class="rounded-button border border-border px-3 py-1.5 text-caption text-text-secondary transition hover:bg-surface-2"
                >{{ strings.REQUESTS_ACCEPT }}</button>
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/decline{{ requests_hx_source }}"
                    hx-target="{{ requests_hx_target }}"
                    hx-swap="outerHTML"
                    class="rounded-button border border-border px-3 py-1.5 text-caption text-text-secondary transition hover:bg-surface-2"
                >{{ strings.REQUESTS_DECLINE }}</button>
            </div>
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if fellows.outgoing_requests %}
    <ul class="flex flex-col gap-2">
        {% for req in fellows.outgoing_requests %}
        <li class="flex items-center justify-between rounded-card border border-border bg-surface-1 px-4 py-3">
            <a href="/@{{ req.username }}" class="text-body font-medium text-text-primary hover:underline">{{ req.username }}</a>
            <div class="flex flex-wrap items-center gap-2">
                <span class="text-caption text-text-muted">{{ strings.REQUESTS_OUTGOING_HEADING }}</span>
                <button
                    type="button"
                    hx-post="/fellows/requests/{{ req.username }}/cancel{{ requests_hx_source }}"
                    hx-target="{{ requests_hx_target }}"
                    hx-swap="outerHTML"
                    class="rounded-button border border-border px-3 py-1.5 text-caption text-text-secondary transition hover:bg-surface-2"
                >{{ strings.REQUESTS_CANCEL }}</button>
            </div>
        </li>
        {% endfor %}
    </ul>
    {% endif %}
</section>
