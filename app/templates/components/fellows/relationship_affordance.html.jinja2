{#
  Relationship-state affordance on another user's read-only profile —
  one control reflecting `connections.relationship_state`. Swappable as a
  whole fragment after any action (see app.routes.web._render_relationship_affordance).

  Context: `username` (the profile being viewed), `state` (one of
  "self" | "blocked" | "fellow" | "pending_outgoing" | "pending_incoming" |
  "none"), `error` (str|None).

  Optional `dom_id` (defaults to "relationship-affordance") and
  `pending_incoming_target_id` (defaults to "fellows-section") let a caller
  with MULTIPLE instances on one page (e.g. search results, one row per
  person) give each instance a unique id so HTMX's id-selector swap
  (`document.querySelector`, always the first match) targets the right row
  instead of always the first one on the page. Single-instance callers
  (profile pages) omit both and get the original ids unchanged. Optional
  `from_search` (bool, default false) appends `?source=search` to every
  outgoing action URL so the route handlers know to swap this row instead of
  the page-singleton fellows section / use the per-row dom_id downstream.
#}
{% set dom_id = dom_id | default("relationship-affordance") %}
{% set remove_dialog_id = remove_dialog_id | default("connect-remove-dialog-" + username) %}
{% set cancel_request_dialog_id = cancel_request_dialog_id | default("connect-cancel-dialog-" + username) %}
{% set pending_incoming_target_id = pending_incoming_target_id | default("fellows-section") %}
{% set from_search = from_search | default(false) %}
{% set qs = "?source=search" if from_search else "" %}
{% set cancel_qs = "?source=search" if from_search else "?source=profile" %}
<div id="{{ dom_id }}" class="flex flex-col gap-2">
    {% if error %}
    <p class="text-caption text-danger" role="alert">{{ error }}</p>
    {% endif %}

    {% if state == "none" %}
    <div class="flex flex-wrap items-center gap-2">
        <button
            type="button"
            hx-post="/fellows/{{ username }}/connect{{ qs }}"
            hx-target="#{{ dom_id }}"
            hx-swap="outerHTML"
            class="inline-flex min-h-tap items-center gap-2 rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        ><span aria-hidden="true">{{ icon("user-plus", size=18) }}</span><span>{{ strings.CONNECT_ACTION }}</span></button>
    </div>

    {% elif state == "pending_outgoing" %}
    <button
        type="button"
        hx-get="/fellows/requests/{{ username }}/cancel-confirm{{ cancel_qs }}"
        hx-target="#{{ cancel_request_dialog_id }}"
        hx-swap="outerHTML"
        class="min-h-tap self-start rounded-button border border-border px-4 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    >{{ strings.CONNECT_REQUESTED }}</button>

    {% elif state == "pending_incoming" %}
    <div class="flex flex-wrap items-center gap-2">
        <button
            type="button"
            hx-post="/fellows/requests/{{ username }}/accept{{ qs }}"
            hx-target="#{{ pending_incoming_target_id }}"
            hx-swap="outerHTML"
            class="min-h-tap rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >{{ strings.REQUESTS_ACCEPT }}</button>
        <button
            type="button"
            hx-post="/fellows/requests/{{ username }}/decline{{ qs }}"
            hx-target="#{{ pending_incoming_target_id }}"
            hx-swap="outerHTML"
            class="min-h-tap rounded-button border border-border px-3 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >{{ strings.REQUESTS_DECLINE }}</button>
    </div>

    {% elif state == "fellow" %}
    <button
        type="button"
        hx-get="/fellows/{{ username }}/remove-confirm{{ qs }}"
        hx-target="#{{ remove_dialog_id }}"
        hx-swap="outerHTML"
        class="min-h-tap self-start rounded-button border border-cinnabar px-4 text-body font-medium text-accent-text transition hover:bg-accent-subtle focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    >{{ strings.CONNECT_REMOVE }}</button>

    {% elif state == "blocked" %}
    <button
        type="button"
        hx-post="/fellows/{{ username }}/unblock{{ qs }}"
        hx-target="#{{ dom_id }}"
        hx-swap="outerHTML"
        class="min-h-tap rounded-button border border-border px-4 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    >{{ strings.CONNECT_UNBLOCK }}</button>
    {% endif %}
    <div id="{{ cancel_request_dialog_id }}"></div>
    <div id="{{ remove_dialog_id }}"></div>
</div>
