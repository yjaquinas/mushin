<div id="bio-section" class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
    <div class="flex items-center justify-between">
        <h2 class="text-title font-semibold text-text-primary">{{ strings.PROFILE_BIO_HEADING }}</h2>
        <button
            type="button"
            aria-label="{{ strings.PROFILE_BIO_EDIT }}"
            hx-get="/profile/bio-edit"
            hx-target="#bio-section"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap flex items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        >{{ icon('pencil', size=18) }}</button>
    </div>
    {% if bio %}
    <p class="text-body text-text-secondary">{{ bio }}</p>
    {% else %}
    <p class="text-caption text-text-muted">{{ strings.PROFILE_BIO_EMPTY }}</p>
    {% endif %}
</div>
