<section id="bio-section" class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
    <h2 class="text-title font-semibold text-text-primary">{{ strings.PROFILE_BIO_HEADING }}</h2>
    <form
        hx-post="/profile/bio"
        hx-target="#bio-section"
        hx-swap="outerHTML"
        class="flex flex-col gap-3"
    >
        <textarea
            name="bio"
            maxlength="100"
            rows="3"
            data-bounded-textarea
            data-bounded-max-chars="100"
            data-bounded-max-chars-message="{{ strings.PROFILE_BIO_TOO_LONG }}"
            placeholder="{{ strings.PROFILE_BIO_PLACEHOLDER }}"
            class="min-h-tap w-full rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary placeholder:text-text-muted focus-visible:outline-2 resize-none"
        >{{ bio or '' }}</textarea>
        <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2">
                <span class="text-caption text-text-muted" data-bounded-char-count>0/100</span>
                {% if bio_error %}
                <p class="text-caption text-danger">{{ bio_error }}</p>
                {% endif %}
            </div>
            <div class="flex gap-2">
                <button
                    type="submit"
                    class="min-h-tap rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.PROFILE_BIO_SAVE }}</button>
                <button
                    type="button"
                    hx-get="/profile/bio"
                    hx-target="#bio-section"
                    hx-swap="outerHTML"
                    class="min-h-tap rounded-button border border-border px-3 text-body text-text-secondary transition hover:bg-surface-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ strings.PROFILE_BIO_CANCEL }}</button>
            </div>
        </div>
    </form>
</div>
