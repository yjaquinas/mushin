{#
  Competition stats — W/L/D record, win rate (with basis / "No record yet" when no
  bouts), a chronological results timeline, and per-opponent head-to-head.

  Shown only on the detail screen for sub-tallies whose recipe includes a
  `match_list` field (see app.routes.web._activity_detail).

  Context: `record` (wins/losses/draws/total/decided/win_rate),
  `timeline` (list of {occurred_at, opponent, result, score}),
  `head_to_head` (list of {opponent, wins, losses, draws, total, win_rate}).
  Optional `oob` (bool) — when true, renders as an out-of-band swap target so
  POST /activities/{id}/log can refresh this section alongside the hero card
  it directly responds with (see app.routes.web.create_log).
#}
<section
    id="competition-stats"
    {% if oob %}hx-swap-oob="true"{% endif %}
    class="flex flex-col gap-4 rounded-card border border-border bg-surface-1 p-4"
>
    <h2 class="text-title font-semibold text-text-primary">{{ strings.STATS_TITLE }}</h2>

    {# Record + win rate #}
    <div class="flex flex-col gap-1">
        <p class="text-hero-numeral font-semibold leading-tight text-brand">
            {{ record.wins }}{{ strings.STATS_RECORD_WINS }}
            {{ record.losses }}{{ strings.STATS_RECORD_LOSSES }}
            {{ record.draws }}{{ strings.STATS_RECORD_DRAWS }}
        </p>
        <p class="text-caption text-text-muted">
            {% if record.win_rate is none %}
                {{ strings.STATS_WIN_RATE_LABEL }}: {{ strings.STATS_WIN_RATE_NONE }}
            {% else %}
                {{ strings.STATS_WIN_RATE_LABEL }}: {{ "%.0f"|format(record.win_rate * 100) }}%
                <span class="ms-1">
                    ({{ strings.STATS_WIN_RATE_BASIS_PREFIX }} {{ record.decided }}{{ strings.STATS_WIN_RATE_BASIS_UNIT }})
                </span>
            {% endif %}
        </p>
    </div>

    {# Results timeline #}
    <div class="flex flex-col gap-2">
        <h3 class="text-body font-medium text-text-primary">{{ strings.STATS_TIMELINE_TITLE }}</h3>
        {% if not timeline %}
            <p class="text-caption text-text-muted">{{ strings.STATS_TIMELINE_EMPTY }}</p>
        {% else %}
            <ul class="flex flex-wrap gap-2">
                {% for bout in timeline %}
                    <li
                        class="chip"
                        {% if bout.result == "win" %}
                            aria-label="{{ strings.MATCH_RESULT_WIN }}: {{ bout.opponent }} {{ bout.score }}"
                        {% elif bout.result == "loss" %}
                            aria-label="{{ strings.MATCH_RESULT_LOSS }}: {{ bout.opponent }} {{ bout.score }}"
                        {% else %}
                            aria-label="{{ strings.MATCH_RESULT_DRAW }}: {{ bout.opponent }} {{ bout.score }}"
                        {% endif %}
                    >
                        {% if bout.result == "win" %}{{ strings.MATCH_RESULT_WIN }}
                        {% elif bout.result == "loss" %}{{ strings.MATCH_RESULT_LOSS }}
                        {% else %}{{ strings.MATCH_RESULT_DRAW }}
                        {% endif %}
                        <span class="ms-1 text-text-muted">{{ bout.opponent }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {# Head-to-head #}
    <div class="flex flex-col gap-2">
        <h3 class="text-body font-medium text-text-primary">{{ strings.STATS_HEAD_TO_HEAD_TITLE }}</h3>
        {% if not head_to_head %}
            <p class="text-caption text-text-muted">{{ strings.STATS_HEAD_TO_HEAD_EMPTY }}</p>
        {% else %}
            <table class="w-full text-body text-text-primary">
                <caption class="sr-only">{{ strings.STATS_HEAD_TO_HEAD_TITLE }}</caption>
                <thead>
                    <tr class="text-caption text-text-muted">
                        <th scope="col" class="text-start font-medium">{{ strings.MATCH_LIST_OPPONENT_LABEL }}</th>
                        <th scope="col" class="text-end font-medium">{{ strings.STATS_RECORD_WINS }}</th>
                        <th scope="col" class="text-end font-medium">{{ strings.STATS_RECORD_LOSSES }}</th>
                        <th scope="col" class="text-end font-medium">{{ strings.STATS_RECORD_DRAWS }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for opp in head_to_head %}
                        <tr class="border-t border-border">
                            <th scope="row" class="py-1 text-start font-normal">{{ opp.opponent }}</th>
                            <td class="py-1 text-end">{{ opp.wins }}</td>
                            <td class="py-1 text-end">{{ opp.losses }}</td>
                            <td class="py-1 text-end">{{ opp.draws }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</section>
