{#
  Unified history view: a persistent header (month/all period switcher +
  prev/current/next nav) AND the month calendar visual always renders.
  The log area below the visual shows the day-grouped period log.

  This whole div is the HTMX swap target (#activity-section-history-{{ activity_id }}) for
  every period-switch, prev/next interaction — `hx-swap="outerHTML"`.

  Focus-after-swap: the active period tab carries `data-history-focus`.

  Period sync: after every swap, the `data-period` attribute on the
  field-stats div is updated from the active period tab's `data-period`.

  Context: activity_id, history (see app.routes.web._build_history_context).
#}
<div
    id="activity-section-history-{{ activity_id }}"
    class="flex flex-col gap-3"
>
    {# Sentinel: refreshes the whole history section when entries change.
       Lives here (not on the parent div) so its hx-vals don't bleed into
       period/prev/next button requests via HTMX ancestor-merging. #}
    <span
        class="sr-only"
        aria-hidden="true"
        hx-get="/activities/{{ activity_id }}/history"
        hx-vals='{"period": "{{ history.period }}", "anchor": "{{ history.anchor }}"{% if history.selected_day %}, "day": "{{ history.selected_day }}"{% endif %}, "page": {{ history.page }}}'
        hx-trigger="log-saved from:body"
        hx-target="#activity-section-history-{{ activity_id }}"
        hx-swap="outerHTML"
    ></span>
    {# Period switcher #}
    <div role="tablist" aria-label="{{ strings.HISTORY_PERIOD_SWITCHER_LABEL }}" class="flex gap-2">
        {% for period_key, period_label in [
            ("month", strings.HISTORY_PERIOD_MONTH),
            ("all", strings.HISTORY_PERIOD_ALL),
        ] %}
            {% set is_selected = history.period == period_key %}
            <button
                type="button"
                role="tab"
                id="activity-tab-history-{{ activity_id }}-{{ period_key }}"
                aria-selected="{{ "true" if is_selected else "false" }}"
                {% if is_selected %}data-history-focus{% endif %}
                hx-get="/activities/{{ activity_id }}/history?period={{ period_key }}&anchor={{ history.today_anchor }}"
                hx-target="#activity-section-history-{{ activity_id }}"
                hx-swap="outerHTML"
                class="min-h-tap min-w-tap flex-1 rounded-button px-3 text-body transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong
                    {% if is_selected %}
                        border-2 border-border-strong bg-surface-2 font-semibold text-text-primary
                    {% else %}
                        border border-border text-text-secondary hover:bg-surface-2
                    {% endif %}"
            >
                {{ period_label }}
            </button>
        {% endfor %}
    </div>

    {# Prev / current / next nav — hidden for the "all" period #}
    {% if history.period != "all" %}
    <div class="flex items-center justify-between">
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.prev_anchor }}{% if history.selected_day %}&day={{ history.selected_day }}{% endif %}"
            hx-target="#activity-section-history-{{ activity_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            aria-label="{{ strings.CALENDAR_PREV_MONTH }}"
        >
            &lt;
        </button>
        <div class="flex items-center gap-2">
            <h3 class="text-body font-medium text-text-primary" aria-live="polite">
                {{ history.label }}
            </h3>
        </div>
        <button
            type="button"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.next_anchor }}{% if history.selected_day %}&day={{ history.selected_day }}{% endif %}"
            hx-target="#activity-section-history-{{ activity_id }}"
            hx-swap="outerHTML"
            class="min-h-tap min-w-tap rounded-button px-2 text-body text-text-secondary transition hover:bg-surface-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
            aria-label="{{ strings.CALENDAR_NEXT_MONTH }}"
        >
            &gt;
        </button>
    </div>
    {% endif %}

    {# Period visual — branched on period, not rendered for "all". Always
       rendered regardless of day selection; the grid/strip never leaves the
       DOM, only the log area below it (see next block) swaps. #}
    {% if history.period == "month" %}
        <table class="w-full border-collapse">
            <caption class="sr-only">{{ strings.CALENDAR_TITLE }}</caption>
            <thead>
                <tr>
                    {% for wd in history.visual.weekdays %}
                        <th scope="col" class="text-caption font-medium text-text-muted">{{ wd }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for week in history.visual.weeks %}
                    <tr>
                        {% for day in week %}
                            <td class="text-center">
                                {% if history.is_owner %}
                                <button
                                    type="button"
                                    aria-pressed="{{ 'true' if day.selected else 'false' }}"
                                    class="cal-day{% if day.marked %} cal-day--marked{% endif %}{% if day.today %} cal-day--today{% endif %}{% if day.selected %} cal-day--selected{% endif %}{% if not day.current_month %} cal-day--adjacent{% endif %}{% if day.adjacent_group_start %} cal-day--adjacent-start{% endif %}{% if day.adjacent_group_end %} cal-day--adjacent-end{% endif %}"
                                    hx-get="/activities/{{ activity_id }}/history?period=month&anchor={{ history.anchor }}{% if not day.selected %}&day={{ day.date }}{% endif %}"
                                    hx-target="#activity-section-history-{{ activity_id }}"
                                    hx-swap="outerHTML"
                                >
                                    {{ day.day }}
                                </button>
                                {% elif day.marked %}
                                <button
                                    type="button"
                                    aria-pressed="{{ 'true' if day.selected else 'false' }}"
                                    class="cal-day cal-day--marked{% if day.today %} cal-day--today{% endif %}{% if day.selected %} cal-day--selected{% endif %}{% if not day.current_month %} cal-day--adjacent{% endif %}{% if day.adjacent_group_start %} cal-day--adjacent-start{% endif %}{% if day.adjacent_group_end %} cal-day--adjacent-end{% endif %}"
                                    hx-get="/activities/{{ activity_id }}/history?period=month&anchor={{ history.anchor }}{% if not day.selected %}&day={{ day.date }}{% endif %}"
                                    hx-target="#activity-section-history-{{ activity_id }}"
                                    hx-swap="outerHTML"
                                >
                                    {{ day.day }}
                                </button>
                                {% else %}
                                <span class="cal-day cal-day--readonly{% if day.marked %} cal-day--marked{% endif %}{% if day.today %} cal-day--today{% endif %}{% if not day.current_month %} cal-day--adjacent{% endif %}{% if day.adjacent_group_start %} cal-day--adjacent-start{% endif %}{% if day.adjacent_group_end %} cal-day--adjacent-end{% endif %}">
                                    {{ day.day }}
                                </span>
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    {% if top_tags is defined and top_tags is not none %}
        {% include "components/activities/activity_tags.html.jinja2" with context %}
    {% endif %}

    {# Log area #}
    {% if history.selected_day %}
    {% include "components/history/_selected_day.html.jinja2" with context %}
    {% else %}
    {% include "components/history/period_log.html.jinja2" with context %}
    {% endif %}

    {% if not history.selected_day and history.total_pages > 1 %}
    <nav class="flex items-center justify-center gap-1" aria-label="pagination">
        {% if history.page > 1 %}
        <button type="button" class="min-h-tap min-w-[2rem] rounded-button px-2 py-1 text-body text-text-secondary transition hover:bg-surface-2"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.anchor }}{% if history.selected_day %}&day={{ history.selected_day }}{% endif %}&page={{ history.page - 1 }}"
            hx-target="#activity-section-history-{{ activity_id }}" hx-swap="outerHTML"
        >
            &laquo;
        </button>
        {% endif %}
        {% for p in history.page_range %}
            {% if p is none %}
            <span class="px-1 text-caption text-text-muted">&hellip;</span>
            {% else %}
            <button type="button" class="min-h-tap min-w-[2rem] rounded-button px-2 py-1 text-body transition
                {% if p == history.page %}
                    border-2 border-border-strong bg-surface-2 font-semibold text-text-primary
                {% else %}
                    text-text-secondary hover:bg-surface-2
                {% endif %}"
                hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.anchor }}{% if history.selected_day %}&day={{ history.selected_day }}{% endif %}&page={{ p }}"
                hx-target="#activity-section-history-{{ activity_id }}" hx-swap="outerHTML"
            >
                {{ p }}
            </button>
            {% endif %}
        {% endfor %}
        {% if history.page < history.total_pages %}
        <button type="button" class="min-h-tap min-w-[2rem] rounded-button px-2 py-1 text-body text-text-secondary transition hover:bg-surface-2"
            hx-get="/activities/{{ activity_id }}/history?period={{ history.period }}&anchor={{ history.anchor }}{% if history.selected_day %}&day={{ history.selected_day }}{% endif %}&page={{ history.page + 1 }}"
            hx-target="#activity-section-history-{{ activity_id }}" hx-swap="outerHTML"
        >
            &raquo;
        </button>
        {% endif %}
    </nav>
    {% endif %}
</div>
