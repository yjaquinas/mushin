{# Shared summary card: title (optional), all-time count, current-year heatmap,
   and top tags. #}
<section
    id="stats-summary-{{ activity_id }}"
    class="flex flex-col gap-4 rounded-card border border-border bg-surface-1 p-4"
    {% if is_owner | default(false) %}
    hx-get="/activities/{{ activity_id }}/stats-summary"
    hx-trigger="log-saved from:body"
    hx-swap="outerHTML"
    {% endif %}
>
    {% if card_name is defined and card_name %}
    {% if title_editable | default(false) %}
    <div id="rename-heading" class="flex items-center">
        <div class="flex-1"></div>
        <h1 class="text-title font-semibold text-text-primary">{{ card_name }}</h1>
        <div class="flex flex-1 justify-end">
            <button
                type="button"
                aria-label="{{ strings.RENAME_LABEL }}"
                hx-get="/activities/{{ activity_id }}/rename-form"
                hx-target="#rename-activity-dialog"
                hx-swap="outerHTML"
                class="min-h-tap min-w-tap flex items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ icon('pencil', size=20) }}</button>
        </div>
    </div>
    {% else %}
    <h2 class="flex flex-wrap items-baseline justify-center gap-1.5 text-center text-text-primary">
        <span class="text-title font-semibold">{{ card_name }}</span>
    </h2>
    {% endif %}
    <div class="-mx-4 border-t border-border"></div>
    {% endif %}

    <div class="flex flex-row gap-3">
        <dl class="flex-1 rounded-card bg-surface-0 px-3 py-2">
            <div class="flex items-center justify-between gap-3">
                <dt class="text-caption text-text-muted">{{ strings.STATS_AVERAGE_WEEKLY_LABEL }}</dt>
                <dd class="text-title font-medium text-text-primary">{{ average_weekly_count | default(0) | format_average_weekly_count }}</dd>
            </div>
        </dl>
        <dl class="flex-1 rounded-card bg-surface-0 px-3 py-2">
            <div class="flex items-center justify-between gap-3">
                <dt class="text-caption text-text-muted">{{ strings.STATS_PERIOD_LIFETIME }}</dt>
                <dd class="text-title font-medium text-text-primary">{{ counts.lifetime | format_count }}</dd>
            </div>
        </dl>
    </div>
    <div class="flex flex-col gap-4">
        {% if heatmap is defined %}
        {% set active_weeks = heatmap | selectattr('intensity', 'gt', 0) | list | length %}
        <div class="flex flex-col gap-1">
            <div class="flex gap-px" aria-hidden="true">
                {% for week in heatmap %}
                <span class="min-w-0 flex-1 whitespace-nowrap text-caption text-text-muted">
                    {% if week.quarter_month %}{{ strings.HEATMAP_QUARTER_LABELS[week.quarter_month] }}{% endif %}
                </span>
                {% endfor %}
            </div>
            <div
                role="img"
                aria-label="{{ strings.HEATMAP_ARIA.format(active_weeks=active_weeks) }}"
                class="flex h-12 items-end gap-px"
            >
                {% for week in heatmap %}
                    {% if week.intensity > 0 %}
                        {% set height_pct = (week.intensity / 7 * 100) | round(1) %}
                        <div
                            aria-hidden="true"
                            class="min-w-0 flex-1 bg-heatmap-bar"
                            style="height: {{ height_pct }}%"
                        ></div>
                    {% else %}
                        <div
                            aria-hidden="true"
                            class="min-w-0 flex-1 bg-heatmap-baseline"
                            style="height: 2px"
                        ></div>
                    {% endif %}
                {% endfor %}
            </div>
            {% if active_weeks == 0 %}
            <p class="text-caption text-text-muted">{{ strings.HEATMAP_EMPTY }}</p>
            {% endif %}
        </div>
        {% endif %}

        {% include "components/activities/_top_tags_content.html.jinja2" with context %}
    </div>
</section>
