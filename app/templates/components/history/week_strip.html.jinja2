{#
  Single-week strip of `.cal-day`-styled cells. Tapping a cell selects that
  day and swaps in its entries inline (below the always-visible strip), the
  same affordance as month view's day cells (components/history/history.html.jinja2's
  month branch) -- same hx-get/hx-target/hx-swap shape, parameterized for
  period=week. Tapping an already-selected cell omits `&day=...` from its
  own hx-get, clearing the selection (same effect as the
  HISTORY_CLEAR_SELECTION control).

  Context: activity_id, history (history.anchor, history.visual.days:
  [{"date","day","marked","today","selected"}, x7]).
#}
<div class="grid grid-cols-7 gap-1">
{% for cell in history.visual.days %}
        <div class="flex flex-col items-center gap-1">
            <span class="text-caption font-medium text-text-muted">
                {{ strings.CALENDAR_WEEKDAYS[loop.index0] }}
            </span>
            {% if cell.marked %}
            <button
                type="button"
                aria-pressed="{{ 'true' if cell.selected else 'false' }}"
                class="cal-day cal-day--marked{% if cell.today %} cal-day--today{% endif %}{% if cell.selected %} cal-day--selected{% endif %}"
                {% if cell.selected %}
                hx-get="/activities/{{ activity_id }}/history?period=week&anchor={{ history.anchor }}"
                {% else %}
                hx-get="/activities/{{ activity_id }}/history?period=week&anchor={{ history.anchor }}&day={{ cell.date }}"
                {% endif %}
                hx-target="#activity-section-history-{{ activity_id }}"
                hx-swap="outerHTML"
            >
                {{ cell.day }}
            </button>
            {% else %}
            <span class="cal-day cal-day--empty{% if cell.today %} cal-day--today{% endif %}">
                {{ cell.day }}
            </span>
            {% endif %}
        </div>
    {% endfor %}
</div>
