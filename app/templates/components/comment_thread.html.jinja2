{#
  Comment thread fragment for a single entry — swapped in place below the
  entry row by the collapsed comment-count affordance's hx-get, and re-swapped
  after a post/delete.

  Density is intentionally low (per copy-patterns): a flat list, no replies,
  no reactions. The composer is rendered ONLY when `can_comment` is true for
  the current viewer — never CSS-hidden, never present-but-disabled. A
  logged-out viewer (on an otherwise-visible public entry) sees the list
  read-only plus a plain inline "Log in to comment" link. A viewer who fails
  `can_view_activity_detail` entirely never reaches this template at all (the
  route 404s/redirects before rendering).

  Context:
    activity_id    int
    entry_id       int
    username       str   — profile owner's username (for the route URLs)
    comments       list[dict] — see app.services.comments.list_comments
                     (id, author_id, author_username, author_display_name,
                      body, created_at), oldest first
    can_comment    bool  — true iff profiles.can_comment_on_entry for this viewer
    viewer_logged_in bool
    current_user_id  int | None — for the per-comment delete affordance
    entry_owner_id    int       — for the per-comment delete affordance
#}
<div id="comment-thread-{{ entry_id }}" class="flex flex-col gap-3 pt-2">
    {% if not comments %}
    <p class="text-caption text-text-muted">{{ strings.COMMENTS_EMPTY }}</p>
    {% else %}
        <ul class="flex flex-col gap-2">
        {% for comment in comments %}
        {% set author_name = comment.author_display_name or comment.author_username %}
        {% set is_entry_owner_comment = comment.author_id == entry_owner_id %}
        {% set is_current_user_comment = current_user_id is not none and comment.author_id == current_user_id %}
        <li class="flex flex-col gap-0.5">
            <div class="flex items-baseline justify-between gap-2">
                <span class="flex min-w-0 items-center gap-2 text-caption font-medium">
                    {% if is_entry_owner_comment %}
                    <span class="min-w-0 truncate text-[var(--color-obsidian)]">
                        {{ author_name }}
                    </span>
                    <span class="rounded-full bg-surface-2 px-1 py-px text-[10px] leading-none text-[var(--color-obsidian)]">
                        {{ strings.COMMENTS_AUTHOR_OWNER }}
                    </span>
                    {% elif is_current_user_comment %}
                    <span class="min-w-0 truncate text-accent-text">
                        {{ author_name }}
                    </span>
                    <span class="rounded-full bg-accent-subtle px-1 py-px text-[10px] leading-none text-accent-text">
                        {{ strings.COMMENTS_AUTHOR_YOU }}
                    </span>
                    {% elif comment.author_username %}
                    <a
                        href="/@{{ comment.author_username }}"
                        class="min-w-0 truncate text-text-secondary underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                    >{{ author_name }}</a>
                    {% else %}
                    <span class="min-w-0 truncate text-text-secondary">
                        {{ author_name }}
                    </span>
                    {% endif %}
                </span>
                <span class="text-caption text-text-muted" data-local-timestamp="{{ comment.created_at }}">{{ comment.created_at | format_comment_timestamp }}</span>
            </div>
            <div class="flex items-start justify-between gap-2">
                {% if comment.hidden_at %}
                <p class="min-w-0 flex-1 text-body text-text-muted italic">{{ strings.COMMENTS_HIDDEN_BY_MODERATOR }}</p>
                {% else %}
                <p class="min-w-0 flex-1 whitespace-pre-wrap break-all text-body text-text-primary">{{ comment.body }}</p>
                {% endif %}
                {% if current_user_id is not none and (current_user_id == comment.author_id or current_user_id == entry_owner_id) %}
                <button
                    type="button"
                    aria-label="{{ strings.COMMENTS_DELETE }}"
                    hx-get="/@{{ username }}/{{ slug }}/entries/{{ entry_id }}/comments/{{ comment.id }}/delete-confirm"
                    hx-target="#comment-delete-dialog-{{ comment.id }}"
                    hx-swap="outerHTML"
                    class="min-h-tap min-w-tap flex shrink-0 items-center justify-center rounded text-text-muted transition hover:text-danger focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                >{{ icon('trash', size=18) }}<span class="sr-only">{{ strings.COMMENTS_DELETE }}</span></button>
                {% endif %}
            </div>
            <div id="comment-delete-dialog-{{ comment.id }}"></div>
        </li>
        {% endfor %}
    </ul>
    {% endif %}

    {% if can_comment %}
    <form
        hx-post="/@{{ username }}/{{ slug }}/entries/{{ entry_id }}/comments"
        hx-target="#comment-thread-{{ entry_id }}"
        hx-swap="outerHTML"
        class="flex items-end gap-2"
        data-comment-form
    >
        <label for="comment-body-{{ entry_id }}" class="sr-only">{{ strings.COMMENTS_BODY_LABEL }}</label>
        <textarea
            id="comment-body-{{ entry_id }}"
            name="body"
            rows="2"
            required
            placeholder="{{ strings.COMMENTS_BODY_PLACEHOLDER }}"
            data-comment-max-lines="5"
            data-comment-max-chars="200"
            data-comment-max-lines-message="{{ strings.COMMENTS_BODY_MAX_LINES_REACHED }}"
            data-comment-max-chars-message="{{ strings.COMMENTS_BODY_MAX_CHARS_REACHED }}"
            class="min-h-tap flex-1 resize-none overflow-hidden rounded-card border border-border bg-surface-1 p-2 text-body text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        ></textarea>
        <div class="flex shrink-0 flex-col items-end gap-1">
            <span
                class="text-caption text-text-muted"
                data-comment-char-count
            >0/200</span>
            <button
                type="submit"
                class="min-h-tap shrink-0 rounded-button bg-brand px-4 text-body font-semibold text-on-brand transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
            >{{ strings.COMMENTS_SUBMIT }}</button>
        </div>
    </form>
    {% elif not viewer_logged_in %}
    <a
        href="/"
        class="text-caption text-text-muted underline-offset-2 hover:underline focus-visible:outline-offset-2"
    >{{ strings.COMMENTS_LOGIN_TO_COMMENT }}</a>
    {% endif %}
</div>
