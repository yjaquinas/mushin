{#
  Prefix-routed search results.
  Context: query, kind, people, tags, activities.
#}
{% if not query %}
<p class="py-2 text-center text-caption text-text-secondary">{{ strings.SEARCH_PROMPT }}</p>
{% else %}
<div class="flex flex-col gap-6">
    {% if kind in ("people", "all") and people %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_PEOPLE_HEADING }}</h2>
        <ul class="flex flex-col gap-2">
            {% for person in people %}
            <li hx-get="/social/@{{ person.username }}"
                hx-push-url="true"
                hx-target="#tab-panel-social"
                hx-select="#tab-panel-social"
                hx-swap="outerHTML"
                hx-select-oob="#masthead-area"
                class="flex min-h-tap items-center justify-between gap-3 rounded-card px-3 py-2 transition hover:bg-surface-2 cursor-pointer"
                tabindex="0" role="link">
                <span class="min-w-0 truncate font-medium text-text-primary">@{{ person.username }}</span>
                <span class="shrink-0" onclick="event.stopPropagation()">
                    {% with
                        username=person.username,
                        state=person.relationship_state,
                        error=None,
                        dom_id="relationship-affordance-" ~ person.username,
                        pending_incoming_target_id="relationship-affordance-" ~ person.username,
                        from_search=true
                    %}
                    {% include "components/fellows/relationship_affordance.html.jinja2" %}
                    {% endwith %}
                </span>
            </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if kind in ("tags", "all") and tags %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_TAGS_HEADING }}</h2>
        <ul class="flex flex-col gap-2">
            {% for entry in tags %}
            <li hx-get="/social{{ entry.activity_url }}{% if entry.detail_visible %}?entry_id={{ entry.entry_id }}{% endif %}"
                hx-push-url="true"
                hx-target="#tab-panel-social"
                hx-select="#tab-panel-social"
                hx-swap="outerHTML"
                hx-select-oob="#masthead-area"
                class="flex min-h-tap items-center gap-3 rounded-card px-3 py-2 transition hover:bg-surface-2 cursor-pointer"
                tabindex="0" role="link">
                <span class="line-clamp-2 text-body text-text-primary">{{ entry.memo }}</span>
            </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if kind in ("activities", "all") and activities %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_ACTIVITIES_HEADING }}</h2>
        <ul class="flex flex-col gap-2">
            {% for activity in activities %}
            <li hx-get="/social{{ activity.url }}"
                hx-push-url="true"
                hx-target="#tab-panel-social"
                hx-select="#tab-panel-social"
                hx-swap="outerHTML"
                hx-select-oob="#masthead-area"
                class="flex min-h-tap items-center gap-3 rounded-card px-3 py-2 transition hover:bg-surface-2 cursor-pointer"
                tabindex="0" role="link">
                <span class="flex min-w-0 flex-col">
                    <span class="truncate font-medium text-text-primary">{{ activity.name }}</span>
                    <span class="text-caption text-text-secondary">@{{ activity.username }}</span>
                </span>
            </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if kind == "people" and not people %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_PEOPLE_HEADING }}</h2>
        <p class="text-caption text-text-secondary">{{ strings.SEARCH_PEOPLE_EMPTY }}</p>
    </section>
    {% elif kind == "tags" and not tags %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_TAGS_HEADING }}</h2>
        <p class="text-caption text-text-secondary">{{ strings.SEARCH_TAGS_EMPTY }}</p>
    </section>
    {% elif kind == "activities" and not activities %}
    <section class="flex flex-col gap-2">
        <h2 class="text-body font-medium text-text-secondary">{{ strings.SEARCH_ACTIVITIES_HEADING }}</h2>
        <p class="text-caption text-text-secondary">{{ strings.SEARCH_ACTIVITIES_EMPTY }}</p>
    </section>
    {% elif kind == "all" and not people and not tags and not activities %}
    <p class="text-caption text-text-secondary">{{ strings.SEARCH_ALL_EMPTY }}</p>
    {% endif %}
</div>
{% endif %}
