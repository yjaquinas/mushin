<a href="/admin/users" class="text-sm text-text-secondary underline-offset-2 hover:underline">{{ strings.ADMIN_BACK_TO_USERS }}</a>
<section class="rounded-card border border-border bg-surface-1 p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h2 class="mt-2 text-lg font-semibold">
                {% if detail_user.username %}@{{ detail_user.username }}{% else %}#{{ detail_user.id }}{% endif %}
            </h2>
            <p class="mt-1 text-sm text-text-secondary">
                {{ strings.ADMIN_COLUMN_CREATED }} {{ detail_user.created_at }}
            </p>
            {% if detail_user.email %}
            <p class="mt-1 text-sm text-text-secondary">
                {{ strings.ADMIN_FIELD_EMAIL }}: {{ detail_user.email }}
            </p>
            {% endif %}
            {% if detail_user.deleted_at %}
            <p class="mt-2 text-sm font-medium text-text-secondary">{{ strings.ADMIN_STATUS_DELETED }}: {{ detail_user.deleted_at }}</p>
            {% elif detail_user.suspended_at %}
            <p class="mt-2 text-sm font-medium text-danger">{{ strings.ADMIN_STATUS_SUSPENDED }}: {{ detail_user.suspended_at }}</p>
            {% endif %}
        </div>
        {% if detail_user.username and not detail_user.deleted_at %}
        <a href="/@{{ detail_user.username }}" class="rounded-button border border-border px-3 py-2 text-sm text-text-secondary">{{ strings.ADMIN_PUBLIC_PROFILE }}</a>
        {% endif %}
    </div>
</section>

<section class="grid gap-4 lg:grid-cols-2">
    <form method="post" action="/admin/users/{{ detail_user.id }}/edit" class="rounded-card border border-border bg-surface-1 p-4">
        <h3 class="font-semibold">{{ strings.ADMIN_EDIT_USER_HEADING }}</h3>
        <label class="mt-3 block text-sm text-text-secondary">
            {{ strings.ADMIN_FIELD_USERNAME }}
            <input name="username" value="{{ detail_user.username or '' }}" required class="mt-1 w-full rounded border border-border bg-surface-0 px-3 py-2 text-text-primary">
        </label>
        <label class="mt-3 block text-sm text-text-secondary">
            {{ strings.ADMIN_FIELD_EMAIL }}
            <input name="email" value="{{ detail_user.email or '' }}" class="mt-1 w-full rounded border border-border bg-surface-0 px-3 py-2 text-text-primary">
        </label>
        <label class="mt-3 block text-sm text-text-secondary">
            {{ strings.ADMIN_FIELD_PASSWORD }}
            <input name="password" type="password" class="mt-1 w-full rounded border border-border bg-surface-0 px-3 py-2 text-text-primary">
        </label>
        <button class="mt-4 rounded-button bg-brand px-4 py-2 text-sm font-medium text-on-brand">{{ strings.ADMIN_SAVE_USER }}</button>
    </form>

    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h3 class="font-semibold">{{ strings.ADMIN_MANAGEMENT_HEADING }}</h3>
        <p class="mt-2 text-sm text-text-secondary">{{ strings.ADMIN_MANAGEMENT_ACTIVE_NOTE }}</p>
        <form method="post" action="/admin/users/{{ detail_user.id }}/suspension" class="mt-4">
            {% if detail_user.deleted_at %}
            <p class="text-sm text-text-secondary">{{ strings.ADMIN_DELETED_ACCOUNT_NOTE }}</p>
            {% elif detail_user.suspended_at %}
            <input type="hidden" name="suspended" value="false">
            <button class="w-full rounded-button border border-border px-4 py-2 text-sm text-text-secondary">{{ strings.ADMIN_UNSUSPEND_USER }}</button>
            {% else %}
            <input type="hidden" name="suspended" value="true">
            <button class="w-full rounded-button border border-accent px-4 py-2 text-sm font-medium text-accent-text">{{ strings.ADMIN_SUSPEND_USER }}</button>
            {% endif %}
        </form>
        {% if not detail_user.deleted_at %}
        <button
            id="delete-user-dialog-trigger"
            type="button"
            class="mt-4 w-full rounded-button bg-danger px-4 py-2 text-sm font-medium text-on-brand"
        >
            {{ strings.ADMIN_DELETE_USER_HEADING }}
        </button>
        {% endif %}
        <form method="post" action="/admin/users/{{ detail_user.id }}/visibility" class="mt-4 border-t border-border pt-4">
            <h4 class="text-sm font-semibold text-text-primary">{{ strings.ADMIN_VISIBILITY_HEADING }}</h4>
            <p class="mt-1 text-xs text-text-secondary">{{ strings.ADMIN_VISIBILITY_CURRENT.format(visibility=detail_user.visibility) }}</p>
            <select name="visibility" class="mt-2 w-full rounded border border-border bg-surface-0 px-3 py-2 text-sm text-text-primary">
                <option value="public" {{ "selected" if detail_user.visibility == "public" else "" }}>{{ strings.ADMIN_VISIBILITY_PUBLIC }}</option>
                <option value="private" {{ "selected" if detail_user.visibility == "private" else "" }}>{{ strings.ADMIN_VISIBILITY_PRIVATE }}</option>
            </select>
            <button class="mt-2 w-full rounded-button bg-brand px-4 py-2 text-sm font-medium text-on-brand">{{ strings.ADMIN_SET_VISIBILITY }}</button>
        </form>
    </div>
</section>

{# Delete user confirmation dialog #}
<div
    id="delete-user-dialog"
    hidden
    class="fixed inset-0 z-50 flex items-end justify-center bg-text-primary/50 sm:items-center"
    role="presentation"
>
    <div
        role="dialog"
        aria-modal="true"
        aria-labelledby="delete-user-title"
        class="flex w-full max-w-md flex-col gap-4 rounded-card border border-border bg-surface-1 p-4 sm:rounded-card"
    >
        <h2 id="delete-user-title" class="text-body font-semibold text-text-primary">
            {{ strings.ADMIN_DELETE_USER_HEADING }}
        </h2>
        <p class="text-caption text-text-secondary">{{ strings.ADMIN_DELETE_USER_BODY }}</p>
        <form method="post" action="/admin/users/{{ detail_user.id }}/delete" class="flex flex-col gap-3">
            <button
                type="submit"
                class="min-h-tap w-full rounded-button bg-danger px-4 py-3 text-body font-semibold text-on-danger transition hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 disabled:opacity-60"
            >
                {{ strings.ADMIN_DELETE_USER_CONFIRM }}
            </button>
            <button
                type="button"
                id="delete-user-cancel"
                class="min-h-tap w-full rounded-button border border-border bg-surface-1 px-4 py-3 text-body font-medium text-text-primary transition hover:bg-surface-2 focus-visible:outline-offset-2"
            >
                {{ strings.ADMIN_DELETE_USER_CANCEL }}
            </button>
        </form>
    </div>
</div>

{% include "components/admin/_admin_user_detail_content.html.jinja2" with context %}
