<section class="rounded-card border border-border bg-surface-1 p-4">
    <h2 class="text-lg font-semibold">{{ strings.ADMIN_USERS_HEADING }}</h2>
    <p class="mt-1 text-sm text-text-secondary">{{ strings.ADMIN_USERS_NOTE }}</p>
    <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[480px] text-left text-sm">
            <thead class="text-text-secondary">
                <tr>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_USERNAME }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_EMAIL }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_COLUMN_ACCOUNT_STATUS }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                {% for user in users %}
                <tr>
                    <td class="py-2 pr-3">
                        <a class="font-medium underline-offset-2 hover:underline" href="/admin/users/{{ user.id }}">
                            {% if user.username %}@{{ user.username }}{% else %}#{{ user.id }}{% endif %}
                        </a>
                        <span class="ms-1 text-text-muted">#{{ user.id }}</span>
                    </td>
                    <td class="py-2 pr-3 text-text-secondary">
                        {{ user.email or strings.ADMIN_EMPTY_FIELD }}
                    </td>
                    <td class="py-2 pr-3">
                        {% if user.deleted_at %}
                        <span class="rounded-full bg-surface-2 px-2 py-0.5 text-caption text-text-secondary">{{ strings.ADMIN_STATUS_DELETED }}</span>
                        {% elif user.suspended_at %}
                        <span class="rounded-full bg-danger-subtle px-2 py-0.5 text-caption text-danger">{{ strings.ADMIN_STATUS_SUSPENDED }}</span>
                        {% else %}
                        <span class="rounded-full bg-accent-subtle px-2 py-0.5 text-caption text-accent-text">{{ strings.ADMIN_STATUS_ACTIVE }}</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <p class="mt-4 text-sm text-text-secondary">{{ strings.ADMIN_DELETED_USERS_NOTE }}</p>
</section>

<section class="rounded-card border border-border bg-surface-1 p-4">
    <h2 class="font-semibold">{{ strings.ADMIN_USER_TRACKING_HEADING }}</h2>
    <ul class="mt-3 grid gap-2 text-sm text-text-secondary sm:grid-cols-2">
        <li>{{ strings.ADMIN_USER_TRACKING_STATUS }}</li>
        <li>{{ strings.ADMIN_USER_TRACKING_VISIT_COUNT }}</li>
        <li>{{ strings.ADMIN_USER_TRACKING_CONTENT }}</li>
        <li>{{ strings.ADMIN_USER_TRACKING_MODERATION }}</li>
    </ul>
</section>
