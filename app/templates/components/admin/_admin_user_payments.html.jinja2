<section class="rounded-card border border-border bg-surface-1 p-4">
    <h3 class="font-semibold">{{ strings.ADMIN_PAYMENTS_HEADING }}</h3>
    {% if payments %}
    <div class="mt-3 overflow-x-auto">
        <table class="w-full min-w-[480px] text-left text-sm">
            <thead class="text-text-secondary">
                <tr>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_DATE }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_PLAN }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_AMOUNT }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_STATUS }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_METHOD }}</th>
                    <th class="py-2 pr-3 font-medium">{{ strings.ADMIN_PAYMENTS_COLUMN_PERIOD }}</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                {% for p in payments %}
                <tr>
                    <td class="py-2 pr-3 text-text-secondary">{{ p.created_at }}</td>
                    <td class="py-2 pr-3 font-medium text-text-primary">{{ p.plan }}</td>
                    <td class="py-2 pr-3 text-text-primary">${{ "{:.2f}".format(p.amount_cents / 100) }}</td>
                    <td class="py-2 pr-3 text-text-secondary">{{ p.status }}</td>
                    <td class="py-2 pr-3 text-text-secondary">
                        {% if p.payment_method == 'promotion' %}
                            Promotion
                        {% else %}
                            {{ p.payment_method or strings.ADMIN_EMPTY_FIELD }}
                        {% endif %}
                    </td>
                    <td class="py-2 pr-3 text-text-secondary">
                        {% if p.period_start and p.period_end %}
                        {{ p.period_start[:10] }} – {{ p.period_end[:10] }}
                        {% else %}
                        {{ strings.ADMIN_EMPTY_FIELD }}
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="mt-3 text-sm text-text-secondary">{{ strings.ADMIN_PAYMENTS_EMPTY }}</p>
    {% endif %}
</section>
