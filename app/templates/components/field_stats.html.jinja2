{#
  Tag-frequency and scale-distribution sections, rendered for whichever
  fields exist on the sub-tally's recipe (see app.routes.web._build_field_stats_context).

  Context: field_stats ({"tag_groups": [...], "scales": [...], "period": str, "period_label": str}),
           activity_id (int), is_owner (bool, default false).

  When is_owner, the outer div uses HTMX to refresh after a log or period change.
  Period sync (data-period) and request injection are handled by field-stats.js.
#}
{% if is_owner | default(false) %}
<div
    id="field-stats-{{ activity_id }}"
    data-period="{{ field_stats.period | default('month') }}"
    hx-get="/activities/{{ activity_id }}/field-stats"
    hx-vals='js: { period: this.dataset.period }'
    hx-trigger="log-saved from:body, needs-period-refresh"
    hx-swap="outerHTML"
>
{% else %}
<div>
{% endif %}
{% if field_stats.tag_groups %}
<section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
    {% for group in field_stats.tag_groups %}
        <div class="flex flex-col gap-2">
            <h3 class="text-body font-medium text-text-primary">{{ group.label }}</h3>
            {% if not group.tags %}
                <p class="text-caption text-text-muted">{{ strings.TAG_FREQUENCY_EMPTY }}</p>
            {% else %}
                <ul class="flex flex-wrap gap-2">
                    {% for tag in group.tags %}
                        <li class="chip">
                            {{ tag.name }}
                            <span class="ms-1 text-text-muted">{{ tag.total }}</span>
                            {% if tag.this_period %}
                                <span class="ms-1 text-caption text-text-muted">
                                    ({{ field_stats.period_label }} {{ tag.this_period }})
                                </span>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    {% endfor %}
</section>
{% endif %}

{% if field_stats.scales %}
<section class="flex flex-col gap-3 rounded-card border border-border bg-surface-1 p-4">
    {% for scale in field_stats.scales %}
        <div class="flex flex-col gap-2">
            <h3 class="text-body font-medium text-text-primary">{{ scale.label }}</h3>
            {% if not scale.distribution %}
                <p class="text-caption text-text-muted">{{ strings.SCALE_DISTRIBUTION_EMPTY }}</p>
            {% else %}
                <ul class="flex flex-wrap gap-2">
                    {% for bucket in scale.distribution %}
                        <li class="chip">
                            {{ bucket.value }}
                            <span class="ms-1 text-text-muted">{{ bucket.count }}</span>
                        </li>
                    {% endfor %}
                </ul>
                <p class="text-caption text-text-muted">
                    {{ strings.SCALE_DISTRIBUTION_AVERAGE_LABEL }} {{ scale.average }}
                </p>
            {% endif %}
        </div>
    {% endfor %}
</section>
{% endif %}
</div>
