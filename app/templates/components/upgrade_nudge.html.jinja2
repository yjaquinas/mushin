{#
  Guest upgrade nudge — fires only at the first progression level-up, for
  guest sessions only (see app.routes.web.create_log). Gift-framed,
  dismissible, never blocks logging.

  Context: nudge_level_id (passed back to /nudge/dismiss on "나중에").
#}
<div
    x-data="{ dismissed: false }"
    x-show="!dismissed"
    class="flex flex-col gap-3 rounded-card border border-border bg-accent-subtle p-4"
    role="status"
>
    <p class="text-body text-text-primary">{{ strings.UPGRADE_NUDGE_TITLE }}</p>
    <div class="flex gap-2">
        <a
            href="/auth/email"
            class="min-h-tap flex flex-1 items-center justify-center rounded-button bg-brand px-4 text-body font-semibold text-surface-1 transition focus-visible:outline-offset-2"
        >
            {{ strings.UPGRADE_NUDGE_CONNECT }}
        </a>
        <button
            type="button"
            hx-post="/nudge/dismiss"
            hx-vals='{"level_id": {{ nudge_level_id }}}'
            hx-swap="none"
            @click="dismissed = true"
            class="min-h-tap flex-1 rounded-button border border-border bg-surface-1 px-4 text-body font-medium text-text-secondary transition hover:bg-surface-2"
        >
            {{ strings.UPGRADE_NUDGE_LATER }}
        </button>
    </div>
</div>
