{#
  Theme toggle — single icon-button toggling light <-> dark.
  Icon and aria-label reflect the *destination* state (the theme tapping
  switches to); tapping posts to /preferences/theme, which sets the
  mushin_theme cookie and returns this same fragment re-rendered for the
  new state.

  Context: theme ("light" | "dark").
#}
{% from "components/_icon.html.jinja2" import icon %}
{% if theme == "light" %}
  {% set theme_icon = "sun" %}
  {% set theme_label = strings.THEME_TOGGLE_LABEL_LIGHT %}
{% else %}
  {% set theme_icon = "moon" %}
  {% set theme_label = strings.THEME_TOGGLE_LABEL_DARK %}
{% endif %}
<button
    type="button"
    id="theme-toggle"
    hx-post="/preferences/theme"
    hx-swap="outerHTML"
    hx-on::after-swap="document.documentElement.dataset.theme=document.getElementById('theme-toggle').dataset.theme"
    aria-label="{{ theme_label }}"
    data-theme="{{ theme }}"
    class="flex min-h-tap min-w-tap items-center justify-center rounded-button text-text-secondary transition hover:bg-surface-2 focus-visible:outline-offset-2"
>
    {{ icon(theme_icon, size=24) }}
</button>
