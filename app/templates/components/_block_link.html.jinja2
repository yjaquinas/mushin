{#
  Quiet, unobtrusive Block affordance — included by relationship_affordance
  in the "none" / "pending_outgoing" / "pending_incoming" states (a fellow
  uses Remove instead; a blocked viewer sees Unblock instead — see the
  parent template's branching).

  Context: `username` (the profile being viewed). Optional `dom_id` (default
  "relationship-affordance") lets a caller with multiple instances on one
  page (search results) give each row a unique id — see
  relationship_affordance.html.jinja2 for why this matters. Optional
  `from_search` (bool, default false) keeps `?source=search` on the
  block-confirm URL so the route handler keeps targeting this row.
#}
{% set dom_id = dom_id | default("relationship-affordance") %}
{% set from_search = from_search | default(false) %}
<button
    type="button"
    hx-get="/fellows/{{ username }}/block-confirm{{ '?source=search' if from_search else '' }}"
    hx-target="#{{ dom_id }}"
    hx-swap="outerHTML"
    class="min-h-tap rounded-button text-caption text-text-muted underline-offset-2 transition hover:underline focus-visible:outline-offset-2"
>{{ strings.CONNECT_BLOCK }}</button>
