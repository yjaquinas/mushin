{#
  Quick-add / log sheet — a free-text notes field with inline #hashtags for
  tag_group fields, plus scale, count, memo, and an editable-defaulting
  occurred_at.

  On submit, POSTs to /activities/{id}/log with hx-swap="none" -- the
  detail screen's stats-summary/history/field-stats sections refresh
  themselves off the "log-saved" HX-Trigger the response fires, so there's
  no primary swap target.

  Dialog behavior (init focus, Escape key, overlay click, cancel button)
  is handled by log-sheet.js. The time checkbox toggle uses hx-on::change
  inline (shared with entry_edit_form).

  Context: activity_id, name, fields (field-priority order), today (default
  occurred_at value, KST date YYYY-MM-DD), inline (bool — when True, renders
  without the dialog wrapper for inline expansion in activity detail).
#}
{% set tag_group_fields = fields | selectattr("kind", "equalto", "tag_group") | list %}
{% set has_tag_group = tag_group_fields | length > 0 %}

{% if inline %}
<div id="log-sheet-inline" data-inline="true" class="flex flex-col gap-4 rounded-card border border-border bg-surface-1 p-4">
    <div class="flex items-center justify-between">
        <h2 class="text-title font-semibold text-text-primary">{{ name }}</h2>
        <button
            type="button"
            id="log-sheet-inline-cancel"
            hx-on:click="var c=document.getElementById('log-sheet-inline');if(c){c.setAttribute('hidden','');var i=document.getElementById('log-trigger-icon-{{ activity_id }}');if(i)i.classList.remove('rotate-45');}"
            class="min-h-tap min-w-tap rounded-button px-3 text-body text-text-secondary transition hover:bg-surface-2"
        >
            {{ strings.LOG_CANCEL }}
        </button>
    </div>

    <form
        hx-post="/activities/{{ activity_id }}/log"
        hx-swap="none"
        hx-on:log-saved="this.reset();var p=document.getElementById('log-panel');if(p){p.setAttribute('hidden','');p.innerHTML='';}var b=document.getElementById('log-trigger-{{ activity_id }}');if(b)b.setAttribute('aria-expanded','false');"
        class="flex flex-col gap-4"
    >
        {% include "components/_log_form_body.html.jinja2" with context %}
    </form>
</div>
{% else %}
<div
    id="log-sheet-dialog"
    hidden
    class="flex max-h-[90vh] w-full max-w-screen-sm flex-col gap-4 overflow-y-auto rounded-t-card bg-surface-1 p-4 sm:rounded-card"
>
    <header class="flex items-center justify-between">
        <h2 class="text-title font-semibold text-text-primary">{{ name }}</h2>
        <button
            type="button"
            id="log-sheet-cancel"
            hx-on:click="var f=document.getElementById('log-sheet-dialog').querySelector('form');if(f){f.querySelectorAll('input[type=number],input[type=date],input[type=time],textarea').forEach(function(i){i.value=''});f.querySelectorAll('input[type=checkbox]').forEach(function(c){c.checked=false});}document.getElementById('log-sheet-dialog').setAttribute('hidden','')"
            class="min-h-tap min-w-tap rounded-button px-3 text-body text-text-secondary transition hover:bg-surface-2"
        >
            {{ strings.LOG_CANCEL }}
        </button>
    </header>

    <form
        hx-post="/activities/{{ activity_id }}/log"
        hx-swap="none"
        hx-on:log-saved="this.reset();var d=document.getElementById('log-sheet-dialog');if(d)d.setAttribute('hidden','');"
        class="flex flex-col gap-4"
    >
        {% include "components/_log_form_body.html.jinja2" with context %}
    </form>
</div>
{% endif %}
