<section class="rounded-card border border-border bg-surface-1 p-4">
    <h2 class="text-lg font-semibold">{{ strings.ADMIN_VISITOR_HEADING }}</h2>
    <p class="mt-1 text-sm text-text-secondary">{{ strings.ADMIN_VISITOR_NOTE }}</p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
        <div class="rounded-card bg-surface-2 p-3">
            <p class="text-sm text-text-secondary">{{ strings.ADMIN_VISITOR_TODAY }}</p>
            <p class="text-2xl font-semibold">{{ metrics.today }}</p>
        </div>
        <div class="rounded-card bg-surface-2 p-3">
            <p class="text-sm text-text-secondary">{{ strings.ADMIN_VISITOR_WEEK }}</p>
            <p class="text-2xl font-semibold">{{ metrics.week }}</p>
        </div>
        <div class="rounded-card bg-surface-2 p-3">
            <p class="text-sm text-text-secondary">{{ strings.ADMIN_VISITOR_MONTH }}</p>
            <p class="text-2xl font-semibold">{{ metrics.month }}</p>
        </div>
    </div>
</section>

{% include "components/_admin_period_nav.html.jinja2" with context %}

<section class="grid gap-4 md:grid-cols-2">
    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h2 class="font-semibold">{{ strings.ADMIN_COUNTRIES_HEADING }}</h2>
        <dl class="mt-3 flex flex-col gap-2">
            {% for country in countries %}
            <div class="flex justify-between gap-3 text-sm">
                <dt class="text-text-secondary">{{ country.country }}</dt>
                <dd class="font-semibold">{{ country.total }}</dd>
            </div>
            {% endfor %}
        </dl>
    </div>
    <div class="rounded-card border border-border bg-surface-1 p-4">
        <h2 class="font-semibold">{{ strings.ADMIN_REFERRERS_HEADING }}</h2>
        <dl class="mt-3 flex flex-col gap-2">
            {% for referrer in referrers %}
            <div class="flex justify-between gap-3 text-sm">
                <dt class="truncate text-text-secondary">{{ referrer.source }}</dt>
                <dd class="font-semibold">{{ referrer.total }}</dd>
            </div>
            {% endfor %}
        </dl>
    </div>
</section>

{% include "components/_admin_recent_visitors.html.jinja2" with context %}
{% include "components/_admin_recent_content.html.jinja2" with context %}
