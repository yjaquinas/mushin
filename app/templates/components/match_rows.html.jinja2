{#
  Match-list sub-form row group — repeatable bouts (opponent, score, result)
  for a `match_list` field on a tournament entry. Rows are addable/removable
  via HTMX fragments that swap the whole row group, carrying already-entered
  values along (hx-include="closest form" or this group's inputs).

  Result chip selection uses CSS :has(input:checked) for styling; the radio
  input inside each <label> is toggled by native <label> click behavior.

  On submit, the parent form's POST reads `match_opponent_{field.id}_{i}` /
  `match_score_{field.id}_{i}` / `match_result_{field.id}_{i}` for each row
  index in `rows` and persists via competition.add_matches.

  Context: activity_id, field (id, label), rows (list of
  {opponent, score, result} — result is "win" | "loss" | "draw" | "").
#}
<div id="match-rows-{{ field.id }}" class="flex flex-col gap-3">
    <span class="text-caption font-medium text-text-secondary">{{ field.label }}</span>

    {% for row in rows %}
        <fieldset class="flex flex-col gap-2 rounded-card border border-border p-3">
            <legend class="sr-only">{{ field.label }} {{ loop.index }}</legend>

            <div class="flex flex-col gap-1">
                <label for="match_opponent_{{ field.id }}_{{ loop.index0 }}" class="text-caption font-medium text-text-secondary">
                    {{ strings.MATCH_LIST_OPPONENT_LABEL }}
                </label>
                <input
                    type="text"
                    id="match_opponent_{{ field.id }}_{{ loop.index0 }}"
                    name="match_opponent_{{ field.id }}_{{ loop.index0 }}"
                    value="{{ row.opponent }}"
                    class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
                >
            </div>

            <div class="flex flex-col gap-1">
                <label for="match_score_{{ field.id }}_{{ loop.index0 }}" class="text-caption font-medium text-text-secondary">
                    {{ strings.MATCH_LIST_SCORE_LABEL }}
                </label>
                <input
                    type="text"
                    id="match_score_{{ field.id }}_{{ loop.index0 }}"
                    name="match_score_{{ field.id }}_{{ loop.index0 }}"
                    value="{{ row.score }}"
                    class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
                >
            </div>

            <div class="flex flex-col gap-1">
                <span class="text-caption font-medium text-text-secondary">
                    {{ strings.MATCH_LIST_RESULT_LABEL }}
                </span>
                <div class="flex flex-wrap gap-2">
                    {% for value, text in (
                        ("win", strings.MATCH_RESULT_WIN),
                        ("loss", strings.MATCH_RESULT_LOSS),
                        ("draw", strings.MATCH_RESULT_DRAW),
                    ) %}
                        <label
                            class="chip"
                            aria-pressed="{{ 'true' if row.result == value else 'false' }}"
                        >
                            <input
                                type="radio"
                                name="match_result_{{ field.id }}_{{ loop.index0 }}"
                                value="{{ value }}"
                                class="sr-only"
                                {% if row.result == value %}checked{% endif %}
                            >
                            {{ text }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            <button
                type="button"
                hx-post="/activities/{{ activity_id }}/match-rows/{{ field.id }}/remove/{{ loop.index0 }}"
                hx-include="#match-rows-{{ field.id }}"
                hx-target="#match-rows-{{ field.id }}"
                hx-swap="outerHTML"
                class="min-h-tap self-start rounded-button border border-border bg-surface-1 px-3 text-caption font-medium text-text-secondary transition hover:bg-surface-2"
            >
                {{ strings.MATCH_LIST_REMOVE_ROW }}
            </button>
        </fieldset>
    {% endfor %}

    <button
        type="button"
        hx-post="/activities/{{ activity_id }}/match-rows/{{ field.id }}/add"
        hx-include="#match-rows-{{ field.id }}"
        hx-target="#match-rows-{{ field.id }}"
        hx-swap="outerHTML"
        class="min-h-tap self-start rounded-button border border-border bg-surface-1 px-3 text-body font-medium text-text-primary transition hover:bg-surface-2"
    >
        {{ strings.MATCH_LIST_ADD_ROW }}
    </button>
</div>
