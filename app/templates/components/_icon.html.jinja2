{# Inline Lucide outline icons.

Usage: {{ icon('swords', size=20) }}

Renders a decorative `<svg stroke="currentColor" fill="none" aria-hidden="true">`
sized via width/height attributes. Monochrome by inheritance — never an
icon-specific color token (see component-patterns skill, "Icon system").

Add new icons by dropping in the Lucide outline path data (stroke-width 2,
viewBox 0 0 24 24). Unrecognized names fall back to `circle-dot`. #}

{% macro icon(name, size=20) %}
{%- if name == 'swords' -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"></polyline>
  <line x1="13" y1="19" x2="19" y2="13"></line>
  <line x1="16" y1="16" x2="20" y2="20"></line>
  <line x1="19" y1="21" x2="21" y2="19"></line>
  <polyline points="14.5 6.5 18 3 21 3 21 6 17.5 9.5"></polyline>
  <line x1="5" y1="14" x2="9" y2="18"></line>
  <line x1="7" y1="17" x2="4" y2="20"></line>
  <line x1="3" y1="19" x2="5" y2="21"></line>
</svg>
{%- elif name == 'book-open' -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  <path d="M12 7v14"></path>
  <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path>
</svg>
