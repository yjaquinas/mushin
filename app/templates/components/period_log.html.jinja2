{#
  Day-grouped chronological log for the current history period, newest day
  first. Each entry row has a stable .entry-row wrapper so the edit-in-place
  flow can swap it via hx-target="closest .entry-row" / hx-swap="outerHTML".

  The pencil edit button is shown only when is_owner is truthy.

  Context:
    history        — history context (history.log: [{"day": "YYYY-MM-DD", "entries": [...]}])
    activity_id   int    — owning sub-tally (needed for edit-route URLs)
    is_owner       bool   — True when the current session user owns this sub-tally
#}
{% from "components/_icon.html.jinja2" import icon %}

<div class="flex flex-col gap-3">
    {% if not history.log %}
        <p class="text-caption text-text-muted">{{ strings.HISTORY_LOG_EMPTY }}</p>
    {% else %}
        {% for day_group in history.log %}
            <div class="flex flex-col gap-1">
                <p class="text-caption font-medium text-text-muted">{{ day_group.day }}</p>
                <ul class="flex flex-col gap-1">
                    {% for entry in day_group.entries %}
                        <li class="entry-row flex items-center justify-between gap-2">
                            <span class="text-body text-text-primary">
                                <span class="text-caption text-text-muted">
                                    {%- if entry.time_known == 1 -%}
                                        {{ entry.occurred_at | format_entry_time }}
                                    {%- endif -%}
                                </span>
                                {%- if entry.memo %}<span class="{% if entry.time_known == 1 %}ms-2{% endif %}">{{ entry.memo }}</span>{% endif %}
                            </span>
                            {% if is_owner %}
                                <button
                                    type="button"
                                    aria-label="{{ strings.ENTRY_EDIT }}"
                                    hx-get="/activities/{{ activity_id }}/entries/{{ entry.id }}/edit"
                                    hx-target="closest .entry-row"
                                    hx-swap="outerHTML"
                                    class="min-h-tap min-w-tap flex shrink-0 items-center justify-center rounded text-text-muted transition hover:text-text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
                                >{{ icon('pencil', size=16) }}</button>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    {% endif %}
</div>
