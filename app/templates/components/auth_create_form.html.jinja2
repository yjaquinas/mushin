{#
  Create-account form — username + password + optional recovery email +
  required consent checkbox. Standalone-renderable: re-asserts the Log in /
  Create account toggle above itself.

  Submits to POST /auth/signup with hx-swap="none" (form field `consent`,
  required checkbox — _require_consent rejects with 400 if unchecked; the
  endpoint returns JSON, not HTML). app/static/js/auth-form.js's
  MushinAuth.handle reads the response: on success it redirects to the user's
  /@{username} profile via the response's `redirect_url` field (if a guest
  session cookie is present, /auth/signup upgrades that guest in-place — zero
  data migration); on 409 (username/email taken) or 400
  (invalid shape / consent) it writes the JSON `detail` message into the
  form's [data-auth-error] element — the form itself is never swapped, so
  the entered username and email are preserved.

  Context:
    error (str, optional) — initial inline error message, for parity when
    this fragment is server-rendered directly (currently always empty; the
    JS path fills [data-auth-error] client-side).
#}
<div id="auth-form" class="flex flex-col gap-4">
    {% include "components/auth_tabs.html.jinja2" with context %}

    <form
        hx-post="/auth/signup"
        hx-swap="none"
        hx-on::after-request="MushinAuth.handle(event)"
        class="flex flex-col gap-4"
    >
        <div class="flex flex-col gap-1">
            <label for="create-username" class="text-caption font-medium text-text-secondary">
                {{ strings.ENTRY_FIELD_USERNAME }}
            </label>
            <input
                type="text"
                id="create-username"
                name="username"
                required
                value="{{ username | default('') }}"
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            />
        </div>
        <input hidden autocomplete="username" />

        <div class="flex flex-col gap-1">
            <label for="create-password" class="text-caption font-medium text-text-secondary">
                {{ strings.ENTRY_FIELD_PASSWORD }}
            </label>
            <input
                type="password"
                id="create-password"
                name="password"
                required
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            />
        </div>

        <div class="flex flex-col gap-1">
            <label for="create-email" class="text-caption font-medium text-text-secondary">
                {{ strings.ENTRY_FIELD_EMAIL }}
            </label>
            <input
                type="email"
                id="create-email"
                name="email"
                autocomplete="email"
                value="{{ email | default('') }}"
                class="min-h-tap rounded-input border border-border bg-surface-1 px-3 py-2 text-body text-text-primary focus-visible:outline-2"
            >
            <p class="text-micro text-text-muted">{{ strings.ENTRY_FIELD_EMAIL_HELP }}</p>
        </div>

        <label for="create-consent" class="flex min-h-tap items-center gap-2 text-caption text-text-secondary">
            <input
                type="checkbox"
                id="create-consent"
                name="consent"
                value="true"
                required
                class="size-5 rounded-input border border-border focus-visible:outline-2"
            />
            {{ strings.ENTRY_CONSENT_CHECKBOX }}
        </label>

        <p data-auth-error class="text-caption text-danger" role="alert" {% if not error %}hidden{% endif %}>{{ error | default('') }}</p>

        <button
            type="submit"
            hx-disabled-elt="this"
            class="min-h-tap w-full rounded-button bg-brand px-4 py-3 text-title font-semibold text-surface-1 transition focus-visible:outline-offset-2 disabled:opacity-60"
        >
            {{ strings.ENTRY_CREATE_SUBMIT }}
        </button>
    </form>
</div>
