{#
  Activity card — name header + the same Counts/Streaks grid as the detail
  screen's Summary card. Used both on the home page (per activity) and as
  the HTMX fragment that swaps in for a freshly created activity (see
  POST /activities).

  Context: `card` (see app.routes.web._build_card_context, needs `counts`
  and `streaks`).

  Only the `linked` branch is rendered — every current caller passes
  `linked=True`. There is no chrome-less/unlinked variant any more: the
  former hero-numeral zone on activity_detail.html.jinja2 and
  public_activity.html.jinja2 was dropped as redundant with the Summary
  card already on those pages (see meetings/ for the build that retired it).
#}
{% if card.linked %}
<article id="card-{{ card.id }}">
    <a
        href="/activities/{{ card.id }}"
        class="flex flex-col gap-2 rounded-card transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-border-strong"
    >
        {% if card.show_breadcrumb %}
        <header class="flex flex-col gap-0.5 px-1">
            <span class="text-caption text-text-muted">{{ card.category_name }}</span>
        </header>
        {% endif %}

        {% with activity_id=card.id, counts=card.counts, streaks=card.streaks, is_owner=false, card_name=card.name %}
        {% include "components/stats_summary.html.jinja2" with context %}
        {% endwith %}
    </a>
</article>
{% endif %}
