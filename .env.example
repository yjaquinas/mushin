# Mushin — environment variables
# Copy to .env (dev) or /opt/mushin/.env (prod, chmod 600)
# NEVER commit .env

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Database
DATABASE_PATH=./data/app.db  # dev: relative; prod: /opt/mushin/data/app.db

# Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# Kakao OAuth (Korean default login — Kakao developers console)
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# KAKAO_REDIRECT_URI=https://mushin.aqnas.xyz/auth/kakao/callback

# Naver OAuth (optional)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# NAVER_REDIRECT_URI=https://mushin.aqnas.xyz/auth/naver/callback

# Brevo SMTP (if sending mail)
# BREVO_API_KEY=
# MAIL_FROM=no-reply@aqnas.xyz

# Cloudflare (for Caddy DNS challenge — prod only, usually in systemd EnvironmentFile)
# CLOUDFLARE_API_TOKEN=
