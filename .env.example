# Mushin — environment variables
# Copy to .env (dev) or /opt/mushin/.env (prod, chmod 600)
# NEVER commit .env

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Database
DATABASE_PATH=./data/app.db  # dev: relative; prod: /opt/mushin/data/app.db

# Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# --- Auth (Task 4) ---------------------------------------------------------
# Signed-session cookie key. REQUIRED — the app refuses to sign sessions
# without it. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-with-a-long-random-string

# Gates the Google OAuth routes. While unset or "false" (the default),
# /auth/{provider}/authorize and /callback return 404 — the product is
# guest-only and social sign-in is hidden. Set "true" to re-enable OAuth.
# OAUTH_ENABLED=false

# Google OAuth — scope "openid email profile". Google Cloud console.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# GOOGLE_REDIRECT_URI=https://mushin.aqnas.xyz/auth/google/callback

# Optional: set to a public username to show "See an example record" on the entry screen
# DEMO_PROFILE_USERNAME=

# Brevo SMTP (if sending mail)
# BREVO_API_KEY=
# MAIL_FROM=no-reply@aqnas.xyz

# Cloudflare (for Caddy DNS challenge — prod only, usually in systemd EnvironmentFile)
# CLOUDFLARE_API_TOKEN=
