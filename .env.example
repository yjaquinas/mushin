# Mushin — environment variables
# Copy to .env (dev) or /opt/mushin/.env (prod, chmod 600)
# NEVER commit .env

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Database
DATABASE_PATH=./data/app.db  # dev: relative; prod: /opt/mushin/data/app.db

# Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=

# --- Auth (Task 4) ---------------------------------------------------------
# Signed-session cookie key. REQUIRED — the app refuses to sign sessions
# without it. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-with-a-long-random-string

# Gates the Google OAuth routes. While unset or "false" (the default),
# /auth/{provider}/authorize and /callback return 404 — the product is
# guest-only and social sign-in is hidden. Set "true" to re-enable OAuth.
# OAUTH_ENABLED=false

# --- Admin dashboard ---------------------------------------------------
# HTTP Basic Auth gate for /admin. Username is plain text (not a secret,
# just compared); password is Argon2id-hashed — never store it plaintext.
# Generate a hash: uv run python -c "from app.auth.passwords import hash_password; print(hash_password('your-password-here'))"
# Unset (either value empty) means /admin always 401s.
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# --- Visitor analytics -------------------------------------------------
# Optional: a separate salt for visitor fingerprints. If unset, SESSION_SECRET
# is used. Rotating this salt starts a new visitor identity history.
VISITOR_ANALYTICS_SALT=

# Optional: path to a MaxMind GeoLite2/GeoIP2 City .mmdb file. Without this,
# visitor country/city stays "Unknown" and no network geolocation is attempted.
GEOIP_DATABASE_PATH=
